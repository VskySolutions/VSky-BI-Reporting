    </DataSet>
    <DataSet Name="ProjectPriorityDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>SELECT 
	DD.Id AS ProjectPriorityId,
	DD.DropDownValue AS ProjectPriority
FROM DropDown DD
LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Priorities'
AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectPriorityId">
          <rd:TypeName>System.String</rd:TypeName>
