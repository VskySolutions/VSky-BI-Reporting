          <DataField>ProjectPriority</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectCategoryDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>--SELECT 
	--DD.Id AS ProjectCategoryId,
	--DD.DropDownValue AS ProjectCategory
--FROM DropDown DD
--LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
--WHERE DDT.Type='Project Category'
--AND DDT.Deleted!=1
--ORDER BY DD.DropDownValue

SELECT distinct
	isnull(P.ProjectCategoryId,'') as ProjectCategoryId,
	isnull(ddc.dropdownvalue,'NA') as projectcategory
FROM Projects P
LEFT JOIN DropDown DDC ON DDC.Id=P.ProjectCategoryId and DDC.Deleted!=1
WHERE P.Deleted!=1</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectCategoryId</DataField>
        </Field>
        <Field Name="ProjectCategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectSubCategoryDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>--SELECT 
	--DD.Id AS ProjectSubcategoryId,
	--DD.DropDownValue AS ProjectSubcategory
--FROM DropDown DD
--LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
--WHERE DDT.Type='Project Subcategory' 
--AND DDT.Deleted!=1
--ORDER BY DD.DropDownValue


SELECT DISTINCT
    ISNULL(P.ProjectSubcategoryId, '') AS ProjectSubcategoryId,
    ISNULL(DDC.DropDownValue, 'NA') AS ProjectSubcategory
FROM Projects P
LEFT JOIN DropDown DDC 
    ON DDC.Id = P.ProjectSubcategoryId AND DDC.Deleted != 1
WHERE P.Deleted != 1
ORDER BY ProjectSubcategory</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectSubcategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectSubcategoryId</DataField>
        </Field>
        <Field Name="ProjectSubcategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectSubcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
