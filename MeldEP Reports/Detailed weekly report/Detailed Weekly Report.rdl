  <ReportParameters>
    <ReportParameter Name="FromDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd("d", -((Weekday(Today(), FirstDayOfWeek.Monday) - 1) + 21), Today())</Value>
        </Values>
      </DefaultValue>
      <Prompt>From Timesheet Create Date</Prompt>
      <cl:ComponentMetadata>
        <cl:HideUpdateNotifications>true</cl:HideUpdateNotifications>
      </cl:ComponentMetadata>
    </ReportParameter>
    <ReportParameter Name="ToDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd("d", 7 - Weekday(Today(), FirstDayOfWeek.Monday), Today())</Value>
        </Values>
      </DefaultValue>
      <Prompt>To Timesheet Create Date</Prompt>
      <cl:ComponentMetadata>
        <cl:HideUpdateNotifications>true</cl:HideUpdateNotifications>
      </cl:ComponentMetadata>
    </ReportParameter>
