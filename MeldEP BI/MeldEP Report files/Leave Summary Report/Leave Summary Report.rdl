  <DataSets>
    <DataSet Name="LeaveSummaryReport">
      <Query>
        <DataSourceName>Meldep</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EmployeeName">
            <Value>=Parameters!EmployeeName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>    SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;

    ;WITH LeaveDetails AS (
        SELECT
            EL.EmployeeId,
            EL.FromDate,
            EL.ToDate,
            EL.NoOfLeaves,
            EL.IsPaidLeave,
            DD.DropDownValue AS LeaveType,
            D.DropDownValue  AS LeaveStatus
        FROM EmployeeLeave EL
        LEFT JOIN DropDown DD ON EL.LeaveCategoryId = DD.Id
        LEFT JOIN DropDown D  ON EL.LeaveStatusId   = D.Id
        WHERE EL.Deleted != 1
          AND DD.DropDownValue IN ('Sick','Casual')
          AND EL.ToDate   &gt;= @FromDate
          AND EL.FromDate &lt;= @ToDate
          AND D.DropDownValue IN ('Applied','Sent to Approver','Approved')
    ),

    LeaveUtilization AS (
        SELECT
            LD.EmployeeId,
            MIN(LD.FromDate) AS FirstLeaveDateInRange,
            MAX(LD.ToDate)   AS LastLeaveDateInRange,

            SUM(CASE WHEN LD.IsPaidLeave = 1 AND LD.LeaveType = 'Sick'
                     THEN ISNULL(LD.NoOfLeaves,0) ELSE 0 END) AS UtilizedPaidSickLeaves,

            SUM(CASE WHEN LD.IsPaidLeave = 1 AND LD.LeaveType = 'Casual'
                     THEN ISNULL(LD.NoOfLeaves,0) ELSE 0 END) AS UtilizedPaidCasualLeaves,

            SUM(CASE WHEN LD.IsPaidLeave = 0 AND LD.LeaveType = 'Sick'
                     THEN ISNULL(LD.NoOfLeaves,0) ELSE 0 END) AS UtilizedUnpaidSickLeaves,

            SUM(CASE WHEN LD.IsPaidLeave = 0 AND LD.LeaveType = 'Casual'
                     THEN ISNULL(LD.NoOfLeaves,0) ELSE 0 END) AS UtilizedUnpaidCasualLeaves
        FROM LeaveDetails LD
        GROUP BY LD.EmployeeId
    ),

    CumulativeYTD AS (
        SELECT
            EL.EmployeeId,
            SUM(CASE WHEN DD.DropDownValue = 'Sick'
         THEN ISNULL(EL.NoOfLeaves,0) ELSE 0 END) AS CumPaidSickUsed,

SUM(CASE WHEN DD.DropDownValue = 'Casual'
         THEN ISNULL(EL.NoOfLeaves,0) ELSE 0 END) AS CumPaidCasualUsed
        FROM EmployeeLeave EL
        LEFT JOIN DropDown DD ON EL.LeaveCategoryId = DD.Id
        LEFT JOIN DropDown D  ON EL.LeaveStatusId   = D.Id
        WHERE EL.Deleted != 1
          AND DD.DropDownValue IN ('Sick','Casual')
          AND YEAR(EL.FromDate) = YEAR(@FromDate)
          AND EL.FromDate &lt;= @ToDate
          AND D.DropDownValue IN ('Applied','Sent to Approver','Approved')
        GROUP BY EL.EmployeeId
    ),

    Credits AS (
        SELECT 
            LC.EmployeeId,

            SUM(CASE WHEN D.DropDownValue = 'Paid'
                     AND LC.CreditReason = 'Yearly'
                     THEN ISNULL(LC.SickLeaves,0) ELSE 0 END) AS AllocatedPaidSickLeaves,

            SUM(CASE WHEN D.DropDownValue = 'Paid'
                     AND LC.CreditReason &lt;&gt; 'Yearly'
                     THEN ISNULL(LC.SickLeaves,0) ELSE 0 END) AS AddedPaidSickLeaves,

            SUM(CASE WHEN D.DropDownValue = 'Paid'
                     AND LC.CreditReason = 'Yearly'
                     THEN ISNULL(LC.CasualLeaves,0) ELSE 0 END) AS AllocatedPaidCasualLeaves,

            SUM(CASE WHEN D.DropDownValue = 'Paid'
                     AND LC.CreditReason &lt;&gt; 'Yearly'
                     THEN ISNULL(LC.CasualLeaves,0) ELSE 0 END) AS AddedPaidCasualLeaves,

            SUM(CASE WHEN D.DropDownValue = 'Unpaid'
                     THEN ISNULL(LC.SickLeaves,0) ELSE 0 END) AS AllocatedUnpaidSickLeaves,

            SUM(CASE WHEN D.DropDownValue = 'Unpaid'
                     THEN ISNULL(LC.CasualLeaves,0) ELSE 0 END) AS AllocatedUnpaidCasualLeaves
        FROM LeaveCredit LC
        INNER JOIN DropDown D ON LC.LeaveTypeId = D.Id
        WHERE LC.LeaveCreditsForYear BETWEEN YEAR(@FromDate) AND YEAR(@ToDate)
          AND LC.Deleted != 1
        GROUP BY LC.EmployeeId
    )

    SELECT
        @FromDate AS ReportFromDate,
        @ToDate   AS ReportToDate,

        E.Id AS EmployeeId,
        P.FirstName + ' ' + P.LastName AS EmployeeName,

        LU.FirstLeaveDateInRange,
        LU.LastLeaveDateInRange,

        NULLIF(COALESCE(C.AllocatedPaidSickLeaves,0),0) AS AllocatedPaidSickLeaves,
        NULLIF(COALESCE(C.AddedPaidSickLeaves,0),0)     AS AddedPaidSickLeaves,
        NULLIF(COALESCE(C.AllocatedPaidSickLeaves,0)
             + COALESCE(C.AddedPaidSickLeaves,0),0)     AS TotalPaidSickLeaves,

        NULLIF(COALESCE(LU.UtilizedPaidSickLeaves,0),0) AS UtilizedPaidSickLeaves,

        NULLIF(
            (COALESCE(C.AllocatedPaidSickLeaves,0)
           + COALESCE(C.AddedPaidSickLeaves,0))
           - COALESCE(CY.CumPaidSickUsed,0),0)          AS BalancePaidSick,

        NULLIF(COALESCE(C.AllocatedPaidCasualLeaves,0),0) AS AllocatedPaidCasualLeaves,
        NULLIF(COALESCE(C.AddedPaidCasualLeaves,0),0)     AS AddedPaidCasualLeaves,
        NULLIF(COALESCE(C.AllocatedPaidCasualLeaves,0)
             + COALESCE(C.AddedPaidCasualLeaves,0),0)     AS TotalPaidCasualLeaves,

        NULLIF(COALESCE(LU.UtilizedPaidCasualLeaves,0),0) AS UtilizedPaidCasualLeaves,

        NULLIF(
            (COALESCE(C.AllocatedPaidCasualLeaves,0)
           + COALESCE(C.AddedPaidCasualLeaves,0))
           - COALESCE(CY.CumPaidCasualUsed,0),0)         AS BalancePaidCasual,

        NULLIF(COALESCE(C.AllocatedUnpaidSickLeaves,0),0)   AS AllocatedUnpaidSickLeaves,
        NULLIF(COALESCE(LU.UtilizedUnpaidSickLeaves,0),0)   AS UtilizedUnpaidSickLeaves,
        NULLIF(COALESCE(C.AllocatedUnpaidCasualLeaves,0),0) AS AllocatedUnpaidCasualLeaves,
        NULLIF(COALESCE(LU.UtilizedUnpaidCasualLeaves,0),0) AS UtilizedUnpaidCasualLeaves

    FROM Employee E
    INNER JOIN Person P ON P.Id = E.PersonId
    LEFT JOIN Credits C ON C.EmployeeId = E.Id
    LEFT JOIN LeaveUtilization LU ON LU.EmployeeId = E.Id
    LEFT JOIN CumulativeYTD CY ON CY.EmployeeId = E.Id
    WHERE E.Active = 1
    and E.Siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' -- Vsky SiteID
      AND E.Id IN (@EmployeeName)
            
        
    ORDER BY EmployeeName;</CommandText>
      </Query>
      <Fields>
        <Field Name="ReportFromDate">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ReportFromDate</DataField>
        </Field>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="ReportToDate">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ReportToDate</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="AllocatedPaidSickLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>AllocatedPaidSickLeaves</DataField>
        </Field>
        <Field Name="AddedPaidSickLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>AddedPaidSickLeaves</DataField>
        </Field>
        <Field Name="FirstLeaveDateInRange">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>FirstLeaveDateInRange</DataField>
        </Field>
        <Field Name="TotalPaidSickLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalPaidSickLeaves</DataField>
        </Field>
        <Field Name="UtilizedPaidSickLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>UtilizedPaidSickLeaves</DataField>
        </Field>
        <Field Name="LastLeaveDateInRange">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>LastLeaveDateInRange</DataField>
        </Field>
        <Field Name="AllocatedPaidCasualLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>AllocatedPaidCasualLeaves</DataField>
        </Field>
        <Field Name="AddedPaidCasualLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>AddedPaidCasualLeaves</DataField>
        </Field>
        <Field Name="TotalPaidCasualLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalPaidCasualLeaves</DataField>
        </Field>
        <Field Name="UtilizedPaidCasualLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>UtilizedPaidCasualLeaves</DataField>
        </Field>
        <Field Name="BalancePaidSick">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>BalancePaidSick</DataField>
        </Field>
        <Field Name="AllocatedUnpaidSickLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>AllocatedUnpaidSickLeaves</DataField>
        </Field>
        <Field Name="UtilizedUnpaidSickLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>UtilizedUnpaidSickLeaves</DataField>
        </Field>
        <Field Name="AllocatedUnpaidCasualLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>AllocatedUnpaidCasualLeaves</DataField>
        </Field>
        <Field Name="UtilizedUnpaidCasualLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>UtilizedUnpaidCasualLeaves</DataField>
        </Field>
        <Field Name="BalancePaidCasual">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>BalancePaidCasual</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!EmployeeId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!EmployeeName.Value()</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="EmployeeName1">
      <Query>
        <DataSourceName>Meldep</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT distinct
        E.Id AS id,
        P.FirstName+' '+
        P.LastName AS EmployeeName
        
  FROM Employee e
     JOIN EmployeeStatus es ON e.Id = es.EmployeeId
     JOIN Dropdown dd ON dd.Id = es.EmployeeStatusId
	JOIN Employeetype et ON e.Id = et.EmployeeId
    JOIN Dropdown emptype ON emptype.Id = et.EmployeetypeId
      JOIN Person p ON e.PersonId = p.Id
  WHERE emptype.DropdownValue not in ( 'On Contract', 'Consultant','Close')
    and dd.dropdownvalue= 'Current'
      AND e.Deleted != 1
     AND e.Active=1
	  and e.id NOT IN('1376F665-F831-4A7E-8502-6A6D0DBE01B4','50d748b8-5e03-4f14-ba6b-f4fadfaafea1')       
order by EmployeeName</CommandText>
      </Query>
      <Fields>
        <Field Name="id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>id</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
      </Fields>
    </DataSet>
