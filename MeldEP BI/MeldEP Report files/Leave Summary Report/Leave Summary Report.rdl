          <Textbox Name="Textbox46">
            <rd:DefaultName>Textbox46</rd:DefaultName>
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="The report displays data from " 
&amp; Format(Parameters!FromDate.Value, "MMMM dd, yyyy") 
&amp; " to " 
&amp; Format(Parameters!ToDate.Value, "MMMM dd, yyyy") 
&amp; ". It shows utilized leaves within the selected date range (day, month, and year), while other leave details are shown for the selected year(s)." 
&amp; vbCrLf &amp;

"The highlighted cells indicate a violation:" &amp; vbCrLf &amp;
"The employee has either used more paid leave than allocated, taken unpaid leave while corresponding paid leave is still available, or utilized unpaid leave exceeding the allocated unpaid leave."</Value>
                    <Style>
                      <FontStyle>Italic</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
            </Paragraphs>
            <Top>7.40833mm</Top>
            <Left>0.62579mm</Left>
            <Height>6mm</Height>
            <Width>308.89791mm</Width>
            <ZIndex>1</ZIndex>
            <Visibility>
              <Hidden>=IIF(Parameters!SelectView.Value="summary",False,True)</Hidden>
            </Visibility>
            <Style>
              <Border>
                <Style>None</Style>
              </Border>
              <PaddingLeft>2pt</PaddingLeft>
              <PaddingRight>2pt</PaddingRight>
              <PaddingTop>2pt</PaddingTop>
              <PaddingBottom>2pt</PaddingBottom>
            </Style>
          </Textbox>
          <Textbox Name="ReportTitle2">
            <rd:WatermarkTextbox>Title</rd:WatermarkTextbox>
            <rd:DefaultName>ReportTitle</rd:DefaultName>
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="The Leave Report provides an overview of employee leave applications from "
&amp; Format(Parameters!FromDate.Value, "dd-MMM-yyyy")
&amp; " to "
&amp; Format(Parameters!ToDate.Value, "dd-MMM-yyyy")
&amp; ". It includes the applied date, leave duration, number of days, type of leave (paid/unpaid), current leave status, and the name of the approver. This report helps track and manage employee leave records efficiently."</Value>
                    <Style>
                      <FontStyle>Italic</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Left</TextAlign>
                </Style>
              </Paragraph>
            </Paragraphs>
            <Top>4.63986cm</Top>
            <Left>0.06258cm</Left>
