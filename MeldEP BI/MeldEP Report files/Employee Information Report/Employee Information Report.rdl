  <DataSets>
    <DataSet Name="Employee_Information">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Employee">
            <Value>=Parameters!Employee.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TypeName">
            <Value>=Parameters!TypeName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>sp_BI_Employee_Information</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="Id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Id</DataField>
        </Field>
        <Field Name="EmployeeCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeCode</DataField>
        </Field>
        <Field Name="StartDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>StartDate</DataField>
        </Field>
        <Field Name="EndDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>EndDate</DataField>
        </Field>
        <Field Name="EmployeeStatusName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeStatusName</DataField>
        </Field>
        <Field Name="EmployeeTypeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeTypeName</DataField>
        </Field>
        <Field Name="note">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>note</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Employee">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
 DISTINCT 
           e.id as EmpID,
             CONCAT(P.FirstName, ' ', P.LastName) AS EmployeeName

FROM Employee e

LEFT OUTER JOIN EmployeeStatus es 
                     ON e.Id = es.EmployeeId

LEFT OUTER JOIN Dropdown dd 
                     ON dd.Id = es.EmployeeStatusId

LEFT OUTER JOIN Person p 
                     ON e.PersonId = p.Id

ORDER BY EmployeeName;</CommandText>
      </Query>
      <Fields>
        <Field Name="EmpID">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmpID</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Status">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT 
    ds.DropDownValue AS StatusName
FROM EmployeeStatus es
JOIN DropDown ds ON es.EmployeeStatusId = ds.Id
WHERE 
    (es.Deleted IS NULL OR es.Deleted = 0)
    AND (ds.Deleted IS NULL OR ds.Deleted = 0)
ORDER BY ds.DropDownValue;</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>StatusName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TypeName">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT dt.DropDownValue AS TypeName
FROM EmployeeType et
JOIN DropDown dt ON et.EmployeeTypeId = dt.Id
WHERE 
    (et.Deleted IS NULL OR et.Deleted = 0)
    AND (dt.Deleted IS NULL OR dt.Deleted = 0)
    AND et.EndDate IS NULL
ORDER BY dt.DropDownValue;</CommandText>
      </Query>
      <Fields>
        <Field Name="TypeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TypeName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
