                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>="This report displays a weekly summary of timesheet hours for employees from " 
&amp; FORMAT(Parameters!FromDate.Value, "MM/dd/yyyy") 
&amp; " to " 
&amp; FORMAT(Parameters!ToDate.Value, "MM/dd/yyyy") 
&amp; " and based on the organizational hierarchy currently available in the system. Results are shown based on the selected team lead. Some team members may not appear if their hierarchy details are not yet updated."</Value>
                        <Style>
                          <FontStyle>Italic</FontStyle>
                          <FontFamily>Times New Roman</FontFamily>
                          <FontSize>12pt</FontSize>
                          <FontWeight>Normal</FontWeight>
                          <TextDecoration>None</TextDecoration>
                          <Color>#000000</Color>
                        </Style>
                      </TextRun>
                    </TextRuns>
                    <Style />
                  </Paragraph>
