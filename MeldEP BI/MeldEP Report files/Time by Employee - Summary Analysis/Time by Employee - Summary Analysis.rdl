  <ReportParameters>
    <ReportParameter Name="FromDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd("d",
        1 - DatePart("w", Today(), vbMonday) - 7,
        Today()
)</Value>
        </Values>
      </DefaultValue>
      <Prompt>From Timesheet Date</Prompt>
      <cl:ComponentMetadata>
        <cl:HideUpdateNotifications>true</cl:HideUpdateNotifications>
      </cl:ComponentMetadata>
    </ReportParameter>
    <ReportParameter Name="ToDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd("d",
        7 - DatePart("w", Today(), vbMonday) - 7,
        Today()
)</Value>
        </Values>
      </DefaultValue>
      <Prompt>To Timesheet Date</Prompt>
      <cl:ComponentMetadata>
        <cl:HideUpdateNotifications>true</cl:HideUpdateNotifications>
      </cl:ComponentMetadata>
    </ReportParameter>
