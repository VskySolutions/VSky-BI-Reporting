  <DataSources>
    <DataSource Name="MeldEPLive">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=67.211.217.118;Initial Catalog=Meldep_Live_v3-2</ConnectString>
        <Prompt>Specify a user name and password for data source DataSource1:</Prompt>
      </ConnectionProperties>
      <rd:DataSourceID>2e26bcf9-2976-47e2-837c-b69ba411ee22</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Leads_Deatils_DS">
      <Query>
        <DataSourceName>MeldEPLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LeadName">
            <Value>=Parameters!LeadName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Company">
            <Value>=Parameters!Company.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@LeadReference">
            <Value>=Parameters!LeadReference.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@LeadSource">
            <Value>=Parameters!LeadSource.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select p.firstname+' '+p.lastname as Leadname,
c.name Company,
l.leadreference as reference,
dd.dropdownvalue as source,
l.leadarrivaldate,
AL.ACTIVITYDATE ,
AL.ActivityNote 
from lead l
inner join person p on p.id = l.personid
inner join company c on c.id = l.companyid
inner join dropdown dd on dd.id= l.leadsourceid
left join leadactivitylogs AL on AL.leadsid= l.id
WHERE P.ID IN (@LeadName)
and l.leadarrivaldate between @FromDate and @ToDate
AND l.companyid in (@Company)
and l.leadreference in (@LeadReference)
and l.leadsourceid in (@LeadSource)
order by leadarrivaldate desc</CommandText>
      </Query>
      <Fields>
        <Field Name="Leadname">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Leadname</DataField>
        </Field>
        <Field Name="Company">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Company</DataField>
        </Field>
        <Field Name="reference">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>reference</DataField>
        </Field>
        <Field Name="source">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>source</DataField>
        </Field>
        <Field Name="leadarrivaldate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>leadarrivaldate</DataField>
        </Field>
        <Field Name="ACTIVITYDATE">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ACTIVITYDATE</DataField>
        </Field>
        <Field Name="ActivityNote">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActivityNote</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="LeadName_DD">
      <Query>
        <DataSourceName>MeldEPLive</DataSourceName>
        <CommandText>SELECT P.ID as LeadID, 
P.FIRSTNAME+' '+P.LASTNAME AS LeadName
FROM Person P

INNER JOIN LEAD l on l.personid = P.ID</CommandText>
      </Query>
      <Fields>
        <Field Name="LeadID">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>LeadID</DataField>
        </Field>
        <Field Name="LeadName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>LeadName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Lead_Reference_DD">
      <Query>
        <DataSourceName>MeldEPLive</DataSourceName>
        <CommandText>SELECT DISTINCT LeadReference
FROM Lead
WHERE LeadReference IS NOT NULL
  AND TRIM(LeadReference) &lt;&gt; '';</CommandText>
      </Query>
      <Fields>
        <Field Name="LeadReference">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>LeadReference</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Company_DD">
      <Query>
        <DataSourceName>MeldEPLive</DataSourceName>
        <CommandText>SELECT C.ID, C.NAME AS CompanyName FROM COMPANY C
INNER JOIN LEAD L ON L.COMPANYID = C.ID
WHERE C.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---VSky SiteID
ORDER BY COMPANYNAME ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="ID">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ID</DataField>
        </Field>
        <Field Name="CompanyName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CompanyName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Lead_Source_DD">
      <Query>
        <DataSourceName>MeldEPLive</DataSourceName>
        <CommandText>SELECT distinct l.leadsourceid, d.DROPDOWNVALUE AS LeadSource FROM lead l
INNER JOIN dropdown d ON l.LEADSOURCEID = d.ID
where l.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---VSky siteID
order by leadsource </CommandText>
      </Query>
      <Fields>
        <Field Name="leadsourceid">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>leadsourceid</DataField>
        </Field>
        <Field Name="LeadSource">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>LeadSource</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
