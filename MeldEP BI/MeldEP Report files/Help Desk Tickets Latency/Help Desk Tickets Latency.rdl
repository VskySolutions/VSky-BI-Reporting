    <DataSet Name="EmployeeDropDown">
      <Query>
        <DataSourceName>MelEP_Live</DataSourceName>
        <CommandText>select

	E.Id as EmployeeId,

	E.PersonId,

	P.FirstName + ' ' + P.LastName as EmployeeName

from Employee E


inner join Person P on P.Id = E.PersonId

where 
    E.Deleted != 1 
AND  E.Active =1
	and  E.ReleaseDate is null

order by P.FirstName + ' ' + P.LastName
 </CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="PersonId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PersonId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
