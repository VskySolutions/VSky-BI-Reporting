    <DataSet Name="ProjectDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT
P.Id AS ProjectId,
P.[Name] AS Project
FROM Projects P
WHERE 
P.Deleted!=1 
AND P.Active=1
ORDER BY Project</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ModuleDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--SELECT 
--'' AS ProjectModuleId,
--'NA' AS ProjectModule 
--UNION

SELECT
PM.Id AS ProjectModuleId,
PM.[Name] AS ProjectModule
FROM ProjectModules PM
WHERE 
PM.Deleted!=1 
--AND PM.ProjectId IN (@Projects)
ORDER BY ProjectModule</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectModuleId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectModuleId</DataField>
        </Field>
        <Field Name="ProjectModule">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectModule</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TaskDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--SELECT
--'' AS TaskId,
--'NA' AS Task
--UNION

SELECT
PT.Id AS TaskId,
PT.[Name] AS Task
FROM ProjectTasks PT
WHERE 
PT.Deleted!=1 
--AND PT.ProjectModuleId IN (@ProjectModules)
ORDER BY Task</CommandText>
      </Query>
      <Fields>
        <Field Name="TaskId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskId</DataField>
        </Field>
        <Field Name="Task">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Task</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH EmployeeDetails AS (
SELECT 
        E.Id AS EmployeeId,
		P.FirstName+' '+P.LastName AS EmployeeName,
		ES.EmployeeStatusId AS StatusId,
		DD.DropDownValue AS Status,
       ROW_NUMBER()OVER (PARTITION BY E.Id ORDER BY ES .StartDate DESC) AS Row_Num
    FROM Employee E
	INNER JOIN Person P ON P.Id=E.PersonId AND P.Deleted!=1
	LEFT JOIN EmployeeStatus ES ON ES.EmployeeId=E.Id
	LEFT JOIN DropDown DD ON DD.ID=ES.EmployeeStatusId
    WHERE 
		ES.Deleted != 1 AND E.Deleted!=1
)
SELECT 
ED.EmployeeId,
ED.EmployeeName
FROM EmployeeDetails ED
WHERE Row_Num=1 AND ED.Status='Current'
ORDER BY EmployeeName</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CustomerData">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH ProjectDetailsList AS (
    SELECT DISTINCT
        CASE 
            WHEN P.Active = 1 THEN 1
            ELSE 0
        END AS StatusId,
        CASE 
            WHEN P.Active = 1 THEN 'Active'
            ELSE 'Inactive'
        END AS Status,
        CPL.CustomerId,
        C.CustomerName
    FROM Projects P
    JOIN VW_CustomerProjectList CPL ON P.Id = CPL.Id
    JOIN VW_CustomerList C ON C.Id = CPL.CustomerId
    WHERE P.Deleted != 1
)
SELECT Distinct
    PD.CustomerId, 
    PD.CustomerName
FROM ProjectDetailsList PD
--WHERE PD.StatusId IN (@Status)
ORDER BY PD.CustomerName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectActiveStatus">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT
                CASE 
		WHEN P.Active=1 THEN 1
		WHEN P.Active=0 THEN 0
	END AS StatusId,
	CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status
FROM Projects P
WHERE
	P.Deleted!=1 
ORDER BY Status</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectStatusData">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>select distinct pr.ProjectStatusId as 'ProjectId', 
       dd.dropdownvalue as 'Project Status'
from Projects pr
inner join dropdown dd
      on pr.ProjectStatusId = dd.id
order by dd.dropdownvalue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project_Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ActivityNameData">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT
    pa.Name AS ActivityName
FROM ProjectActivities pa
INNER JOIN Projects p ON p.Id = pa.ProjectId
INNER JOIN VW_CustomerProjectList CPL ON CPL.Id = p.Id
WHERE  
    pa.ActivityStatusId IS NOT NULL
    AND p.Deleted != 1
   -- AND (CASE WHEN p.Active = 1 THEN 1 ELSE 0 END) IN (@Status)
    --AND CPL.CustomerId IN (@Customer)
ORDER BY pa.Name</CommandText>
      </Query>
      <Fields>
        <Field Name="ActivityName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActivityName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ActivityStatus">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT '' AS ActivityStatusId, 'NA' AS ActivityStatusName
UNION
SELECT 
    id AS ActivityStatusId, 
    DropDownValue AS ActivityStatusName
FROM Dropdown
WHERE Id IN (SELECT DISTINCT activitystatusid FROM ProjectActivities)
ORDER BY ActivityStatusName</CommandText>
      </Query>
      <Fields>
        <Field Name="ActivityStatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActivityStatusId</DataField>
        </Field>
        <Field Name="ActivityStatusName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActivityStatusName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectPriorityData">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
	DD.Id AS ProjectPriorityId,
	DD.DropDownValue AS ProjectPriority
FROM DropDown DD
LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Priorities'
AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectPriorityId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectPriorityId</DataField>
        </Field>
        <Field Name="ProjectPriority">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectPriority</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="WeekEnd">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Month">
            <Value>=Parameters!Month.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT 
    dd.TheLastOfWeek AS WeekEnding,  -- actual value (DATE)
   FORMAT(DATEADD(DAY, 1, TheLastOfWeek), 'MM/dd/yyyy') AS WeekEndingLabel
FROM DimDate dd
WHERE 
    YEAR(dd.TheLastOfWeek) = @Year
    AND MONTH(dd.TheLastOfWeek) = @Month
ORDER BY dd.TheLastOfWeek DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="WeekEnding">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>WeekEnding</DataField>
        </Field>
        <Field Name="WeekEndingLabel">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekEndingLabel</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Year">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <CommandText>SELECT DISTINCT YEAR(TheDate) AS Year
FROM DimDate
WHERE YEAR(TheDate) IN (YEAR(GETDATE()), YEAR(GETDATE()) - 1)
ORDER BY Year DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Month">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <CommandText>SELECT DISTINCT 
    MONTH(TheDate) AS MonthNumber,
    DATENAME(MONTH, TheDate) AS MonthName
FROM DimDate
ORDER BY MonthNumber;</CommandText>
      </Query>
      <Fields>
        <Field Name="MonthNumber">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>MonthNumber</DataField>
        </Field>
        <Field Name="MonthName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Employee_Parameter">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@UserEmail">
            <Value>=Parameters!UserEmail.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
    E.Id AS EmployeeId,
    P.FirstName + ' ' + P.LastName AS EmployeeName
FROM Employee E
JOIN Person P ON P.Id = E.PersonId AND P.Deleted != 1
  

WHERE 
    E.Deleted != 1
    AND E.Active = 1
 AND e.siteid='779c5524-d53a-47ed-960c-dd4c14e98a8e' --Elixir UK SitedID
AND
    (
     
-- Admin → see all employees
        
@UserEmail IN (
 SELECT Email
            
FROM (
                
VALUES 
  ('suvarna.bhamare@elixiruk.com')     ) AS AdminTable(Email)
   
 )

       
 -- Employee → see only themselves
       
 OR E.officialEmail = @UserEmail
    )
       </CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
