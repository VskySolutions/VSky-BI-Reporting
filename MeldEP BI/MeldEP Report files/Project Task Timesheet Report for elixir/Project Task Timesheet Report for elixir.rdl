  <DataSets>
    <DataSet Name="TimesheetDetailDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@WeekEnding">
            <Value>=Parameters!WeekEnding.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@UserEmail">
            <Value>=Parameters!UserEmail.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EmployeeName">
            <Value>=Parameters!EmployeeName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SELECT 
    FORMAT(t.TimesheetDate, 'MM/dd/yyyy') AS [Date],  
    FORMAT(DATEADD(DAY, 1, TheLastOfWeek), 'MM/dd/yyyy') AS WeekEnding,
    DATENAME(WEEKDAY, t.TimesheetDate) AS DayName,
    tl.ProjectId AS ProjectId,
    p.[Name] AS Project,   
    tl.ProjectModuleId AS ProjectModuleId,
    pm.[Name] AS ProjectModule,
    tl.ProjectTaskId AS TaskId,
    pt.[Name] AS Task,
    tl.ProjectActivityId AS ProjectActivityId,
    pa.[Name] AS Activity,
    tl.Description AS ActivityDetails,
    e.Id AS EmployeeId,
    Per.FirstName + ' ' + Per.LastName AS [Resource],
    tl.[Hours] AS ActualHours,
    tl.BillableHours AS BillableHours,
    
    pt.StartDate AS [Activity Start Date],
    pt.EndDate AS [Activity End Date],
    ddStatus.DropDownValue AS [Activity Status],
    e.officialemail as Email

FROM Timesheet t
LEFT JOIN TimesheetLines tl ON (t.Id = tl.TimesheetId)

LEFT JOIN Projects p ON tl.ProjectId = p.Id
LEFT JOIN ProjectModules pm ON tl.ProjectModuleId = pm.Id
LEFT JOIN ProjectTasks pt ON tl.ProjectTaskId = pt.Id
LEFT JOIN ProjectActivities pa ON tl.ProjectActivityId = pa.Id
 AND pa.ActivityStatusId IS NOT NULL --- filtering only the existing data for project activities
LEFT JOIN [DimDate] dd ON t.TimesheetDate = dd.TheDate
LEFT JOIN AspNetUsers anu ON tl.CreatedById = anu.Id
LEFT JOIN Person Per ON anu.PersonId = Per.Id
LEFT JOIN Employee e ON (e.PersonId = Per.Id AND (e.Deleted IS NULL OR e.Deleted = 0))

-- New join for Activity Status
LEFT JOIN DropDown ddStatus ON ddStatus.Id = pa.ActivityStatusId

-- Existing mapping from Activity Status Report
LEFT JOIN VW_CustomerProjectList CPL WITH (FORCESEEK) ON CPL.Id = p.Id

WHERE 
e.siteid='779c5524-d53a-47ed-960c-dd4c14e98a8e' --- Elixir UK SiteID
   AND dd.TheLastOfWeek IN (@WeekEnding)
    AND (t.Deleted = 0 OR t.Deleted IS NULL) 
    AND (tl.Deleted = 0 OR tl.Deleted IS NULL)

AND 
(
 -- EMPLOYEE: Can only see their own data, always
        
(
  @UserEmail NOT IN (SELECT Email FROM (VALUES ('suvarna.bhamare@elixiruk.com') ) AS AdminTable(Email) )
            
AND e.officialemail = @UserEmail
        
)
        
OR
        
-- ADMIN: See all employees by default, OR filter by selected employee
        
(
  @UserEmail IN ('suvarna.bhamare@elixiruk.com')
  AND
  (
      -- No employee selected → show admin's own data
      @EmployeeName IS NULL 
      AND e.officialemail = @UserEmail

      OR

      -- Employee selected → filter
     e.Id IN (
    SELECT TRY_CAST(VALUE AS uniqueidentifier)
    FROM string_split(@EmployeeName, ',')
)
  )
)
)



   
ORDER BY t.TimesheetDate ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="Date">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Date</DataField>
        </Field>
        <Field Name="WeekEnding">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekEnding</DataField>
        </Field>
        <Field Name="DayName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DayName</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="ProjectModuleId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectModuleId</DataField>
        </Field>
        <Field Name="ProjectModule">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectModule</DataField>
        </Field>
        <Field Name="TaskId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskId</DataField>
        </Field>
        <Field Name="Task">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Task</DataField>
        </Field>
        <Field Name="ProjectActivityId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectActivityId</DataField>
        </Field>
        <Field Name="Activity">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Activity</DataField>
        </Field>
        <Field Name="ActivityDetails">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActivityDetails</DataField>
        </Field>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="Resource">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Resource</DataField>
        </Field>
        <Field Name="ActualHours">
          <rd:TypeName>System.Decimal</rd:TypeName>
