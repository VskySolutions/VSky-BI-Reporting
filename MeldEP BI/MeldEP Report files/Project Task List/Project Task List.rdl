  <DataSets>
    <DataSet Name="ProjectTaskListDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Customer">
            <Value>=Parameters!Customer.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectModules">
            <Value>=Parameters!ProjectModules.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectTasks">
            <Value>=Parameters!ProjectTasks.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH EmployeeTaskEstimates AS (
    SELECT 
        PT.Id AS TaskId,
        P.FirstName + ' ' + P.LastName AS EmployeeName,
        SUM(PA.EstimateHours) AS TotalHours
    FROM 
        ProjectTasks PT
    LEFT JOIN 
        ProjectActivities PA ON PA.TaskId = PT.Id AND PA.ProjectId=PT.ProjectId AND PA.ProjectModuleId=PT.ProjectModuleId AND PA.Deleted != 1
    LEFT JOIN 
        Employee E ON E.Id = PA.AssignedToId AND E.Deleted != 1 
	LEFT JOIN EmployeeStatus ES ON ES.EmployeeId=E.Id AND ES.Deleted!=1
    LEFT JOIN 
        Person P ON P.Id = E.PersonId AND P.Deleted != 1
    WHERE 
        PT.Deleted != 1
    GROUP BY 
        PT.Id, P.FirstName, P.LastName
),
WorkedEmployees AS (
    SELECT 
        PT.Id AS TaskId,
        P.FirstName + ' ' + P.LastName AS EmployeeName,
        SUM(TL.Hours) AS TotalHours
    FROM 
        ProjectTasks PT
    LEFT JOIN 
        TimesheetLines TL ON TL.ProjectTaskId = PT.Id AND TL.ProjectId=PT.ProjectId AND TL.ProjectModuleId=PT.ProjectModuleId AND TL.Deleted != 1
    LEFT JOIN 
        Timesheet T ON T.Id = TL.TimesheetId AND T.Deleted != 1
    LEFT JOIN 
        AspNetUsers A ON A.Id = T.CreatedById AND A.Deleted != 1
    LEFT JOIN 
        Person P ON P.Id = A.PersonId AND P.Deleted != 1
    WHERE 
        PT.Deleted != 1
    GROUP BY 
        PT.Id, P.FirstName, P.LastName
)

SELECT 
	P.Id AS ProjectId,
	P.Name AS ProjectName,
	PM.Id as ProjectModuleId,
	ISNULL(PM.Name,'NA') AS ProjectModuleName,
	PT.Id AS ProjectTaskId,
	ISNULL(PT.Name,'NA') AS ProjectTaskName,
	P.CustomerId AS CustomerId,
    ISNULL(C.Name, 'NA') AS CustomerName,
    P.ProjectStatusId AS ProjectStatusId,
    SDD.DropDownValue AS ProjectStatus,
    CASE 
        WHEN P.Active = 1 THEN 1
        WHEN P.Active = 0 THEN 0
    END AS StatusId,
    CASE 
        WHEN P.Active = 1 THEN 'Active'
        WHEN P.Active = 0 THEN 'Inactive'
    END AS Status,
	ISNULL(ETE.AssignedTo, 'NA') AS AssignedTo,
	ISNULL(WK.WorkedBy, 'NA') AS WorkedBy
FROM Projects P
LEFT JOIN ProjectModules PM ON PM.ProjectId=P.Id AND PM.Deleted!=1
LEFT JOIN ProjectTasks PT ON PT.ProjectId=P.Id AND PM.Id=PT.ProjectModuleId AND PT.Deleted!=1
LEFT JOIN CompanyCustomers CC ON CC.Id = P.CustomerId
LEFT JOIN Company C ON C.Id = CC.CompanyId
LEFT JOIN DropDown SDD ON SDD.Id = P.ProjectStatusId
LEFT JOIN (
    SELECT 
        TaskId,
        STRING_AGG(EmployeeName + ' (' + CAST(TotalHours AS NVARCHAR(10)) + ')', ', ') AS AssignedTo
    FROM 
        EmployeeTaskEstimates
    GROUP BY 
        TaskId
) ETE ON ETE.TaskId = PT.Id
LEFT JOIN (
    SELECT 
        TaskId,
        STRING_AGG(EmployeeName + ' (' + CAST(TotalHours AS NVARCHAR(10)) + ')', ', ') AS WorkedBy
    FROM 
        WorkedEmployees
    GROUP BY TaskId
) WK ON WK.TaskId = PT.Id
WHERE P.Deleted!=1 
AND (ISNULL(P.CustomerId, 'NULL') IN (@Customer)) 
AND P.ProjectStatusId IN (@ProjectStatus)
AND ISNULL(P.Id,'NULL') IN (@Projects)
AND (ISNULL(PM.Id,'NULL') IN (@ProjectModules)) 
AND (ISNULL(PT.Id,'NULL') IN (@ProjectTasks)) </CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
        <Field Name="ProjectModuleId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectModuleId</DataField>
        </Field>
        <Field Name="ProjectModuleName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectModuleName</DataField>
        </Field>
        <Field Name="ProjectTaskId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectTaskId</DataField>
        </Field>
        <Field Name="ProjectTaskName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectTaskName</DataField>
        </Field>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
        <Field Name="ProjectStatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatusId</DataField>
        </Field>
        <Field Name="ProjectStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatus</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
        <Field Name="AssignedTo">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>AssignedTo</DataField>
        </Field>
        <Field Name="WorkedBy">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WorkedBy</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!StatusId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!Status.Value()</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="StatusDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>SELECT DISTINCT
                CASE 
		WHEN P.Active=1 THEN 1
		WHEN P.Active=0 THEN 0
	END AS StatusId,
	CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status
FROM Projects P
WHERE
	P.Deleted!=1 
ORDER BY Status</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CustomerDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH CustomerDetails AS (
SELECT
	ISNULL(P.CustomerId,'NULL') AS CustomerId,
	ISNULL(C.[Name],'NA') AS CustomerName,
                CASE 
		WHEN P.Active=1 THEN 1
		WHEN P.Active=0 THEN 0
	END AS StatusId,
	CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status

FROM Projects P 
LEFT JOIN CompanyCustomers CC ON CC.Id=P.CustomerId
LEFT JOIN Company C ON C.Id=CC.CompanyId
WHERE
	P.Deleted!=1 
)

SELECT DISTINCT

CD.CustomerId,
CD.CustomerName
FROM CustomerDetails CD
WHERE CD.StatusId IN (@Status)
ORDER BY CustomerName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectStatusDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
	DD.Id AS ProjectStatusId,
	DD.DropDownValue AS ProjectStatus
FROM DropDown DD
LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Status'
AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectStatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatusId</DataField>
        </Field>
        <Field Name="ProjectStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatus</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Customer">
            <Value>=Parameters!Customer.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH ProjectDetailsList AS(
SELECT DISTINCT
	P.Id AS ProjectId,
	P.[Name] AS ProjectName,
                P.CustomerId AS CustomerId,
	CASE 
			WHEN P.Active=1 THEN 1
			WHEN P.Active=0 THEN 0
	END AS StatusId,
		CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status,P.ProjectStatusId AS ProjectStatusId,
	SDD.DropDownValue AS ProjectStatus

FROM Projects P 
LEFT JOIN CompanyCustomers CC ON CC.Id=P.CustomerId
LEFT JOIN DropDown SDD ON SDD.Id=P.ProjectStatusId
WHERE
	P.Deleted!=1 
)
SELECT '' AS ProjectId, 'NA' AS ProjectName UNION
SELECT
	PD.ProjectId,
	PD.ProjectName
FROM ProjectDetailsList PD
WHERE 
          PD.StatusId IN (@Status)
          AND ISNULL(PD.CustomerId,'NULL') IN (@Customer)
          AND PD.ProjectStatusId IN (@ProjectStatus)
ORDER BY ProjectName</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectModuleDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT '' AS ProjectId,'NA' AS Project,
'' AS ModuleId,
'NA' AS ModuleName UNION
SELECT DISTINCT
P.Id AS ProjectId,
P.Name AS Project,
ISNULL(PM.Id,'NULL') AS ModuleId,
ISNULL(PM.Name,'NA') AS ModuleName
FROM Projects P
LEFT JOIN ProjectModules PM ON PM.ProjectId=P.Id AND PM.Deleted!=1
WHERE P.Deleted!=1
AND ISNULL(P.Id,'NULL') IN (@Projects)
ORDER BY ModuleName</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ModuleId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ModuleId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="ModuleName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ModuleName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectTaskDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectModules">
            <Value>=Parameters!ProjectModules.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
'' AS ModuleId,
'NA' AS ModuleName,
'' AS TaskId,
'NA' AS TaskName UNION
SELECT DISTINCT
ISNULL(PM.Id,'NULL') AS ModuleId,
ISNULL(PM.Name,'NA') AS ModuleName,
ISNULL(PT.Id,'NULL') AS TaskId,
ISNULL(PT.Name,'NA') AS TaskName
FROM Projects P
LEFT JOIN ProjectModules PM ON PM.ProjectId=P.Id AND PM.Deleted!=1
LEFT JOIN ProjectTasks PT ON PT.ProjectId=P.Id AND PM.Id=PT.ProjectModuleId AND PT.Deleted!=1
WHERE P.Deleted!=1
AND ISNULL(PM.Id,'NULL') IN (@ProjectModules)
ORDER BY TaskName</CommandText>
      </Query>
      <Fields>
        <Field Name="ModuleId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ModuleId</DataField>
        </Field>
        <Field Name="TaskId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskId</DataField>
        </Field>
        <Field Name="ModuleName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ModuleName</DataField>
        </Field>
        <Field Name="TaskName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
