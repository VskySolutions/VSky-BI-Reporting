  <DataSets>
    <DataSet Name="ListOfTestCasesDS">
      <Query>
        <DataSourceName>Meldep_LiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectName">
            <Value>=Parameters!ProjectName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TestPlanName">
            <Value>=Parameters!TestPlanName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TestedBy">
            <Value>=Parameters!TestedBy.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TestCaseStatus">
            <Value>=Parameters!TestCaseStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    p.Id AS ProjectId,
    p.Active AS ProjectStatus,
    p.Name AS [Projects],
    tp.Id AS TestPlanId,
    tp.Name AS [Test Plan Name],
    tc.TestCaseNumber AS [TestCaseID],
    tc.Name AS [TestCaseName],
    dd.Id AS StatusId,
    dd.Dropdownvalue AS [TestCaseStatus],
    tc.Testedby AS TestedById,
    pe.FirstName + ' ' + pe.LastName AS [TestedBy],
    FORMAT(tc.TestedDate, 'MM/dd/yy') AS TestedDate,
    tc.CreatedById AS CreatedById,
    per.FirstName + ' ' + per.LastName AS [CreatedBy],
    FORMAT(tc.CreatedOnUtc, 'MM/dd/yy') AS [CreatedDate],
    tc.Description AS [Description],
    tc.Steps AS [Steps],
    tc.ExpectedResult AS [ExpectedResult],
    tc.ActualResult AS [ActualResult]
FROM [dbo].[TestCase] tc
LEFT JOIN [dbo].[TestPlan] tp ON tc.PlanId = tp.Id
LEFT JOIN [dbo].[Projects] p ON tc.ProjectId = p.Id
LEFT JOIN [dbo].[DropDown] dd ON tc.StatusId = dd.Id
LEFT JOIN [dbo].[Employee] emp ON tc.TestedBy = emp.Id
LEFT JOIN [dbo].[Person] pe ON emp.PersonId = pe.Id
LEFT JOIN [dbo].[AspNetUsers] asp ON asp.Id=tc.CreatedById
LEFT JOIN [dbo].[Person] per ON per.Id = asp.PersonId
WHERE tc.Deleted != 1
AND (p.Id IN (@ProjectName))
AND (p.Active IN (@ProjectStatus)) 
AND (tp.Id IN (@TestPlanName))
AND (tc.Testedby IN (@TestedBy))
AND (dd.dropdownvalue IN (@TestCaseStatus))
AND ((tc.TestedDate BETWEEN @FromDate AND @ToDate))</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectStatus">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>ProjectStatus</DataField>
        </Field>
        <Field Name="Projects">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Projects</DataField>
        </Field>
        <Field Name="TestPlanId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestPlanId</DataField>
        </Field>
        <Field Name="Test_Plan_Name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Test Plan Name</DataField>
        </Field>
        <Field Name="TestCaseID">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>TestCaseID</DataField>
        </Field>
        <Field Name="TestCaseName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestCaseName</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="TestCaseStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestCaseStatus</DataField>
        </Field>
        <Field Name="TestedById">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestedById</DataField>
        </Field>
        <Field Name="TestedBy">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestedBy</DataField>
        </Field>
        <Field Name="TestedDate">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestedDate</DataField>
        </Field>
        <Field Name="CreatedById">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CreatedById</DataField>
        </Field>
        <Field Name="CreatedBy">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CreatedBy</DataField>
        </Field>
        <Field Name="CreatedDate">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CreatedDate</DataField>
        </Field>
        <Field Name="Description">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Description</DataField>
        </Field>
        <Field Name="Steps">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Steps</DataField>
        </Field>
        <Field Name="ExpectedResult">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ExpectedResult</DataField>
        </Field>
        <Field Name="ActualResult">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActualResult</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectDropdownDS">
      <Query>
        <DataSourceName>Meldep_LiveV32</DataSourceName>
        <CommandText>SELECT 
	Id AS ProjectId,
	Name AS ProjectName
FROM Projects
WHERE Deleted !=1
ORDER BY Name;</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TestPlanNameDropdownDS">
      <Query>
        <DataSourceName>Meldep_LiveV32</DataSourceName>
        <CommandText>SELECT
	Id AS TestPlanId,
	Name AS TestPlanName
FROM TestPlan
WHERE Deleted !=1</CommandText>
      </Query>
      <Fields>
        <Field Name="TestPlanId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestPlanId</DataField>
        </Field>
        <Field Name="TestPlanName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestPlanName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TestCaseStatusDropdownDS">
      <Query>
        <DataSourceName>Meldep_LiveV32</DataSourceName>
        <CommandText>select
	dd.Id StatusId,
	dd.dropdownvalue AS [TestCaseStatus]
from DropDown dd
left Outer join DropDownType ddt on dd.DropDownTypeId = ddt.id
where (ddt.Type = 'Test Case Status' AND ddt.Deleted = 0)
Order by DropDownValue ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="TestCaseStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestCaseStatus</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectStatusDropdownDS">
      <Query>
        <DataSourceName>Meldep_LiveV32</DataSourceName>
        <CommandText>SELECT DISTINCT
                CASE 
		WHEN P.Active=1 THEN 1
		WHEN P.Active=0 THEN 0
	END AS StatusId,
	CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status
FROM Projects P
WHERE
	P.Deleted!=1 
ORDER BY Status</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TestedByDropdownDS">
      <Query>
        <DataSourceName>Meldep_LiveV32</DataSourceName>
        <CommandText>Select 
	e.id AS TestedById,
	pe.FirstName + ' ' + pe.LastName AS TestedBy
From Employee e
 LEFT JOIN [dbo].[Person] pe ON e.PersonId = pe.Id
 where e.Deleted = 0 AND pe.deleted = 0
 Order by TestedBy;</CommandText>
      </Query>
      <Fields>
        <Field Name="TestedById">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestedById</DataField>
        </Field>
        <Field Name="TestedBy">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestedBy</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
