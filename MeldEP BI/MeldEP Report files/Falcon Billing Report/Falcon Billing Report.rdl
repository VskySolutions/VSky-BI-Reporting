  <DataSets>
    <DataSet Name="ProjectHoursSummary">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectCategory">
            <Value>=Parameters!ProjectCategory.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectsubCategory">
            <Value>=Parameters!ProjectSubcategory.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Customers">
            <Value>=Parameters!Customers.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectType">
            <Value>=Parameters!ProjectType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectPriority">
            <Value>=Parameters!ProjectPriority.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SELECT 
    p.Name AS ProjectName,
   --ISNULL(ddt.DisplayName, 'No Category') AS CategoryName,
    ISNULL(dd.DropDownValue, 'No Subcategory') AS SubcategoryName,
    YEAR(t.TimesheetDate) AS [Year], 
    MONTH(t.TimesheetDate) AS [Month],
    FORMAT(t.TimesheetDate, 'MMM yyyy') AS MonthYear,  
    SUM(tl.Hours) AS ActualHours
FROM Timesheet t
INNER JOIN TimesheetLines tl ON t.Id = tl.TimesheetId
INNER JOIN Projects p ON p.Id = tl.ProjectId
LEFT JOIN AspNetUsers anu ON tl.CreatedById = anu.Id
LEFT JOIN Person Per ON anu.PersonId = Per.Id
LEFT JOIN Employee e ON e.PersonId = Per.Id AND (e.Deleted IS NULL OR e.Deleted = 0)
LEFT JOIN Project_Employee_Mapping pem ON pem.ProjectId = tl.ProjectId AND pem.EmployeeId = e.Id AND (pem.Deleted = 0 OR pem.Deleted IS NULL)
LEFT JOIN DropDownType ddt 
       ON p.ProjectCategoryId = ddt.Id 
      AND ddt.GroupName = 'ProjectCategory'
LEFT JOIN DropDown dd 
       ON p.ProjectSubcategoryId = dd.Id
WHERE 
    (t.Deleted = 0 OR t.Deleted IS NULL)
    AND (tl.Deleted = 0 OR tl.Deleted IS NULL)
    AND p.Name IS NOT NULL
    AND t.TimesheetDate BETWEEN @FromDate AND @ToDate
    AND ISNULL(p.ProjectCategoryId, '') IN (@ProjectCategory)
    AND ISNULL(p.ProjectSubcategoryId, '') IN (@ProjectsubCategory)
    AND p.CustomerId IN (@Customers)
    AND p.Id IN (@Projects)
    AND p.ProjectStatusId IN (@ProjectStatus)
    AND p.ProjectTypeId IN (@ProjectType)
    AND p.ProjectPriorityId IN (@ProjectPriority)
GROUP BY 
    p.Name,
    --ddt.DisplayName,
    dd.DropDownValue,
    FORMAT(t.TimesheetDate, 'MMM yyyy'),
    YEAR(t.TimesheetDate),
    MONTH(t.TimesheetDate)
    
ORDER BY
    dd.DropDownValue,
    p.Name;</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
        <Field Name="SubcategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubcategoryName</DataField>
        </Field>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
        <Field Name="Month">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Month</DataField>
        </Field>
        <Field Name="MonthYear">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthYear</DataField>
        </Field>
        <Field Name="ActualHours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ActualHours</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectCategoryDD">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>select ''as CategoryId, 
'NA' AS CategoryName
UNION
SELECT DISTINCT 
       CAST(ddt.Id AS VARCHAR(50)) AS CategoryId, 
       ddt.DisplayName AS CategoryName
FROM DropDownType ddt
WHERE ddt.GroupName = 'ProjectCategory'
      --AND ddt.Deleted != 1
ORDER BY CategoryName</CommandText>
      </Query>
      <Fields>
        <Field Name="CategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryId</DataField>
        </Field>
        <Field Name="CategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectSubcategoryDD">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectCategory">
            <Value>=Parameters!ProjectCategory.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>select ''as SubCategoryId,
           'NA' AS Subcategory 
UNION 
SELECT DISTINCT 
       CAST(dd.Id AS VARCHAR(50)) AS SubCategoryId, 
     dd.DropDownValue as Subcategory
FROM DropDownType ddt LEFT JOIN DropDown dd
           ON ddt.Id = dd.DropDownTypeId 
WHERE ddt.GroupName = 'ProjectCategory' 
            --AND ddt.Deleted != 1 
           AND ddt.Id IN (@ProjectCategory) 
ORDER BY Subcategory</CommandText>
      </Query>
      <Fields>
        <Field Name="SubCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubCategoryId</DataField>
        </Field>
        <Field Name="Subcategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Subcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CustomersDD">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH ProjectDetailsList AS (
    SELECT DISTINCT
        CASE 
            WHEN P.Active = 1 THEN 1
            ELSE 0
        END AS StatusId,
        CASE 
            WHEN P.Active = 1 THEN 'Active'
            ELSE 'Inactive'
        END AS Status,
        CPL.CustomerId,
		C.CustomerName
    FROM Projects P
    JOIN VW_CustomerProjectList CPL ON P.Id = CPL.Id
	JOIN  VW_CustomerList C ON C.Id=CPL.CustomerId
    WHERE P.Deleted != 1
)
SELECT distinct PD.CustomerId, PD.CustomerName
FROM ProjectDetailsList PD
--WHERE PD.StatusId IN (@Status)
ORDER BY CustomerName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectDD">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Customers">
            <Value>=Parameters!Customers.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH ProjectDetailsList AS(
SELECT DISTINCT
	P.Id AS ProjectId,
	P.[Name] AS Project,
P.CustomerId

FROM Projects P 
WHERE
	P.Deleted!=1 AND P.Active=1
)
SELECT
	PD.ProjectId,
	PD.Project
FROM ProjectDetailsList PD
WHERE 
          isnull(PD.CustomerId,'') IN (@Customers)
ORDER BY Project</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectWeeklyDescription">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Customers">
            <Value>=Parameters!Customers.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectCategory">
            <Value>=Parameters!ProjectCategory.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectType">
            <Value>=Parameters!ProjectType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectsubCategory">
            <Value>=Parameters!ProjectSubcategory.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectPriority">
            <Value>=Parameters!ProjectPriority.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
WITH WeeksCTE AS (
    SELECT DATEADD(WEEK, DATEDIFF(WEEK, 0, @FromDate), 0) AS WeekStart
    UNION ALL
    SELECT DATEADD(WEEK, 1, WeekStart)
    FROM WeeksCTE
    WHERE DATEADD(DAY, 6, DATEADD(WEEK, 1, WeekStart)) &lt;= @ToDate
),

-- 1️⃣ Actual Data
ActualData AS (
    SELECT
        DATEADD(DAY, - (DATEPART(WEEKDAY, PWPD.WeekDate) + @@DATEFIRST - 2) % 7, PWPD.WeekDate) AS WeekStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,
        PC.DropDownValue AS CategoryName,
        PSC.DropDownValue AS SubcategoryName,
        COALESCE(STRING_AGG(PWPDL.ActualDescription, CHAR(13) + CHAR(10)), 'Data Not Available') AS ActualDescription
    FROM Projects P
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId
    LEFT JOIN DropDown SDD ON SDD.Id = P.ProjectStatusId
    LEFT JOIN DropDown PT ON PT.Id = P.ProjectTypeId
    LEFT JOIN DropDown PP ON PP.Id = P.ProjectPriorityId
    LEFT JOIN DropDown PC ON PC.Id = P.ProjectCategoryId
    LEFT JOIN DropDown PSC ON PSC.Id = P.ProjectSubcategoryId
    WHERE 
        P.Deleted != 1
        AND PWPDL.Deleted != 1
        AND PWPDL.ActualDescription IS NOT NULL
        AND LTRIM(RTRIM(PWPDL.ActualDescription)) &lt;&gt; ''
        AND D.Id = '1CFDEC9F-9C68-4E75-BC4E-E408C5918B1A'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
        AND P.CustomerId IN (@Customers)
        AND P.Id IN (@Projects)
        AND P.ProjectStatusId IN (@ProjectStatus)
        AND P.ProjectTypeId IN (@ProjectType)
        AND P.ProjectPriorityId IN (@ProjectPriority)
        AND ISNULL(P.ProjectCategoryId, '') IN (@ProjectCategory)
        AND ISNULL(P.ProjectSubcategoryId, '') IN (@ProjectsubCategory)
    GROUP BY 
        DATEADD(DAY, - (DATEPART(WEEKDAY, PWPD.WeekDate) + @@DATEFIRST - 2) % 7, PWPD.WeekDate),
        P.Id,
        P.Name,
        P.Active,
        PC.DropDownValue,
        PSC.DropDownValue
),

-- 2️⃣ Expected Data
ExpectedData AS (
    SELECT 
        DATEADD(DAY, - (DATEPART(WEEKDAY, PWPD.WeekDate) + @@DATEFIRST - 2) % 7, PWPD.WeekDate) AS WeekStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,
        PC.DropDownValue AS CategoryName,
        PSC.DropDownValue AS SubcategoryName,
        COALESCE(STRING_AGG(PWPDL.ExpectedDescription, CHAR(13) + CHAR(10)), 'Data Not Available') AS ExpectedDescription
    FROM Projects P
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId
    LEFT JOIN DropDown SDD ON SDD.Id = P.ProjectStatusId
    LEFT JOIN DropDown DPT ON DPT.Id = P.ProjectTypeId
    LEFT JOIN DropDown DPP ON DPP.Id = P.ProjectPriorityId
    LEFT JOIN DropDown PC ON PC.Id = P.ProjectCategoryId
    LEFT JOIN DropDown PSC ON PSC.Id = P.ProjectSubcategoryId
    WHERE 
        P.Deleted != 1
        AND PWPDL.Deleted != 1
        AND PWPDL.ExpectedDescription IS NOT NULL
        AND LTRIM(RTRIM(PWPDL.ExpectedDescription)) &lt;&gt; ''
        AND D.Id = '1CFDEC9F-9C68-4E75-BC4E-E408C5918B1A'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
        AND P.CustomerId IN (@Customers)
        AND P.Id IN (@Projects)
        AND P.ProjectStatusId IN (@ProjectStatus)
        AND P.ProjectTypeId IN (@ProjectType)
        AND P.ProjectPriorityId IN (@ProjectPriority)
        AND ISNULL(P.ProjectCategoryId, '') IN (@ProjectCategory)
        AND ISNULL(P.ProjectSubcategoryId, '') IN (@ProjectsubCategory)
    GROUP BY 
        DATEADD(DAY, - (DATEPART(WEEKDAY, PWPD.WeekDate) + @@DATEFIRST - 2) % 7, PWPD.WeekDate),
        P.Id,
        P.Name,
        P.Active,
        PC.DropDownValue,
        PSC.DropDownValue
),

-- 3️⃣ Merge Unique Projects (with Category + Subcategory)
AllProjects AS (
    SELECT DISTINCT ProjectId, Project, StatusId, Status, CategoryName, SubcategoryName
    FROM (
        SELECT ProjectId, Project, StatusId, Status, CategoryName, SubcategoryName FROM ActualData
        UNION
        SELECT ProjectId, Project, StatusId, Status, CategoryName, SubcategoryName FROM ExpectedData
    ) p
)

-- 4️⃣ Final Result
SELECT
    W.WeekStart AS [Date],
    FORMAT(COALESCE(A.WeekStart, E.WeekStart, W.WeekStart), ' MMM dd yyyy') + 
    ' - ' + FORMAT(DATEADD(DAY, 6, COALESCE(A.WeekStart, E.WeekStart, W.WeekStart)), ' MMM dd yyyy') AS WeekRange,
    P.ProjectId,
    P.Project,
    P.CategoryName,
    P.SubcategoryName,
    P.StatusId,
    P.Status,
    CASE 
        WHEN A.ActualDescription IS NULL OR LTRIM(RTRIM(A.ActualDescription)) = '' THEN '' 
        ELSE A.ActualDescription 
    END AS ActualDescription,
    CASE 
        WHEN E.ExpectedDescription IS NULL OR LTRIM(RTRIM(E.ExpectedDescription)) = '' THEN '' 
        ELSE E.ExpectedDescription 
    END AS ExpectedDescription
FROM WeeksCTE W
CROSS JOIN AllProjects P
LEFT JOIN ActualData A 
    ON A.WeekStart = W.WeekStart AND A.ProjectId = P.ProjectId
LEFT JOIN ExpectedData E
    ON E.WeekStart = W.WeekStart AND E.ProjectId = P.ProjectId
ORDER BY W.WeekStart, P.ProjectId
OPTION (MAXRECURSION 0);</CommandText>
      </Query>
      <Fields>
        <Field Name="Date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>Date</DataField>
        </Field>
        <Field Name="WeekRange">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekRange</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="CategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryName</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="SubcategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubcategoryName</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
        <Field Name="ActualDescription">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActualDescription</DataField>
        </Field>
        <Field Name="ExpectedDescription">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ExpectedDescription</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectTimesheetDetails">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SELECT 
    FORMAT(t.TimesheetDate, 'MM/dd/yyyy') AS [Date],  
    FORMAT(DATEADD(DAY, 1, dd.TheLastOfWeek), 'MM/dd/yyyy') AS WeekEnding, 
    tl.ProjectId AS ProjectId,
    p.[Name] AS Project,
    tl.[Description] AS ActivityDetails,
    e.Id AS EmployeeId,
    Per.FirstName + ' ' + Per.LastName AS [Resource],
    tl.[Hours] AS ActualHours,
    tl.ProjectTaskId AS TaskId,
    pt.Name AS WorkType

FROM Timesheet t
inner JOIN TimesheetLines tl ON t.Id = tl.TimesheetId
inner JOIN Projects p ON tl.ProjectId = p.Id
LEFT JOIN AspNetUsers anu ON tl.CreatedById = anu.Id
LEFT JOIN Person Per ON anu.PersonId = Per.Id
LEFT JOIN Employee e ON e.PersonId = Per.Id AND (e.Deleted IS NULL OR e.Deleted = 0)
LEFT JOIN Project_Employee_Mapping pem ON pem.ProjectId = tl.ProjectId AND pem.EmployeeId = e.Id AND (pem.Deleted = 0 OR pem.Deleted IS NULL)
LEFT JOIN ProjectTasks pt ON tl.ProjectTaskId = pt.Id
LEFT JOIN [DimDate] dd ON t.TimesheetDate = dd.TheDate

where
 t.TimesheetDate BETWEEN @FromDate AND @ToDate
  and (t.Deleted = 0 OR t.Deleted IS NULL)
 AND (tl.Deleted = 0 OR tl.Deleted IS NULL)
 AND  tl.ProjectId IN (@Projects)

ORDER BY t.TimesheetDate ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="Date">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Date</DataField>
        </Field>
        <Field Name="WeekEnding">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekEnding</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="ActivityDetails">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActivityDetails</DataField>
        </Field>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="ActualHours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ActualHours</DataField>
        </Field>
        <Field Name="Resource">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Resource</DataField>
        </Field>
        <Field Name="TaskId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskId</DataField>
        </Field>
        <Field Name="WorkType">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WorkType</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectStatus">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
	DD.Id AS ProjectStatusId,
	DD.DropDownValue AS ProjectStatus
FROM DropDown DD
LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Status'
AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectStatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatusId</DataField>
        </Field>
        <Field Name="ProjectStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatus</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectPriority">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
	DD.Id AS ProjectPriorityId,
	DD.DropDownValue AS ProjectPriority
FROM DropDown DD
LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Priorities'
AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectPriorityId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectPriorityId</DataField>
        </Field>
        <Field Name="ProjectPriority">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectPriority</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectType">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
	DD.Id AS ProjectTypeId,
	DD.DropDownValue AS ProjectType
FROM DropDown DD
LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Type'
AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectTypeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectTypeId</DataField>
        </Field>
        <Field Name="ProjectType">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectType</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="ReportTitle">
            <rd:WatermarkTextbox>Title</rd:WatermarkTextbox>
            <rd:DefaultName>ReportTitle</rd:DefaultName>
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
