  <DataSources>
    <DataSource Name="MeldepLiveV32">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=67.211.217.118;Initial Catalog=Meldep_Live_v3-2</ConnectString>
        <Prompt>Specify a user name and password for data source MeldepDevV32:</Prompt>
      </ConnectionProperties>
      <rd:DataSourceID>401477a0-c466-4f30-88c9-77a76bda7eca</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProjectDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH ProjectDetailsList AS(
SELECT DISTINCT
	P.Id AS ProjectId,
	P.[Name] AS Project,
	CASE 
			WHEN P.Active=1 THEN 1
			WHEN P.Active=0 THEN 0
	END AS StatusId,
		CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status

FROM Projects P 
WHERE
	P.Deleted!=1 
)SELECT '' AS ProjectId, 'NA' AS Project UNION
SELECT
	PD.ProjectId,
	PD.Project
FROM ProjectDetailsList PD
WHERE 
          PD.StatusId IN (@Status)
ORDER BY Project</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="StatusDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>SELECT DISTINCT
                CASE 
		WHEN P.Active=1 THEN 1
		WHEN P.Active=0 THEN 0
	END AS StatusId,
	CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status
FROM Projects P
WHERE
	P.Deleted!=1 
ORDER BY Status</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
