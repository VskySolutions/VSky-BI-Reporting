  <DataSets>
    <DataSet Name="MonthlyPlanReportDataSet">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <CommandText>WITH ProjectHrsCTE as (
	select 
		p.Id,
		p.Name
	from Projects p
	where p.Active=1 and p.Deleted != 1
),
EmployeeDetails AS (
		select
			E.Id as employeeId,
			E.PersonId EPersonId,
			A.Id as aspUId,
			P.FirstName PFName,
			P.LastName as pLastName,
			A.Email as EOEmail
		from Employee E
		inner join AspNetUsers A on A.Email = E.OfficialEmail
		inner join Person P on P.Id = A.PersonId
		where 
			E.Deleted != 1 and 
			A.Deleted != 1 and 
			E.Active = 1 and
			E.ReleaseDate is null
),
DistributedHrs as(
	select 
		pa.ProjectId as ProjectId,
		pa.EstimateHours as ProjEstimateHours,
		FORMAT(pa.TargetMonth, 'MMM-yyyy') AS TargetMonth2,
                                YEAR(pa.TargetMonth) [Year],
    MONTH(pa.TargetMonth) [MONTH],
		pa.AssignedToId as Employee
	FROM [ProjectActivities] pa
	where pa.Deleted !=1 AND pa.ProjectModuleId IS NOT NULL
)
select 
	PCte.Id ProjectId,
	PCte.[Name] ProjectName,
	ed.employeeId EmployeeId,
	ed.PFName + ' '+ed.pLastName EmployeeName,
	Dhrs.TargetMonth2 TargetMonth,
	sum(Dhrs.ProjEstimateHours) [Hours],
                Dhrs.Year,
  
Dhrs.MONTH
from ProjectHrsCTE PCte
left outer join DistributedHrs Dhrs on Dhrs.ProjectId =PCte.Id
inner join EmployeeDetails ed on ed.employeeId = Dhrs.Employee
--where  Dhrs.TargetMonth2 = 'Sep-2024'
group by PCte.Id,PCte.[Name],ed.employeeId,ed.PFName,ed.pLastName,Dhrs.Year,Dhrs.MONTH,Dhrs.TargetMonth2
order by Dhrs.TargetMonth2,PCte.[Name]</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="TargetMonth">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TargetMonth</DataField>
        </Field>
        <Field Name="Hours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Hours</DataField>
        </Field>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
        <Field Name="MONTH">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>MONTH</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!Year.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue>=Parameters!YearDropDown.Value</FilterValue>
          </FilterValues>
        </Filter>
        <Filter>
          <FilterExpression>=Fields!MONTH.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue>=Parameters!MonthDropDown.Value</FilterValue>
          </FilterValues>
        </Filter>
        <Filter>
          <FilterExpression>=Fields!ProjectId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!ProjectDropDown.Value</FilterValue>
          </FilterValues>
        </Filter>
        <Filter>
          <FilterExpression>=Fields!EmployeeId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!EmployeeDropDown.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="YearDataSet">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <CommandText>select Distinct 
	YEAR(pa.TargetMonth) [Year]
FROM 
    [ProjectActivities] pa
 where YEAR(pa.TargetMonth) is not null
 Order By 
	YEAR(pa.TargetMonth) DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MonthDataSet">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <CommandText>select Distinct 
	MONTH(pa.TargetMonth) [MONTH],
	FORMAT(pa.TargetMonth, 'MMMM') AS [MonthName]
FROM 
    [ProjectActivities] pa
 where MONTH(pa.TargetMonth) is not null
 Order By 
	MONTH(pa.TargetMonth)</CommandText>
      </Query>
      <Fields>
        <Field Name="MONTH">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>MONTH</DataField>
        </Field>
        <Field Name="MonthName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectsDataSet">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <CommandText>select 
		p.Id,
		p.Name
	from Projects p
	where p.Active=1 and p.Deleted != 1
	Order by 2</CommandText>
      </Query>
      <Fields>
        <Field Name="Id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Id</DataField>
        </Field>
        <Field Name="Name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Name</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeDropDown">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <CommandText>select
	E.Id as EmployeeId,
	E.PersonId,
	A.Id as AspNetUserId,
	P.FirstName + ' ' + P.LastName as EmployeeName,
	A.Email as EmailAddress
from Employee E
inner join AspNetUsers A on A.Email = E.OfficialEmail
inner join Person P on P.Id = A.PersonId
where 
	E.Deleted != 1 and 
	A.Deleted != 1 and 
	E.Active = 1 and
	E.ReleaseDate is null
order by P.FirstName + ' ' + P.LastName</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="PersonId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PersonId</DataField>
        </Field>
        <Field Name="AspNetUserId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>AspNetUserId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="EmailAddress">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmailAddress</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
