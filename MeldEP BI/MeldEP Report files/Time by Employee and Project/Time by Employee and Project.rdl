  <DataSets>
    <DataSet Name="WeeklyTimesheetSumaaryDataSet">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Month">
            <Value>=Parameters!Month.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@WeekEndDates">
            <Value>=Parameters!WeekEndDates.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SET DATEFIRST 1; -- Monday = 1, Sunday = 7

-- Get last completed Sunday (weekend) for default
WITH LastCompletedWeek AS (
    SELECT TOP 1 TheDate AS WeekEnd
    FROM DimDate
    WHERE DATEPART(WEEKDAY, TheDate) = 7       -- Sunday
      AND YEAR(TheDate) = @Year
      AND MONTH(TheDate) = @Month
      
    ORDER BY TheDate DESC
),

-- Determine week to use (parameter or default)
SelectedWeek AS (
    SELECT TheDate AS WeekEnd
    FROM DimDate
    WHERE TheDate IN (@WeekEndDates)
),

-- Calculate week boundaries (Monday → Sunday)
WeekRange AS (
    SELECT
        DATEADD(DAY, -6, sw.WeekEnd) AS TheFirstOfWeek,  -- Monday
        sw.WeekEnd AS TheLastOfWeek                       -- Sunday
    FROM SelectedWeek sw
),

EmployeeDetails AS (
    SELECT DISTINCT
        e.Id AS EmployeeId,
        p.FirstName + ' ' + p.LastName AS EmployeeName,
        es.EmployeeStatusId AS StatusId,
        dd.DropDownValue AS Status
    FROM Employee e
    INNER JOIN Person p ON p.Id = e.PersonId AND p.Deleted != 1
    LEFT JOIN EmployeeStatus es ON es.EmployeeId = e.Id AND es.Deleted != 1
    LEFT JOIN DropDown dd ON dd.Id = es.EmployeeStatusId AND dd.Deleted != 1 AND dd.DropDownValue = 'Current'
    LEFT JOIN EmployeeType et ON e.Id = et.EmployeeId
    LEFT JOIN DropDown emptype ON emptype.Id = et.EmployeeTypeId
    WHERE e.Deleted != 1 
      AND e.Active = 1
      AND es.EmployeeStatusId IS NOT NULL
      AND emptype.DropDownValue NOT IN ('Ex-Employee','Consultant','Close')
      AND e.Id NOT IN ('1376F665-F831-4A7E-8502-6A6D0DBE01B4',
                       '50d748b8-5e03-4f14-ba6b-f4fadfaafea1',
                       '040B2C55-B056-4D2D-8F26-1E4A94556F0F')
    and dd.dropdownvalue is not null
),

EmployeeWeekMap AS (
    SELECT 
        ed.EmployeeId,
        ed.EmployeeName,
        ed.StatusId,
        ed.Status,
        wr.TheFirstOfWeek,
        wr.TheLastOfWeek
    FROM EmployeeDetails ed
    CROSS JOIN WeekRange wr
),

TimesheetDetail AS (
    SELECT
        t.EmployeeId,
        wr.TheFirstOfWeek,
        wr.TheLastOfWeek,
        SUM(tl.Hours) AS FilledHours,
        tl.description as Details,
        p.name as Project,
        pt.name as projecttask
    FROM Timesheet t
    INNER JOIN TimesheetLines tl ON tl.TimesheetId = t.Id AND tl.Deleted != 1
    INNER JOIN ProjectActivities pa ON pa.Id = tl.ProjectActivityId
    INNER JOIN WeekRange wr ON wr.TheFirstOfWeek &lt;= t.TimesheetDate 
                             AND wr.TheLastOfWeek &gt;= t.TimesheetDate
    INNER JOIN Projects p on p.id=tl.projectid 
    INNER JOIN Projecttasks pt on pt.id=tl.projecttaskid
    WHERE t.TimesheetDate BETWEEN wr.TheFirstOfWeek AND wr.TheLastOfWeek
      AND (t.Deleted = 0 OR t.Deleted IS NULL)
      AND pa.ProjectId IN (@Projects)
    GROUP BY t.EmployeeId, wr.TheFirstOfWeek, wr.TheLastOfWeek, tl.description ,p.name ,pt.name 
),

WeeklySummary AS (
    SELECT 
        ewm.EmployeeId,
        ewm.EmployeeName,
        ewm.StatusId,
        ewm.Status,
        CONVERT(VARCHAR(10), ewm.TheFirstOfWeek, 110) + ' - ' + CONVERT(VARCHAR(10), ewm.TheLastOfWeek, 110) AS WeekInterval,
        ISNULL(td.FilledHours, 0) AS Hours,
        td.details,
        td.project,
        td.projecttask
    FROM EmployeeWeekMap ewm
    LEFT JOIN TimesheetDetail td
        ON td.EmployeeId = ewm.EmployeeId
        AND td.TheFirstOfWeek = ewm.TheFirstOfWeek
        AND td.TheLastOfWeek = ewm.TheLastOfWeek
)

SELECT DISTINCT
    EmployeeId,
    EmployeeName,
    WeekInterval,
    StatusId,
    Hours,
    Details,
    project,
    projecttask
FROM WeeklySummary
ORDER BY EmployeeName, WeekInterval;</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="WeekInterval">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekInterval</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Hours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Hours</DataField>
        </Field>
        <Field Name="Details">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Details</DataField>
        </Field>
        <Field Name="project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>project</DataField>
        </Field>
        <Field Name="projecttask">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projecttask</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!EmployeeId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!Employees.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="StatusDropDownDS">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <CommandText>WITH StatusDetails AS (
SELECT 
        ES.EmployeeStatusId AS StatusId,
		StatusDD.DropDownValue AS Status,
		ROW_NUMBER()OVER(PARTITION BY E.Id ORDER BY ES.StartDate DESC) AS RowNum
    FROM Employee E
	LEFT JOIN EmployeeStatus ES ON E.Id = ES.EmployeeId
    LEFT JOIN DropDown StatusDD ON StatusDD.Id = ES.EmployeeStatusId
    WHERE ES.Deleted!=1
)

SELECT DISTINCT
SD.StatusId,
SD.Status
FROM StatusDetails SD
WHERE SD.RowNum=1 
ORDER BY Status</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectDropDownDS">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Customers">
            <Value>=Parameters!Customers.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH ProjectDetailsList AS (
    SELECT DISTINCT
        P.Id AS ProjectId,
        P.[Name] AS Project,
        CASE 
            WHEN P.Active = 1 THEN 1
            ELSE 0
        END AS StatusId,
        CASE 
            WHEN P.Active = 1 THEN 'Active'
            ELSE 'Inactive'
        END AS Status,
        CPL.CustomerId
    FROM Projects P
    JOIN VW_CustomerProjectList CPL ON P.Id = CPL.Id
    WHERE P.Deleted != 1
)
SELECT PD.ProjectId, PD.Project
FROM ProjectDetailsList PD
WHERE --PD.StatusId IN (@Status) and 
PD.CustomerId IN (@Customers)
ORDER BY Project</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectActiveStatusDropDownDS">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <CommandText>SELECT DISTINCT
                CASE 
		WHEN P.Active=1 THEN 1
		WHEN P.Active=0 THEN 0
	END AS StatusId,
	CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status
FROM Projects P
WHERE
	P.Deleted!=1 
ORDER BY Status</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ClientDropDownDS">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH ProjectDetailsList AS (
    SELECT DISTINCT
        CASE 
            WHEN P.Active = 1 THEN 1
            ELSE 0
        END AS StatusId,
        CASE 
            WHEN P.Active = 1 THEN 'Active'
            ELSE 'Inactive'
        END AS Status,
        CPL.CustomerId,
		C.CustomerName
    FROM Projects P
    JOIN VW_CustomerProjectList CPL ON P.Id = CPL.Id
	JOIN  VW_CustomerList C ON C.Id=CPL.CustomerId
    WHERE P.Deleted != 1
)
SELECT distinct PD.CustomerId, PD.CustomerName
FROM ProjectDetailsList PD
--WHERE PD.StatusId IN (@Status)
ORDER BY CustomerName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
