    <DataSet Name="EmployeeDropDownDS">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TeamLead">
            <Value>=Parameters!TeamLead.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH EmployeeRanked AS (
    SELECT DISTINCT
        E.Id AS EmployeeId,
        P.FirstName + ' ' + P.LastName AS EmployeeName,
        ES.EmployeeStatusId AS StatusId,
        ROW_NUMBER() OVER (PARTITION BY E.Id ORDER BY ES.StartDate DESC) AS RowNum,
        eos.ManagerId
    FROM Employee E
    JOIN EmployeeStatus ES ON E.Id = ES.EmployeeId
    JOIN Dropdown DD ON DD.Id = ES.EmployeeStatusId
    JOIN EmployeeType et ON E.Id = et.EmployeeId
    JOIN Dropdown emptype ON emptype.Id = et.EmployeeTypeId
    JOIN Person P ON P.Id = E.PersonId AND P.Deleted != 1
    LEFT JOIN EmployeeOrgStructure eos ON eos.EmployeeId = E.Id
    LEFT JOIN ProjectActivities PA ON PA.AssignedToId = E.Id AND PA.Deleted != 1

    WHERE 
        E.Deleted != 1
        AND E.Active = 1
        AND DD.DropdownValue = 'Current'
        AND emptype.DropDownValue NOT IN ('Consultant','Close')
        AND PA.ProjectId IN (@Projects)

        -- Team Lead Parameter 
        AND (
                ('NA' IN (@TeamLead) AND eos.ManagerId IS NULL)   -- show employees with no TL
                OR
                (eos.ManagerId IN (@TeamLead))                    -- employees under TL
                OR
                (E.Id IN (@TeamLead))                             -- include TL themselves
            )
)

SELECT DISTINCT
    EmployeeId,
    EmployeeName,
    StatusId
FROM EmployeeRanked
WHERE RowNum = 1
ORDER BY EmployeeName;</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeHalfDayLeave">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@WeekEndDates">
            <Value>=Parameters!WeekEndDates.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Employees">
            <Value>=Parameters!Employees.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH SelectedWeeks AS (
    SELECT TheDate AS WeekEnd
    FROM DimDate
    WHERE TheDate IN (@WeekEndDates)
),
WeekRange AS (
    SELECT
        DATEADD(DAY, -6, WeekEnd) AS TheFirstOfWeek,
        WeekEnd AS TheLastOfWeek
    FROM SelectedWeeks
)
SELECT 
    emplv.id,
    emplv.EmployeeId,
    p.FirstName + ' ' + p.LastName AS EmployeeName,
    SUM(emplv.NoOfLeaves) AS TotalLeaves,
    emplv.FromDate,
    emplv.ToDate,
    emplv.IsHalfDay
FROM EmployeeLeave emplv
JOIN Employee e ON emplv.EmployeeId = e.Id
JOIN Person p ON p.Id = e.PersonId
INNER JOIN DropDown dd ON emplv.LeaveStatusId = dd.Id
INNER JOIN WeekRange wr
       ON emplv.FromDate &lt;= wr.TheLastOfWeek
      AND emplv.ToDate   &gt;= wr.TheFirstOfWeek
WHERE emplv.IsHalfDay = 1
  AND dd.DropDownValue NOT IN ('Decline', 'Cancelled')
  AND emplv.EmployeeId IN (@Employees)
  AND emplv.Deleted = 0
GROUP BY 
    emplv.EmployeeId, 
    p.FirstName + ' ' + p.LastName,
    emplv.FromDate,
    emplv.ToDate,
    emplv.IsHalfDay,
    emplv.id
ORDER BY EmployeeName ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>id</DataField>
        </Field>
        <Field Name="employeeid">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="TotalLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalLeaves</DataField>
        </Field>
        <Field Name="FromDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>FromDate</DataField>
        </Field>
        <Field Name="ToDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ToDate</DataField>
        </Field>
        <Field Name="ishalfday">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>IsHalfDay</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeFullDayLeave">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@WeekEndDates">
            <Value>=Parameters!WeekEndDates.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Employees">
            <Value>=Parameters!Employees.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>-- Full-Day Leave for selected weeks
WITH SelectedWeeks AS (
    SELECT TheDate AS WeekEnd
    FROM DimDate
    WHERE TheDate IN (@WeekEndDates)
),
WeekRange AS (
    SELECT
        DATEADD(DAY, -6, WeekEnd) AS TheFirstOfWeek,  -- Monday
        WeekEnd AS TheLastOfWeek                       -- Sunday
    FROM SelectedWeeks
)
SELECT 
    emplv.EmployeeId,
    p.FirstName + ' ' + p.LastName AS EmployeeName,
    SUM(CAST(emplv.NoOfLeaves AS int)) AS TotalLeaves,
    emplv.IsHalfDay,
    MIN(emplv.FromDate) AS MinDate,
    MAX(emplv.ToDate) AS MaxDate
FROM EmployeeLeave emplv
INNER JOIN Employee e ON emplv.EmployeeId = e.Id
INNER JOIN Person p ON p.Id = e.PersonId
INNER JOIN DropDown dd ON emplv.LeaveStatusId = dd.Id
INNER JOIN WeekRange wr
       ON emplv.FromDate &lt;= wr.TheLastOfWeek
      AND emplv.ToDate   &gt;= wr.TheFirstOfWeek  -- overlap with week
WHERE emplv.IsHalfDay = 0
  AND emplv.EmployeeId IN (@Employees)
  AND dd.DropDownValue NOT IN ('Decline', 'Cancelled')
  AND emplv.Deleted = 0
GROUP BY 
    emplv.EmployeeId, 
    p.FirstName + ' ' + p.LastName,
    emplv.IsHalfDay
ORDER BY EmployeeName ASC;
</CommandText>
      </Query>
      <Fields>
        <Field Name="employeeid">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="TotalLeaves">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>TotalLeaves</DataField>
        </Field>
        <Field Name="ishalfday">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>IsHalfDay</DataField>
        </Field>
        <Field Name="MinDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>MinDate</DataField>
        </Field>
        <Field Name="MaxDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>MaxDate</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TeamLeadDropDown">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 'NA' AS ManagerId, 'NA' AS ManagerName
UNION ALL
SELECT distinct
    eos.ManagerId,
    (pm.FirstName + ' ' + pm.LastName) AS ManagerName
FROM EmployeeOrgStructure eos
LEFT JOIN Employee m
    ON m.Id = eos.ManagerId         
LEFT JOIN Person pm
    ON pm.Id = m.PersonId
order by ManagerName;</CommandText>
      </Query>
      <Fields>
        <Field Name="ManagerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ManagerId</DataField>
        </Field>
        <Field Name="ManagerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ManagerName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="YearDropDown">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT YEAR(TheDate) AS Year
FROM DimDate
WHERE YEAR(TheDate) IN (YEAR(GETDATE()), YEAR(GETDATE()) - 1)
ORDER BY Year DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MonthDropDown">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT 
    MONTH(TheDate) AS MonthNumber,
    DATENAME(MONTH, TheDate) AS MonthName
FROM DimDate
ORDER BY MonthNumber;</CommandText>
      </Query>
      <Fields>
        <Field Name="MonthNumber">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>MonthNumber</DataField>
        </Field>
        <Field Name="MonthName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="WeekEndDatesDropDown">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Month">
            <Value>=Parameters!Month.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>
SET DATEFIRST 1; -- Monday = 1, Sunday = 7

SELECT  
    TheDate AS WeekEnd,                      -- this is the actual value passed to the report
    FORMAT(TheDate, 'MM-dd-yyyy') AS WeekEndLabel  -- this is what the user will see
FROM DimDate
WHERE YEAR(TheDate) = @Year
  AND MONTH(TheDate) = @Month
  AND DATEPART(WEEKDAY, TheDate) = 7  -- Sundays only

ORDER BY TheDate</CommandText>
      </Query>
      <Fields>
        <Field Name="WeekEnd">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>WeekEnd</DataField>
        </Field>
        <Field Name="WeekEndLabel">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekEndLabel</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectWeeklyTimesheetSumaaryDataSet">
      <Query>
        <DataSourceName>Meldep32Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Month">
            <Value>=Parameters!Month.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@WeekEndDates">
            <Value>=Parameters!WeekEndDates.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Employees">
            <Value>=Parameters!Employees.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SET DATEFIRST 1; -- Monday = 1

-- 1. Last Completed Weekend (Sunday)
WITH LastCompletedWeek AS (
    SELECT TOP 1 TheDate AS WeekEnd
    FROM DimDate
    WHERE DATEPART(WEEKDAY, TheDate) = 7
      AND YEAR(TheDate) = @Year
      AND MONTH(TheDate) = @Month
      AND TheDate &lt; GETDATE()
    ORDER BY TheDate DESC
),

-- 2. Selected Week(s)
SelectedWeek AS (
    SELECT TheDate AS WeekEnd
    FROM DimDate
    WHERE TheDate IN (@WeekEndDates)
),

-- 3. Convert WeekEnd → ISO Week (Mon-Sun)
WeekRange AS (
    SELECT
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, sw.WeekEnd), sw.WeekEnd) AS TheFirstOfWeek,
        sw.WeekEnd AS TheLastOfWeek
    FROM SelectedWeek sw
),

-- Project details
ProjectDetails AS (
	SELECT
		P.Id AS ProjectId,
		P.[Name] AS ProjectName,
		CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS ProjectActiveStatusId,
		CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS ProjectActiveStatus,
		P.ProjectStatusId,
		DDS.DropDownValue AS ProjectStatus,
		P.ProjectPriorityId,
		DDP.DropDownValue AS ProjectPriority,
		P.ProjectTypeId,
		DDT.DropDownValue AS ProjectType,
		P.ProjectCategoryId,
		DDC.DropDownValue AS ProjectCategory,
		P.ProjectSubcategoryId,
		DDCS.DropDownValue AS ProjectSubCategory
	FROM Projects P
	LEFT JOIN DropDown DDS ON DDS.Id = P.ProjectStatusId AND DDS.Deleted != 1
	LEFT JOIN DropDown DDP ON DDP.Id = P.ProjectPriorityId AND DDP.Deleted != 1
	LEFT JOIN DropDown DDT ON DDT.Id = P.ProjectTypeId AND DDT.Deleted != 1
	LEFT JOIN DropDown DDC ON DDC.Id = P.ProjectCategoryId AND DDC.Deleted != 1
	LEFT JOIN DropDown DDCS ON DDCS.Id = P.ProjectSubcategoryId AND DDCS.Deleted != 1
	WHERE P.Deleted != 1
),

-- Timesheet summarized by Week
TimesheetDetails AS (
	SELECT 
		tl.ProjectId,
		PD.ProjectName,
		PD.ProjectActiveStatusId,
		PD.ProjectActiveStatus,
		PD.ProjectStatusId,
		PD.ProjectPriorityId,
		PD.ProjectTypeId,
		PD.ProjectCategoryId,
		PD.ProjectSubcategoryId,
		wr.TheFirstOfWeek,
		wr.TheLastOfWeek,
		SUM(tl.Hours) AS FilledHours
	FROM Timesheet t
	INNER JOIN TimesheetLines tl ON tl.TimesheetId = t.Id AND tl.Deleted != 1
	INNER JOIN ProjectDetails PD ON PD.ProjectId = tl.ProjectId
	INNER JOIN AspNetUsers A ON A.Id = tl.CreatedById AND A.Deleted != 1
                INNER JOIN Employee e ON e.PersonId = A.PersonId AND e.Deleted != 1
	--INNER JOIN Employee e ON e.OfficialEmail = A.Email AND e.Deleted != 1
	INNER JOIN WeekRange wr ON t.TimesheetDate BETWEEN wr.TheFirstOfWeek AND wr.TheLastOfWeek
	WHERE (t.Deleted = 0 OR t.Deleted IS NULL)
	  AND e.Id IN (@Employees)
	GROUP BY 
		tl.ProjectId,
		PD.ProjectName,
		wr.TheFirstOfWeek,
		wr.TheLastOfWeek,
		PD.ProjectActiveStatusId,
		PD.ProjectActiveStatus,
		PD.ProjectStatusId,
		PD.ProjectPriorityId,
		PD.ProjectTypeId,
		PD.ProjectCategoryId,
		PD.ProjectSubcategoryId
),

WeekSummary AS (
	SELECT
		ProjectId,
		ProjectName,
		ProjectActiveStatusId,
		ProjectStatusId,
		ProjectPriorityId,
		ProjectTypeId,
		ProjectCategoryId,
		ProjectSubcategoryId,
		FORMAT(TheFirstOfWeek, 'MM.dd.yy') + '-' + FORMAT(TheLastOfWeek, 'MM.dd.yy') AS WeekInterval,
		SUM(ISNULL(FilledHours,0)) AS Hours
	FROM TimesheetDetails
	GROUP BY
		ProjectId,
		ProjectName,
		TheFirstOfWeek,
		TheLastOfWeek,
		ProjectActiveStatusId,
		ProjectStatusId,
		ProjectPriorityId,
		ProjectTypeId,
		ProjectCategoryId,
		ProjectSubcategoryId
)

SELECT *
FROM WeekSummary
WHERE ProjectId IN (@Projects)
ORDER BY ProjectName, WeekInterval;</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
        <Field Name="ProjectActiveStatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>ProjectActiveStatusId</DataField>
        </Field>
        <Field Name="ProjectStatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatusId</DataField>
        </Field>
        <Field Name="ProjectPriorityId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectPriorityId</DataField>
        </Field>
        <Field Name="ProjectTypeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectTypeId</DataField>
        </Field>
        <Field Name="ProjectCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectCategoryId</DataField>
        </Field>
        <Field Name="ProjectSubcategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectSubcategoryId</DataField>
        </Field>
        <Field Name="WeekInterval">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekInterval</DataField>
        </Field>
        <Field Name="Hours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Hours</DataField>
        </Field>
      </Fields>
    </DataSet>
