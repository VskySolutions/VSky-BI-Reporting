  <DataSets>
    <DataSet Name="ListofTestPlanMainDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@TestPlanId">
            <Value>=Parameters!TestPlanId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectName">
            <Value>=Parameters!ProjectName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TestPlanName">
            <Value>=Parameters!TestPlanName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PlanMaker">
            <Value>=Parameters!PlanMaker.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PlanReviewer">
            <Value>=Parameters!PlanReviewer.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    tp.TestPlanNumber,
    tp.ProjectId,
    p.Name AS ProjectName,
    tp.Id AS TestPlanNameId,
    tp.Name AS TestPlanName,
    tp.PlanMakerId,
    pm.FirstName + ' ' + pm.LastName AS PlanMaker,
    tp.PlanReviewerId,
    pr.FirstName + ' ' + pr.LastName AS PlanReviewer,
    tp.Description AS [Description]
FROM TestPlan tp
LEFT JOIN Projects p ON tp.ProjectId = p.Id
LEFT JOIN Employee e_pm ON tp.PlanMakerId = e_pm.Id
LEFT JOIN Person pm ON e_pm.PersonId = pm.Id
LEFT JOIN Employee e_pr ON tp.PlanReviewerId = e_pr.Id
LEFT JOIN Person pr ON e_pr.PersonId = pr.Id
Where tp.Deleted != 1
AND (tp.TestPlanNumber IN (@TestPlanId))
AND (tp.ProjectId IN (@ProjectName))
AND (tp.Id IN (@TestPlanName))
AND (tp.PlanMakerId IN (@PlanMaker))
AND (tp.PlanReviewerId IN (@PlanReviewer))</CommandText>
      </Query>
      <Fields>
        <Field Name="TestPlanNumber">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>TestPlanNumber</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
        <Field Name="TestPlanNameId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestPlanNameId</DataField>
        </Field>
        <Field Name="TestPlanName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestPlanName</DataField>
        </Field>
        <Field Name="PlanMakerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PlanMakerId</DataField>
        </Field>
        <Field Name="PlanMaker">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PlanMaker</DataField>
        </Field>
        <Field Name="PlanReviewerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PlanReviewerId</DataField>
        </Field>
        <Field Name="PlanReviewer">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PlanReviewer</DataField>
        </Field>
        <Field Name="Description">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Description</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TestPlanIdDropdownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>
Select

     TestPlanNumber AS TestPlanId

From TestPlan
Where 
Deleted !=1

Order by TestPlanNumber;</CommandText>
      </Query>
      <Fields>
        <Field Name="TestPlanId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>TestPlanId</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectNameDropdownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>
SELECT
     Id AS ProjectId,
     Name AS ProjectName

FROM Projects

WHERE Deleted !=1

ORDER BY Name;</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TestPlanNameDropdownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>
Select

	Id AS TestPlanNameID,

	Name
 AS TestPlanName
From TestPlan

Where Deleted !=1</CommandText>
      </Query>
      <Fields>
        <Field Name="TestPlanNameID">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestPlanNameID</DataField>
        </Field>
        <Field Name="TestPlanName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TestPlanName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PlanMaker">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>
Select 

	e.id AS PlanMakerId,

	pe.FirstName + ' ' + pe.LastName AS PlanMaker

From Employee e

LEFT JOIN [dbo].[Person] pe ON e.PersonId = pe.Id

where e.Deleted = 0 AND pe.deleted = 0

Order by PlanMaker;</CommandText>
      </Query>
      <Fields>
        <Field Name="PlanMakerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PlanMakerId</DataField>
        </Field>
        <Field Name="PlanMaker">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PlanMaker</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PlanReviewer">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>
Select
 
	e.id AS PlanReviewerId,

	pe.FirstName + ' ' + pe.LastName AS PlanReviewer

From Employee e

LEFT JOIN [dbo].[Person] pe ON e.PersonId = pe.Id

where e.Deleted = 0 AND pe.deleted = 0

Order by PlanReviewer;</CommandText>
      </Query>
      <Fields>
        <Field Name="PlanReviewerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PlanReviewerId</DataField>
        </Field>
        <Field Name="PlanReviewer">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PlanReviewer</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
