            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=Replace(
    Join(
        LookupSet(
            Nothing,
            Nothing,
            IIF(
            Fields!TotalLeaves.Value = 1,
            Fields!EmployeeName.Value &amp; " took total 1 full day leave on " &amp;
            Format(Fields!MinDate.Value, "MM-dd-yyyy"),
            
            Fields!EmployeeName.Value &amp; " took total " &amp;
            Fields!TotalLeaves.Value &amp; " full day leaves from " &amp;
            Format(Fields!MinDate.Value, "MM-dd-yyyy") &amp;  " to " &amp;  Format(Fields!MaxDate.Value, "MM-dd-yyyy")
            ),
            "EmployeeFullDayLeave"
        ),
        "||"
    ),
"||",
"&lt;br/&gt;")</Value>
                    <MarkupType>HTML</MarkupType>
                    <Style />
