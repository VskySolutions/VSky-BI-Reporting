  <DataSets>
    <DataSet Name="Flacon_Projects">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Project">
            <Value>=Parameters!Project.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectSubcategory">
            <Value>=Parameters!ProjectSubcategory.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;

--- List undeleted Projects, Moduels and tasks

SELECT

    p.Name AS ProjectName,

    ISNULL(ddt.DisplayName, 'No Category') AS CategoryName,

    ISNULL(dd.DropDownValue, 'No Subcategory') AS SubcategoryName,

    ISNULL(pm.Name, 'No Module') AS ProjectModuleName,

    ISNULL(pt.Name, 'No Task') AS ProjectTaskName,

    per.firstname+' '+per.lastname as Employee,

    t.TimesheetDate,

    tl.Hours ActualHours,

    tl.description

FROM Projects p

-- Category

LEFT JOIN DropDownType ddt 

       ON p.ProjectCategoryId = ddt.Id

      AND ddt.GroupName = 'ProjectCategory'

-- Subcategory

LEFT JOIN DropDown dd 

       ON p.ProjectSubcategoryId = dd.Id

-- Project Modules

LEFT JOIN ProjectModules pm

       ON p.Id = pm.ProjectId and pm.Deleted &lt;&gt; 1

-- Project Tasks

LEFT JOIN ProjectTasks pt

       ON pm.Id = pt.ProjectModuleId and pt.Deleted &lt;&gt; 1

LEFT JOIN TimesheetLines tl

       ON pt.id = tl.ProjectTaskID AND tl.Deleted &lt;&gt; 1

-- Timesheets

LEFT JOIN Timesheet t

       ON tl.TimesheetId = t.Id AND t.Deleted &lt;&gt; 1

left join employee e 

        on t.employeeid= e.id 

left join person per 

        on e.personid= per.id


WHERE Timesheetdate &gt;= @FromDate
AND Timesheetdate &lt; DATEADD(DAY, 1, @ToDate)
   and p.Deleted &lt;&gt; 1

    and YEAR(t.TimesheetDate) &gt; 2025

    and ISNULL(ddt.DisplayName, 'No Category')  = 'Falcon'
and p.id IN (@Project)

and p.projectsubcategoryid in (@ProjectSubcategory)
    and p.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---Meldep SiteID
ORDER BY p.Name, pm.Name, pt. Name;
 </CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
        <Field Name="CategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryName</DataField>
        </Field>
        <Field Name="SubcategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubcategoryName</DataField>
        </Field>
        <Field Name="ProjectModuleName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectModuleName</DataField>
        </Field>
        <Field Name="ProjectTaskName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectTaskName</DataField>
        </Field>
        <Field Name="Employee">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Employee</DataField>
        </Field>
        <Field Name="TimesheetDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>TimesheetDate</DataField>
        </Field>
        <Field Name="ActualHours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ActualHours</DataField>
        </Field>
        <Field Name="description">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>description</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Project">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectSubcategory">
            <Value>=Parameters!ProjectSubcategory.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT
	P.Id AS ProjectId,
	P.[Name] AS Project
  
FROM Projects P 
WHERE
P.Deleted!=1 AND P.Active=1
and p.projectcategoryid='94D67E5B-21A1-4267-8223-5755743BD062' ---Falcon category ID
AND p.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---VSKY SiteID
AND P.projectsubcategoryid in (@ProjectSubcategory)
order by Project</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Project_Category">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <CommandText>select ''as CategoryId, 
'NA' AS CategoryName
UNION
SELECT DISTINCT 
       CAST(ddt.Id AS VARCHAR(50)) AS CategoryId, 
       ddt.DisplayName AS CategoryName
FROM DropDownType ddt
JOIN PROJECTS P ON P.PROJECTCATEGORYID = ddt.id
WHERE ddt.GroupName = 'ProjectCategory'
      --AND ddt.Deleted != 1
ORDER BY CategoryName</CommandText>
      </Query>
      <Fields>
        <Field Name="CategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryId</DataField>
        </Field>
        <Field Name="CategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Project_Sub_Category">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <CommandText>select ''as SubCategoryId,
           'NA' AS Subcategory 
UNION 
SELECT DISTINCT 
       CAST(dd.Id AS VARCHAR(50)) AS SubCategoryId, 
     dd.DropDownValue as Subcategory
FROM DropDownType ddt LEFT JOIN DropDown dd
           ON ddt.Id = dd.DropDownTypeId 
WHERE ddt.GroupName = 'ProjectCategory' 
            --AND ddt.Deleted != 1 
         AND ddt.type ='falcon'
         AND ddt.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---VSKY ID

ORDER BY Subcategory</CommandText>
      </Query>
      <Fields>
        <Field Name="SubCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubCategoryId</DataField>
        </Field>
        <Field Name="Subcategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Subcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Falcon_Employees">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH FalconEmployees AS (
    -- Get only employees who have worked on at least one Falcon project
    SELECT DISTINCT e.id AS employeeid
    FROM employee e
    JOIN timesheet t       ON t.employeeid = e.id
    JOIN timesheetlines tl ON tl.timesheetid = t.id
    JOIN projects pr        ON pr.id = tl.projectid
    JOIN dropdowntype dd    ON dd.id = pr.projectcategoryid
    WHERE dd.type = 'falcon'
      AND t.timesheetdate BETWEEN  @FromDate  AND @ToDate
)

SELECT 
    p.firstname + ' ' + p.lastname AS employeename,
    e.id,
    SUM(tl.hours) AS actualhours
FROM employee e
inner JOIN FalconEmployees fe     ON fe.employeeid = e.id   -- only Falcon workers
inner JOIN person p          ON p.id = e.personid
inner JOIN timesheet t       ON t.employeeid = e.id
    AND t.timesheetdate BETWEEN @FromDate  AND @ToDate
inner JOIN timesheetlines tl ON tl.timesheetid = t.id
WHERE e.active = 1
and e.deleted &lt;&gt; 1
and t.deleted= 0 
and tl.deleted =0
GROUP BY p.firstname + ' ' + p.lastname, e.id
ORDER BY employeename


</CommandText>
      </Query>
      <Fields>
        <Field Name="employeename">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>employeename</DataField>
        </Field>
        <Field Name="id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>id</DataField>
        </Field>
        <Field Name="actualhours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>actualhours</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeHalfDayLeave">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    emplv.id,
    emplv.EmployeeId,
    p.FirstName + ' ' + p.LastName AS EmployeeName,
    SUM(emplv.NoOfLeaves) AS TotalLeaves,
    emplv.FromDate,
    emplv.ToDate,
    emplv.IsHalfDay
FROM EmployeeLeave emplv
JOIN Employee e ON emplv.EmployeeId = e.Id
JOIN Person p ON p.Id = e.PersonId
INNER JOIN DropDown dd ON emplv.LeaveStatusId = dd.Id
       AND emplv.FromDate &lt;= @ToDate
       AND emplv.ToDate   &gt;= @FromDate
WHERE emplv.IsHalfDay = 1
  AND dd.DropDownValue NOT IN ('Decline', 'Cancelled')
  AND emplv.Deleted = 0

  -- ✅ Only employees who worked on Falcon projects in selected date range
  AND emplv.EmployeeId IN (
        SELECT DISTINCT t.EmployeeId
        FROM Projects proj
        LEFT JOIN DropDownType ddt 
               ON proj.ProjectCategoryId = ddt.Id
              AND ddt.GroupName = 'ProjectCategory'
        LEFT JOIN DropDown ddsub 
               ON proj.ProjectSubcategoryId = ddsub.Id
        LEFT JOIN ProjectModules pm
               ON proj.Id = pm.ProjectId AND pm.Deleted &lt;&gt; 1
        LEFT JOIN ProjectTasks pt
               ON pm.Id = pt.ProjectModuleId AND pt.Deleted &lt;&gt; 1
        LEFT JOIN TimesheetLines tl
               ON pt.Id = tl.ProjectTaskID AND tl.Deleted &lt;&gt; 1
        LEFT JOIN Timesheet t
               ON tl.TimesheetId = t.Id AND t.Deleted &lt;&gt; 1
        WHERE t.TimesheetDate &gt;= @FromDate
          AND t.TimesheetDate &lt;  DATEADD(DAY, 1, @ToDate)
          AND YEAR(t.TimesheetDate) &gt; 2025
          AND ISNULL(ddt.DisplayName, 'No Category') = 'Falcon'
          --AND proj.Id                IN (@Project)
          --AND proj.ProjectSubcategoryId IN (@ProjectSubcategory)
          AND proj.SiteId = '04086f10-8f09-4e0c-b5c0-c827a244addd'
          AND proj.Deleted &lt;&gt; 1
          AND t.EmployeeId IS NOT NULL
  )

GROUP BY 
    emplv.EmployeeId, 
    p.FirstName + ' ' + p.LastName,
    emplv.FromDate,
    emplv.ToDate,
    emplv.IsHalfDay,
    emplv.id
ORDER BY EmployeeName ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>id</DataField>
        </Field>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="TotalLeaves">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalLeaves</DataField>
        </Field>
        <Field Name="FromDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>FromDate</DataField>
        </Field>
        <Field Name="ToDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ToDate</DataField>
        </Field>
        <Field Name="IsHalfDay">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>IsHalfDay</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeFullDayLeave">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    emplv.EmployeeId,
    p.FirstName + ' ' + p.LastName AS EmployeeName,
    SUM(CAST(emplv.NoOfLeaves AS int)) AS TotalLeaves,
    emplv.IsHalfDay,
    MIN(emplv.FromDate) AS MinDate,
    MAX(emplv.ToDate) AS MaxDate
FROM EmployeeLeave emplv
INNER JOIN Employee e ON emplv.EmployeeId = e.Id
INNER JOIN Person p ON p.Id = e.PersonId
INNER JOIN DropDown dd ON emplv.LeaveStatusId = dd.Id
       AND emplv.FromDate &lt;= @ToDate
       AND emplv.ToDate   &gt;= @FromDate
WHERE emplv.IsHalfDay = 0
  AND dd.DropDownValue NOT IN ('Decline', 'Cancelled')
  AND emplv.Deleted = 0

  -- ✅ Only Falcon project employees
  AND emplv.EmployeeId IN (
        SELECT DISTINCT t.EmployeeId
        FROM Projects proj
        LEFT JOIN DropDownType ddt 
               ON proj.ProjectCategoryId = ddt.Id
              AND ddt.GroupName = 'ProjectCategory'
        LEFT JOIN ProjectModules pm
               ON proj.Id = pm.ProjectId AND pm.Deleted &lt;&gt; 1
        LEFT JOIN ProjectTasks pt
               ON pm.Id = pt.ProjectModuleId AND pt.Deleted &lt;&gt; 1
        LEFT JOIN TimesheetLines tl
               ON pt.Id = tl.ProjectTaskID AND tl.Deleted &lt;&gt; 1
        LEFT JOIN Timesheet t
               ON tl.TimesheetId = t.Id AND t.Deleted &lt;&gt; 1
        WHERE t.TimesheetDate &gt;= @FromDate
          AND t.TimesheetDate &lt;  DATEADD(DAY, 1, @ToDate)
          AND YEAR(t.TimesheetDate) &gt; 2025
          AND ISNULL(ddt.DisplayName, 'No Category') = 'Falcon'
          AND proj.SiteId = '04086f10-8f09-4e0c-b5c0-c827a244addd'
          AND proj.Deleted &lt;&gt; 1
          AND t.EmployeeId IS NOT NULL
  )

GROUP BY 
    emplv.EmployeeId, 
    p.FirstName + ' ' + p.LastName,
    emplv.IsHalfDay
ORDER BY EmployeeName ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="TotalLeaves">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>TotalLeaves</DataField>
        </Field>
        <Field Name="IsHalfDay">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>IsHalfDay</DataField>
        </Field>
        <Field Name="MinDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>MinDate</DataField>
        </Field>
        <Field Name="MaxDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>MaxDate</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Employee_DD">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <CommandText>WITH EmployeeRanked AS (
    SELECT DISTINCT
        E.Id AS EmployeeId,
        P.FirstName + ' ' + P.LastName AS EmployeeName,
        ES.EmployeeStatusId AS StatusId,
        ROW_NUMBER() OVER (PARTITION BY E.Id ORDER BY ES.StartDate DESC) AS RowNum,
        eos.ManagerId
    FROM Employee E
    JOIN EmployeeStatus ES ON E.Id = ES.EmployeeId
    JOIN Dropdown DD ON DD.Id = ES.EmployeeStatusId
    JOIN EmployeeType et ON E.Id = et.EmployeeId
    JOIN Dropdown emptype ON emptype.Id = et.EmployeeTypeId
    JOIN Person P ON P.Id = E.PersonId AND P.Deleted != 1
    LEFT JOIN EmployeeOrgStructure eos ON eos.EmployeeId = E.Id
    LEFT JOIN ProjectActivities PA ON PA.AssignedToId = E.Id AND PA.Deleted != 1

    WHERE 
        E.Deleted != 1
        AND E.Active = 1
        AND DD.DropdownValue = 'Current'
        AND emptype.DropDownValue NOT IN ('Consultant','Close')
)
SELECT DISTINCT
    EmployeeId,
    EmployeeName,
    StatusId
FROM EmployeeRanked
WHERE RowNum = 1
ORDER BY EmployeeName;</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
