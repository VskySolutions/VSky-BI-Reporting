            <Value>=Parameters!SmrutiFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SnehaFactor">
            <Value>=Parameters!SnehaFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SujataFactor">
            <Value>=Parameters!SujataFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SumeshFactor">
            <Value>=Parameters!SumeshFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SurajFactor">
            <Value>=Parameters!SurajFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SusmitaFactor">
            <Value>=Parameters!SusmitaFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SwapnilFactor">
            <Value>=Parameters!SwapnilFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TejasFactor">
            <Value>=Parameters!TejasFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@UjwalaFactor">
            <Value>=Parameters!UjwalaFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@VaibhavFactor">
            <Value>=Parameters!VaibhavFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@VaishnaviFactor">
            <Value>=Parameters!VaishnaviFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@VamshiFactor">
            <Value>=Parameters!VamshiFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@VikasFactor">
            <Value>=Parameters!VikasFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@YatirajFactor">
            <Value>=Parameters!YatirajFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@YogeshFactor">
            <Value>=Parameters!YogeshFactor.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH EmployeeBillability AS (
    SELECT 
        tl.Id AS TimesheetLineId,
        CAST(
            CASE 
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Aashish Mishra' THEN tl.Hours * ISNULL(TRY_CAST(@AashishFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Abhijeet Khot' THEN tl.Hours * ISNULL(TRY_CAST(@AbhijeetFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Aditi Gawade' THEN tl.Hours * ISNULL(TRY_CAST(@AditiFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Aishwarya Hegishte' THEN tl.Hours * ISNULL(TRY_CAST(@AishwaryaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Akshay Kulkarni' THEN tl.Hours * ISNULL(TRY_CAST(@AkshayFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Anuja Deshpande' THEN tl.Hours * ISNULL(TRY_CAST(@AnujaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Arjuna Patil' THEN tl.Hours * ISNULL(TRY_CAST(@ArjunaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Bhagyashri Pednekar' THEN tl.Hours * ISNULL(TRY_CAST(@BhagyashriFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Bhavana Sail' THEN tl.Hours * ISNULL(TRY_CAST(@BhavanaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Darshan Desai' THEN tl.Hours * ISNULL(TRY_CAST(@DarshanFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Diksha Keluskar' THEN tl.Hours * ISNULL(TRY_CAST(@DikshaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Dipti Bhosale' THEN tl.Hours * ISNULL(TRY_CAST(@DiptiFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Divya Wairkar' THEN tl.Hours * ISNULL(TRY_CAST(@DivyaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Gafar Desai' THEN tl.Hours * ISNULL(TRY_CAST(@GafarFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Gaurav Sarode' THEN tl.Hours * ISNULL(TRY_CAST(@GauravFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Manish Dhuri' THEN tl.Hours * ISNULL(TRY_CAST(@ManishFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Mohit Tambe' THEN tl.Hours * ISNULL(TRY_CAST(@MohitFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Neha Gosavi' THEN tl.Hours * ISNULL(TRY_CAST(@NehaGFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Neha Palav' THEN tl.Hours * ISNULL(TRY_CAST(@NehaPFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Nikhil Korade' THEN tl.Hours * ISNULL(TRY_CAST(@NikhilFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Niranjan Suryawanshi' THEN tl.Hours * ISNULL(TRY_CAST(@NiranjanFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Parshwa Vanjole' THEN tl.Hours * ISNULL(TRY_CAST(@ParshwaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Prasad Sawant' THEN tl.Hours * ISNULL(TRY_CAST(@PrasadFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Rajlaxmi Mandavkar' THEN tl.Hours * ISNULL(TRY_CAST(@RajlaxmiFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Rudraksh Abhange' THEN tl.Hours * ISNULL(TRY_CAST(@RudrakshFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sachin Bhanse' THEN tl.Hours * ISNULL(TRY_CAST(@SachinFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sainath Nimbalkar' THEN tl.Hours * ISNULL(TRY_CAST(@SainathFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sameer Nimbalkar' THEN tl.Hours * ISNULL(TRY_CAST(@SameerFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Samiksha Narvekar' THEN tl.Hours * ISNULL(TRY_CAST(@SamikshaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sana Pinjari' THEN tl.Hours * ISNULL(TRY_CAST(@SanaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sandhya Hawaldar' THEN tl.Hours * ISNULL(TRY_CAST(@SandhyaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Saurabh Parab' THEN tl.Hours * ISNULL(TRY_CAST(@SaurabhFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Shahrukh Sanadi' THEN tl.Hours * ISNULL(TRY_CAST(@ShahrukhFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sharvari Vardhamane' THEN tl.Hours * ISNULL(TRY_CAST(@SharvariFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Shruti Mane' THEN tl.Hours * ISNULL(TRY_CAST(@ShrutiFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Siddharth Joshi' THEN tl.Hours * ISNULL(TRY_CAST(@SiddharthFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sitaram Chari' THEN tl.Hours * ISNULL(TRY_CAST(@SitaramFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Smruti Bhore' THEN tl.Hours * ISNULL(TRY_CAST(@SmrutiFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sneha Kadlaskar' THEN tl.Hours * ISNULL(TRY_CAST(@SnehaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sujata Gaikwad' THEN tl.Hours * ISNULL(TRY_CAST(@SujataFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Sumesh Patil' THEN tl.Hours * ISNULL(TRY_CAST(@SumeshFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Suraj Kumbhar' THEN tl.Hours * ISNULL(TRY_CAST(@SurajFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Susmita Gawade' THEN tl.Hours * ISNULL(TRY_CAST(@SusmitaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Swapnil Patil' THEN tl.Hours * ISNULL(TRY_CAST(@SwapnilFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Tejas Talankar' THEN tl.Hours * ISNULL(TRY_CAST(@TejasFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Ujwala Sawant' THEN tl.Hours * ISNULL(TRY_CAST(@UjwalaFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Vaibhav Powar' THEN tl.Hours * ISNULL(TRY_CAST(@VaibhavFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Vaishnavi Tambe' THEN tl.Hours * ISNULL(TRY_CAST(@VaishnaviFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Vamshi Saliganti' THEN tl.Hours * ISNULL(TRY_CAST(@VamshiFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Vikas Hawaldar' THEN tl.Hours * ISNULL(TRY_CAST(@VikasFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Yatiraj Gosavi' THEN tl.Hours * ISNULL(TRY_CAST(@YatirajFactor AS DECIMAL(10,2)), 0)
                WHEN LTRIM(RTRIM(Per.FirstName + ' ' + Per.LastName)) = 'Yogesh Kumbhar' THEN tl.Hours * ISNULL(TRY_CAST(@YogeshFactor AS DECIMAL(10,2)), 0)
                ELSE tl.BillableHours
            END AS DECIMAL(10,2)
        ) AS BillableHours
    FROM Timesheet t
    LEFT JOIN TimesheetLines tl ON t.Id = tl.TimesheetId
    LEFT JOIN AspNetUsers anu ON tl.CreatedById = anu.Id
    LEFT JOIN Person Per ON anu.PersonId = Per.Id
)

SELECT 
    tl.ProjectId,
    P.[Name] AS ProjectName,
    YEAR(T.TimesheetDate) AS [Year], 
    MONTH(T.TimesheetDate) AS [Month],
    FORMAT(T.TimesheetDate, 'MMM yyyy') AS MonthYear,
    SUM(tl.Hours) AS ActualHrs,
    SUM(ISNULL(eb.BillableHours, 0)) AS BillableHrs
FROM Timesheet T
LEFT OUTER JOIN TimesheetLines tl ON t.Id = tl.TimesheetId
LEFT OUTER JOIN Projects P ON P.Id = tl.ProjectId
LEFT JOIN EmployeeBillability eb ON tl.Id = eb.TimesheetLineId
WHERE 
    (T.Deleted = 0 OR T.Deleted IS NULL) 
    AND P.Name IS NOT NULL
    AND T.TimesheetDate BETWEEN DATEFROMPARTS(YEAR(@ToDate), 1, 1) AND @ToDate
GROUP BY 
    tl.ProjectId, P.[Name], FORMAT(T.TimesheetDate, 'MMM yyyy'), YEAR(T.TimesheetDate), MONTH(T.TimesheetDate)
ORDER BY 
    YEAR(T.TimesheetDate), 
    MONTH(T.TimesheetDate),
    P.[Name];</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
        <Field Name="Month">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Month</DataField>
        </Field>
        <Field Name="MonthYear">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthYear</DataField>
        </Field>
        <Field Name="ActualHrs">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ActualHrs</DataField>
        </Field>
        <Field Name="BillableHrs">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>BillableHrs</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!ProjectId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!ProjectDropDown.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="CustomerDropDownDataset">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>WITH CustomerDetails AS (
SELECT 
	CC.Id AS CustomerId,
	C.[Name] AS CustomerName
FROM CompanyCustomers CC
LEFT  JOIN Company C ON C.Id=CC.CompanyId
LEFT JOIN Projects P ON P.CustomerId=CC.Id AND P.Deleted!=1 and P.Active=1
WHERE CC.Deleted!=1 AND C.Deleted!=1
)
SELECT 'NULL' AS CustomerId,'NA' AS CustomerName
UNION
SELECT DISTINCT
CD.CustomerId,
CD.CustomerName
FROM CustomerDetails CD
ORDER BY CustomerName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
