          <DataField>ActivityDetails</DataField>
        </Field>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="Resource">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Resource</DataField>
        </Field>
