                      <FontWeight>Bold</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                  <TextRun>
                    <Value>This table uses both the From Date and To Date filters. It shows data for the exact date range you select, including the day, month, and year—not just the month or year.</Value>
                    <Style>
                      <FontStyle>Italic</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>For example, If you select From Date = March 5, 2024 and To Date = May 20, 2024, the table will only show data between March 5 and May 20, 2024.</Value>
                    <Style>
                      <FontStyle>Italic</FontStyle>
                      <FontFamily>Times New Roman</FontFamily>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
