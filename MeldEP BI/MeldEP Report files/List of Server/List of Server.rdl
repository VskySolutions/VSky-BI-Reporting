  <DataSets>
    <DataSet Name="LIST_OF_SERVER_MAIN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProviderName">
            <Value>=Parameters!ProviderName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ContractId">
            <Value>=Parameters!ContractId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CustomerId">
            <Value>=Parameters!CustomerId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
	srv.ProviderId,
    dd.DropDownValue AS Provider,
    srv.CustomerId, 
    srv.ContractId, 
    srv.Username,
    srv.Password,
    [dbo].[ProcessHTMLDescription](srv.Instructions) AS Instructions,
	[dbo].[ProcessHTMLDescription](srv.Notes) AS ServerNotes,
	srv.FtpUsername,
    srv.FtpPassword,
    srv.FtpPort,
    srv.FtpHostname,
    srv.StartDate,  
    srv.CardDigit,
    sp.RenewDate,
    sp.Amount,
    sp.Notes AS PaymentNotes
FROM dbo.Server srv
JOIN dbo.Sites s ON srv.SiteId = s.Id
LEFT JOIN dbo.DropDown dd ON srv.ProviderId = dd.Id
LEFT JOIN dbo.ServerPayments sp ON srv.Id = sp.ServerId
WHERE 
    srv.Deleted = 0 
    AND s.Deleted = 0
    AND (dd.Deleted = 0 OR dd.Deleted IS NULL)
	AND (srv.ProviderId IN (@ProviderName))
	AND (srv.CustomerId IN (@CustomerId))
	AND (srv.ContractId IN (@ContractId));</CommandText>
      </Query>
      <Fields>
        <Field Name="ProviderId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProviderId</DataField>
        </Field>
        <Field Name="Provider">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Provider</DataField>
        </Field>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="ContractId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ContractId</DataField>
        </Field>
        <Field Name="Username">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Username</DataField>
        </Field>
        <Field Name="Password">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Password</DataField>
        </Field>
        <Field Name="Instructions">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Instructions</DataField>
        </Field>
        <Field Name="ServerNotes">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ServerNotes</DataField>
        </Field>
        <Field Name="FtpUsername">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>FtpUsername</DataField>
        </Field>
        <Field Name="FtpPassword">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>FtpPassword</DataField>
        </Field>
        <Field Name="FtpPort">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>FtpPort</DataField>
        </Field>
        <Field Name="FtpHostname">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>FtpHostname</DataField>
        </Field>
        <Field Name="StartDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>StartDate</DataField>
        </Field>
        <Field Name="CardDigit">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CardDigit</DataField>
        </Field>
        <Field Name="RenewDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>RenewDate</DataField>
        </Field>
        <Field Name="Amount">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Amount</DataField>
        </Field>
        <Field Name="PaymentNotes">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PaymentNotes</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PROVIDER_NAME_DROPDOWN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <CommandText>SELECT 
    d.Id AS ProviderId,
    d.DropDownValue AS ProviderName
FROM dbo.DropDown d
LEFT JOIN dbo.DropDownType dt ON d.DropDownTypeId = dt.Id
WHERE dt.Type = 'Server Provider'
  AND d.Deleted = 0
  AND dt.Deleted = 0
  Order by DropDownValue ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="ProviderId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProviderId</DataField>
        </Field>
        <Field Name="ProviderName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProviderName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CUSTOMERID_DROPDOWN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <CommandText>SELECT DISTINCT
	CustomerID
FROM SERVER
WHERE DELETED != 1
ORDER BY CustomerID ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="CUSTOMERID">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerID</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CONTRACTID_DROPDOWN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <CommandText>SELECT DISTINCT
	ContractID
FROM SERVER
WHERE DELETED != 1
ORDER BY ContractID;</CommandText>
      </Query>
      <Fields>
        <Field Name="CONTRACTID">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ContractID</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
