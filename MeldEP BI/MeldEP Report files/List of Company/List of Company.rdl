  <DataSets>
    <DataSet Name="ListOfCompanyDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Company">
            <Value>=Parameters!Company.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PrimaryEmployee">
            <Value>=Parameters!PrimaryEmployee.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@BusinessType">
            <Value>=Parameters!BusinessType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CompanyStatus">
            <Value>=Parameters!CompanyStatus.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
	C.Id AS CompanyId,
	C.[Name] AS CompanyName,
	C.Website AS Website,
	ISNULL(NULLIF(C.EmailAddress,''),'NA') AS CompanyEmail,
	C.EmployeeId AS PrimaryEmployeeId,
	P.FirstName+' '+P.LastName AS PrimaryEmployeeName,
                P.PrimaryEmailAddress AS PrimaryEmail,
                P.PrimaryPhoneNumber AS PrimaryPhone,
	C.PhoneNumber AS Phone,
	ISNULL(NULLIF(C.AlternativeEmailAddress,''),'NA') AS AlternateEmail,
	C.AlternativePhoneNumber AS AlternatePhone,
	Con.[Name] AS Country,
	SP.[Name] AS State,
	adr.City AS City,
	adr.ZipCode AS ZipCode,
	adr.AddressLine1 AS Address1,
	adr.AddressLine2 AS Address2,
	C.BusinessTypeId AS BTypeId,
	BDD.DropDownValue AS BusinessType,
	C.StatusId AS StatusId,
	DD.DropDownValue AS CompanyStatus

FROM Company C
LEFT JOIN Employee E ON E.Id=C.EmployeeId
LEFT JOIN Person P ON P.Id=E.PersonId
LEFT JOIN DropDown BDD ON BDD.Id=C.BusinessTypeId
LEFT JOIN Address adr ON adr.Id=C.AddressId
LEFT JOIN StateProvince SP ON SP.Id=adr.StateProvinceId
LEFT JOIN Country Con ON Con.Id=SP.CountryId
LEFT JOIN DropDown DD ON DD.Id=C.StatusId
WHERE
	C.Deleted!=1 AND
                C.Id IN (@Company) AND
                ISNULL(C.EmployeeId,'NULL') IN (@PrimaryEmployee) AND
                ISNULL(C.BusinessTypeId,'NULL') IN (@BusinessType) AND
                ISNULL(C.StatusId,'NULL') IN (@CompanyStatus)

ORDER BY CompanyName</CommandText>
      </Query>
      <Fields>
        <Field Name="CompanyId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CompanyId</DataField>
        </Field>
        <Field Name="CompanyName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CompanyName</DataField>
        </Field>
        <Field Name="Website">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Website</DataField>
        </Field>
