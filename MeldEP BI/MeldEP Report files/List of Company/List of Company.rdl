    <DataSet Name="CompanyDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <CommandText>SELECT 
	C.Id AS CompanyId,
	C.[Name] AS CompanyName
FROM Company C
WHERE 
	C.Deleted!=1
ORDER BY CompanyName</CommandText>
      </Query>
      <Fields>
        <Field Name="CompanyId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CompanyId</DataField>
        </Field>
        <Field Name="CompanyName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CompanyName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PrimaryEmployeeDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT
	ISNULL(C.EmployeeId,'NULL') AS PrimaryEmployeeId,
	ISNULL((P.FirstName+' '+P.LastName),'NA') AS PrimaryEmployeeName
FROM Company C
LEFT JOIN Employee E ON E.Id=C.EmployeeId
LEFT JOIN Person P ON P.Id=E.PersonId
WHERE
	C.Deleted!=1
ORDER BY PrimaryEmployeeName;</CommandText>
      </Query>
      <Fields>
        <Field Name="PrimaryEmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PrimaryEmployeeId</DataField>
        </Field>
        <Field Name="PrimaryEmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PrimaryEmployeeName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="BusinessTypeDropDown">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT
	ISNULL(C.BusinessTypeId,'NULL') AS BusinessTypeId,
	ISNULL(DD.DropDownValue,'NA') AS BusinessType
FROM Company C
LEFT JOIN DropDown DD ON DD.Id=C.BusinessTypeId
WHERE 
	C.Deleted!=1</CommandText>
      </Query>
      <Fields>
        <Field Name="BusinessTypeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>BusinessTypeId</DataField>
        </Field>
        <Field Name="BusinessType">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>BusinessType</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CompanyStatusDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT
	ISNULL(C.StatusId,'NULL') AS StatusId,
	ISNULL(DD.DropDownValue,'NA') AS CompanyStatus
FROM Company C
LEFT JOIN DropDown DD ON DD.Id=C.StatusId
WHERE 
	C.Deleted!=1 
ORDER BY CompanyStatus</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="CompanyStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CompanyStatus</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
