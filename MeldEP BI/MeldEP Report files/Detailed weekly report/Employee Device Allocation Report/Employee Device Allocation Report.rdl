    <DataSet Name="Devices">
      <Query>
        <DataSourceName>Meldep</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--SELECT 'All' as DeviceName
--UNION
SELECT DISTINCT 
   id as InventoryID,
   name as DeviceName
FROM Inventoryitemtype 

ORDER BY DeviceName;</CommandText>
      </Query>
      <Fields>
        <Field Name="InventoryID">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>InventoryID</DataField>
        </Field>
        <Field Name="DeviceName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DeviceName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeName">
      <Query>
        <DataSourceName>Meldep</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT distinct
        E.Id AS EmployeeId,
        P.FirstName+' '+
        P.LastName AS EmployeeName

    FROM Employee e
     JOIN EmployeeStatus es ON e.Id = es.EmployeeId
     JOIN Dropdown dd ON dd.Id = es.EmployeeStatusId
	JOIN Employeetype et ON e.Id = et.EmployeeId
    JOIN Dropdown emptype ON emptype.Id = et.EmployeetypeId
      JOIN Person p ON e.PersonId = p.Id
     JOIN AspNetUsers a ON a.PersonId = p.Id
  WHERE emptype.DropdownValue not in ( 'On Contract', 'Consultant','Close')
    and dd.dropdownvalue= 'Current'
      AND e.Deleted != 1
     and e.active=1</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeID">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="InventoryStatusDataset">
      <Query>
        <DataSourceName>Meldep</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>select distinct dd.id, 
                dd.DropDownValue as 'Inventory Status'
from DropDown dd
inner join DropDownType ddt
on dd.DropDownTypeId = ddt.id
where ddt.Type like 'Inventory Status'</CommandText>
      </Query>
      <Fields>
        <Field Name="id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>id</DataField>
        </Field>
        <Field Name="Inventory_Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Inventory Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeStatusDataset">
      <Query>
        <DataSourceName>Meldep</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>
SELECT DISTINCT 
    e.Active AS EmployeeStatusID,
    CASE 
        WHEN e.Active = 1 THEN 'Active'
        WHEN e.Active = 0 THEN 'Inactive'
    END AS EmployeeStatus
FROM Employee e;</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeStatusID">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>EmployeeStatusID</DataField>
        </Field>
        <Field Name="EmployeeStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeStatus</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
