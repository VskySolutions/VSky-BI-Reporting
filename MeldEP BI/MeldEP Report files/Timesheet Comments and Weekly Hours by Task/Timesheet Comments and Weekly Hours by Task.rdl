  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectName">
            <Value>=Parameters!ProjectName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH TaskMetricsCTE AS (
  SELECT
    TL.ProjectTaskId as TaskId, 
    COUNT(DISTINCT TL.CreatedById) AS [NumberOfEmployees],
    COUNT(TimesheetId) AS [TimesheetCount]
  FROM [Timesheet] T
  LEFT JOIN TimesheetLines AS TL ON TL.TimesheetId = T.Id
  WHERE TL.Deleted = 0 and T.Deleted = 0
    AND T.TimesheetDate BETWEEN @FromDate AND @ToDate
  GROUP BY TL.ProjectTaskId
),
TimesheetDetailsCTE AS (
  SELECT
    TL.ProjectTaskId as TaskId,
    CONVERT(VARCHAR(10), T.TimesheetDate, 101) AS [Date],  
	P.Id as ProjectId,
    P.[Name] AS [ProjectName],
    PT.[Name] as TaskName,
    TL.Description as ActivityDetails,
    TL.[Hours]
  FROM [Timesheet] AS T
  LEFT JOIN TimesheetLines AS TL ON TL.TimesheetId = T.Id
  LEFT JOIN Projects AS P ON P.Id = TL.ProjectId
  LEFT JOIN ProjectTasks AS PT ON PT.Id = TL.ProjectTaskId
  WHERE T.Deleted = 0 
 --P.[Name] = 'Falcon - CTBK'

    AND T.TimesheetDate BETWEEN @FromDate AND @ToDate
),
WeekRanges AS (
  SELECT
    DATEPART(WEEK, DD.TheFirstOfWeek) - DATEPART(WEEK, @FromDate) + 1 AS WeekNumber,
    CASE 
      WHEN DD.TheFirstOfWeek &lt; @FromDate THEN @FromDate
      ELSE DD.TheFirstOfWeek
    END AS WeekStart,
    CASE 
      WHEN DD.TheLastOfWeek &gt; @ToDate THEN @ToDate
      ELSE DD.TheLastOfWeek
    END AS WeekEnd,
    FORMAT(
      CASE 
        WHEN DD.TheFirstOfWeek &lt; @FromDate THEN @FromDate
        ELSE DD.TheFirstOfWeek
      END, 'MM.dd.yy') + 
    ' - ' + FORMAT(
      CASE 
        WHEN DD.TheLastOfWeek &gt; @ToDate THEN @ToDate
        ELSE DD.TheLastOfWeek
      END, 'MM.dd.yy') AS WeekRange
  FROM DimDate DD
  WHERE DD.TheDate BETWEEN @FromDate AND @ToDate
  GROUP BY DD.TheFirstOfWeek, DD.TheLastOfWeek
),

TotalWorkedHoursCTE AS (
  SELECT 
    TL.ProjectTaskId as TaskId,
    SUM([Hours]) AS [TotalWorkedHours]
  FROM [Timesheet] T
  LEFT JOIN TimesheetLines AS TL ON TL.TimesheetId = T.Id
  WHERE T.Deleted = 0 and TL.Deleted = 0
    AND T.TimesheetDate BETWEEN @FromDate AND @ToDate
  GROUP BY TL.ProjectTaskId
)

--------------------------------------------------Aggregation--------------------------------------------------
, TaskActivityComments AS (
  SELECT
    TL.ProjectTaskId AS TaskId,
    STRING_AGG(TL.Description, '; ') AS AllActivityDetails
  FROM [Timesheet] AS T
  LEFT JOIN TimesheetLines AS TL ON TL.TimesheetId = T.Id
  WHERE T.Deleted = 0 AND TL.Deleted = 0
    AND T.TimesheetDate BETWEEN @FromDate AND @ToDate
  GROUP BY TL.ProjectTaskId
)

-- Final Aggregation
SELECT
	TD.ProjectId as ProjectId,
  TD.[ProjectName] AS [Project Name],
TD.TaskId as TaskId,
  TD.TaskName AS [Task Name],
  TAC.AllActivityDetails AS [All Activity Details],
  TM.[NumberOfEmployees] AS [Number of Employees Filling Timesheet],
  TM.[TimesheetCount] AS [Total Timesheet Entries],
  WR.WeekRange AS [Week Range],
  SUM(TD.[Hours]) AS [Hours Worked],
  TWH.[TotalWorkedHours] AS [Total Worked Hours]
FROM TimesheetDetailsCTE AS TD
LEFT JOIN TaskMetricsCTE AS TM ON TD.TaskId = TM.TaskId
LEFT JOIN TaskActivityComments AS TAC ON TD.TaskId = TAC.TaskId
INNER JOIN DimDate DD ON TD.[Date] = DD.TheDate
INNER JOIN WeekRanges WR ON TD.[Date] BETWEEN WR.WeekStart AND WR.WeekEnd
LEFT JOIN TotalWorkedHoursCTE TWH ON TD.TaskId = TWH.TaskId
WHERE TD.ProjectId IN (@ProjectName)

GROUP BY 
	TD.ProjectId,
  TD.[ProjectName],
TD.TaskId , 
  TD.TaskName, 
  TAC.AllActivityDetails,
  TM.[NumberOfEmployees], 
  TM.[TimesheetCount], 
  WR.WeekRange,
  TWH.[TotalWorkedHours];</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project_Name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project Name</DataField>
        </Field>
        <Field Name="TaskId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskId</DataField>
        </Field>
        <Field Name="Task_Name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Task Name</DataField>
        </Field>
        <Field Name="All_Activity_Details">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>All Activity Details</DataField>
        </Field>
        <Field Name="Number_of_Employees_Filling_Timesheet">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Number of Employees Filling Timesheet</DataField>
        </Field>
        <Field Name="Total_Timesheet_Entries">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Total Timesheet Entries</DataField>
        </Field>
        <Field Name="Week_Range">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Week Range</DataField>
        </Field>
        <Field Name="Hours_Worked">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Hours Worked</DataField>
        </Field>
        <Field Name="Total_Worked_Hours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Total Worked Hours</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!TaskId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!TaskName.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="ProjectName">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectType">
            <Value>=Parameters!ProjectType.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH ProjectDetailsList AS(
SELECT DISTINCT
	P.Id AS ProjectId,
	P.[Name] AS ProjectName,
                P.CustomerId AS CustomerId,
	CASE 
			WHEN P.Active=1 THEN 1
			WHEN P.Active=0 THEN 0
	END AS StatusId,
		CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status,P.ProjectStatusId AS ProjectStatusId,
	SDD.DropDownValue AS ProjectStatus,
	P.ProjectTypeId as ProjectTypeId

FROM Projects P 
LEFT JOIN CompanyCustomers CC ON CC.Id=P.CustomerId
LEFT JOIN DropDown SDD ON SDD.Id=P.ProjectStatusId
WHERE
	P.Deleted!=1 
)
SELECT '' AS ProjectId, 'NA' AS ProjectName UNION
SELECT
	PD.ProjectId,
	PD.ProjectName
FROM ProjectDetailsList PD
WHERE 
          PD.StatusId IN (@Status)
          --AND ISNULL(PD.CustomerId,'NULL') IN (@Customer)
          AND PD.ProjectStatusId IN (@ProjectStatus)
		  AND PD.ProjectTypeId IN (@ProjectType)
ORDER BY ProjectName</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="StatusDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <CommandText>SELECT DISTINCT
                CASE 
		WHEN P.Active=1 THEN 1
		WHEN P.Active=0 THEN 0
	END AS StatusId,
	CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status
FROM Projects P
WHERE
	P.Deleted!=1 
ORDER BY Status</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectStatusDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <CommandText>SELECT 
	DD.Id AS ProjectStatusId,
	DD.DropDownValue AS ProjectStatus
FROM DropDown DD
LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Status'
AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectStatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatusId</DataField>
        </Field>
        <Field Name="ProjectStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatus</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TaskDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectName">
            <Value>=Parameters!ProjectName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
Id as TaskId,
[Name] as TaskName,
Active as TaskActiveStatus,
StatusId As TaskStatusId,
ProjectId as ProjectId
FROM ProjectTasks
where ProjectId IN (@ProjectName)</CommandText>
      </Query>
      <Fields>
        <Field Name="TaskId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskId</DataField>
        </Field>
        <Field Name="TaskName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskName</DataField>
        </Field>
        <Field Name="TaskActiveStatus">
          <rd:TypeName>System.Boolean</rd:TypeName>
          <DataField>TaskActiveStatus</DataField>
        </Field>
        <Field Name="TaskStatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskStatusId</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!TaskStatusId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!TaskStatus.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="TaskStatusDS">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <CommandText>select dd.Id as DropdownId,
dd.DropDownValue as DropdownValue
 from dropdown dd 
Left Outer Join dropdowntype ddt on dd.DropDownTypeId = ddt.Id 
where ddt.[Type] ='Task Status' and ddt.Deleted != 1 and dd.Deleted != 1
order by 2</CommandText>
      </Query>
      <Fields>
        <Field Name="DropdownId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DropdownId</DataField>
        </Field>
        <Field Name="DropdownValue">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DropdownValue</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectTypeDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <CommandText>select 
	dd.id as projecttypeid,
	dd.dropdownvalue as projecttype
from dropdown dd
left join dropdowntype ddt on ddt.id=dd.dropdowntypeid and ddt.deleted!=1
where dd.deleted!=1
and ddt.type='Project Type'
order by projecttype</CommandText>
      </Query>
      <Fields>
        <Field Name="projecttypeid">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projecttypeid</DataField>
        </Field>
        <Field Name="projecttype">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projecttype</DataField>
        </Field>
      </Fields>
    </DataSet>
