    <DataSet Name="ProjectPriorityDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <CommandText>select 
	dd.id as projectpriorityid,
	dd.dropdownvalue as projectpriority
from dropdown dd
left join dropdowntype ddt on ddt.id=dd.dropdowntypeid and ddt.deleted!=1
where dd.deleted!=1
and ddt.type='Project Priorities'
order by projectpriority</CommandText>
      </Query>
      <Fields>
        <Field Name="projectpriorityid">
