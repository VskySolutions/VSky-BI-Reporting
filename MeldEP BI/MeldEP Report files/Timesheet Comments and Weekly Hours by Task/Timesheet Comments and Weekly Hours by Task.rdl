  <Code>Function ConcatenateAll_Activity_Details(ByVal items As Object()) As String
    Dim concatenated As String = ""
    For Each item As String In items
        If concatenated &lt;&gt; "" Then
            concatenated = concatenated &amp; "; " &amp; item
        Else
            concatenated = item
        End If
    Next
    Return concatenated
End Function


Dim currentProject As String

Public Function SetProject(name As String) As String
    currentProject = name
    Return ""
End Function

Public Function GetProject() As String
    Return currentProject
End Function


Dim colCounter As Integer = 0
 
Function ResetColCounter()
    colCounter = 0
    Return ""
End Function
 
Function GetColCounter() As Integer
    colCounter = colCounter + 1
    Return colCounter
End Function</Code>
