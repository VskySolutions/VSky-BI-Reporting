    <DataSet Name="ProjectCategoryDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <CommandText>
SELECT distinct
	isnull(P.ProjectCategoryId,'') as ProjectCategoryId,
	isnull(ddc.dropdownvalue,'NA') as projectcategory
FROM Projects P
LEFT JOIN DropDown DDC ON DDC.Id=P.ProjectCategoryId and DDC.Deleted!=1
WHERE P.Deleted!=1</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectCategoryId</DataField>
        </Field>
        <Field Name="projectcategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectSubCategoryDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <CommandText>
SELECT distinct
	ISNULL(P.ProjectSubcategoryId,'') AS ProjectSubcategoryId,
	ISNULL(ddcs.dropdownvalue,'NA') as projectsubcategory
FROM Projects P
LEFT JOIN DropDown DDCS ON DDCS.Id=P.ProjectSubcategoryId and DDCS.Deleted!=1
WHERE P.Deleted!=1</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectSubcategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectSubcategoryId</DataField>
        </Field>
        <Field Name="projectsubcategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectsubcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ClientDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveDB</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH ProjectDetailsList AS (
    SELECT DISTINCT
        CASE 
            WHEN P.Active = 1 THEN 1
            ELSE 0
        END AS StatusId,
        CASE 
            WHEN P.Active = 1 THEN 'Active'
            ELSE 'Inactive'
        END AS Status,
        CPL.CustomerId,
		C.CustomerName
    FROM Projects P
JOIN ProjectActivities pa on pa.projectid=p.id and pa.deleted!=1
    JOIN VW_CustomerProjectList CPL ON P.Id = CPL.Id
	JOIN  VW_CustomerList C ON C.Id=CPL.CustomerId
    WHERE P.Deleted != 1
--and pa.assignedtoid in (@Employees)
)
SELECT PD.CustomerId, PD.CustomerName
FROM ProjectDetailsList PD
WHERE PD.StatusId IN (@Status)
ORDER BY CustomerName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
