    <DataSet Name="ProjectCategoryDS">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--SELECT 
	--DD.Id AS ProjectCategoryId,
	--DD.DropDownValue AS ProjectCategory
--FROM DropDown DD
--LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
--WHERE DDT.Type='Project Category'
--AND DDT.Deleted!=1
--ORDER BY DD.DropDownValue

SELECT ''as projectcategoryid,
'NA' AS projectcategory
UNION 
SELECT
	ddt.id as projectcategoryid,
	ddt.Type as projectcategory
FROM DropDownType ddt 
Where ddt.Groupname='ProjectCategory'
and ddt.deleted!=1</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectcategoryid</DataField>
        </Field>
        <Field Name="ProjectCategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectSubCategoryDS">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <CommandText>


SELECT DISTINCT
    ISNULL(P.ProjectSubcategoryId, '') AS ProjectSubcategoryId,
    ISNULL(DDC.DropDownValue, 'NA') AS ProjectSubcategory
FROM Projects P
LEFT JOIN DropDown DDC 
    ON DDC.Id = P.ProjectSubcategoryId AND DDC.Deleted != 1
WHERE P.Deleted != 1
ORDER BY ProjectSubcategory</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectSubcategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectSubcategoryId</DataField>
        </Field>
        <Field Name="ProjectSubcategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectSubcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeDs">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>WITH EmployeeRanked AS (
    SELECT DISTINCT
        E.Id AS EmployeeId,
        P.FirstName + ' ' + P.LastName AS EmployeeName,
ES.EmployeeStatusId AS StatusId,
DD.DropDownValue AS Status,
        ROW_NUMBER() OVER (PARTITION BY E.Id ORDER BY ES.StartDate DESC) AS RowNum
    FROM Employee E
    INNER JOIN Person P ON P.Id = E.PersonId
    LEFT JOIN EmployeeStatus ES ON E.Id = ES.EmployeeId
    LEFT JOIN DropDown DD ON DD.Id=ES.EmployeeStatusId
   LEFT JOIN ProjectActivities PA ON PA.AssignedToId = E.Id AND PA.Deleted != 1

    WHERE
        E.Deleted != 1 AND
        P.Deleted != 1
        AND E.ACTIVE=1
        AND PA.ProjectId IN (@Projects)
)
SELECT EmployeeId, EmployeeName,StatusId
FROM EmployeeRanked
WHERE RowNum = 1 
AND Status='Current'
ORDER BY EmployeeName;</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="YearDS">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT YEAR(pwd.WeekDate) AS YearValue
FROM Project_WeeklyPlan_Dates pwd
ORDER BY YearValue DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="YearValue">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>YearValue</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MonthDS">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
    DISTINCT MONTH(pwd.WeekDate) AS MonthValue,
    DATENAME(MONTH, DATEFROMPARTS(2000, MONTH(pwd.WeekDate), 1)) AS MonthName
FROM Project_WeeklyPlan_Dates pwd
ORDER BY MonthValue</CommandText>
      </Query>
      <Fields>
        <Field Name="MonthValue">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>MonthValue</DataField>
        </Field>
        <Field Name="MonthName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="WeekendDate">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Month">
            <Value>=Parameters!Month.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH Tally AS (
    SELECT TOP (31) ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) - 1 AS n
    FROM sys.all_objects
)
SELECT 
    CAST(DATEADD(DAY, n, DATEFROMPARTS(@Year, @Month, 1)) AS DATE) AS WeekendDateValue,
    FORMAT(DATEADD(DAY, n, DATEFROMPARTS(@Year, @Month, 1)), 'MM-dd-yyyy') AS WeekendDateLabel
FROM Tally
WHERE 
    DATENAME(WEEKDAY, DATEADD(DAY, n, DATEFROMPARTS(@Year, @Month, 1))) = 'Sunday'
    AND MONTH(DATEADD(DAY, n, DATEFROMPARTS(@Year, @Month, 1))) = @Month</CommandText>
      </Query>
      <Fields>
        <Field Name="WeekendDateValue">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>WeekendDateValue</DataField>
        </Field>
        <Field Name="WeekendDateLabel">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekendDateLabel</DataField>
        </Field>
      </Fields>
    </DataSet>
