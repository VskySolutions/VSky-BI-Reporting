  <DataSources>
    <DataSource Name="MELDEPLiveV32">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=67.211.217.118;Initial Catalog=MeldEp_Live_v3-2</ConnectString>
        <Prompt>Specify a user name and password for data source MELDEP3V2:</Prompt>
      </ConnectionProperties>
      <rd:DataSourceID>72a53c58-af8c-4d6d-84b0-9934db3a677d</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CompanyContactsDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Company">
            <Value>=Parameters!Company.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ContactName">
            <Value>=Parameters!ContactName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT 
	CC.Id AS ContactId,
	C.[Name] AS CompanyName,
	P.FirstName+' '+P.LastName AS ContactName,
	ISNULL(NULLIF(P.PrimaryEmailAddress,''),'NA') AS PrimaryEmail,
	P.PrimaryPhoneNumber AS PrimaryPhone,
	ISNULL(NULLIF(CC.AlternateEmail,''),'NA') AS AlternateEmail,
	CC.AlternatePhoneNumber AS AlternatePhone,
                P.GenderId AS GenderId,
                DD.DropDownValue AS Gender
FROM CompanyContacts CC
LEFT JOIN Person P ON P.Id=CC.PersonId
LEFT JOIN Company C ON C.Id=CC.CompanyId
LEFT JOIN DropDown DD ON DD.Id=P.GenderId
WHERE
	CC.Deleted!=1 AND 
	C.Deleted!=1 AND
                CC.CompanyId IN (@Company) AND
                (P.FirstName+' '+P.LastName) IN (@ContactName)
ORDER BY CompanyName</CommandText>
      </Query>
      <Fields>
        <Field Name="ContactId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ContactId</DataField>
        </Field>
        <Field Name="CompanyName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CompanyName</DataField>
        </Field>
        <Field Name="ContactName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ContactName</DataField>
        </Field>
        <Field Name="PrimaryEmail">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PrimaryEmail</DataField>
        </Field>
        <Field Name="PrimaryPhone">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PrimaryPhone</DataField>
        </Field>
        <Field Name="AlternateEmail">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>AlternateEmail</DataField>
        </Field>
        <Field Name="AlternatePhone">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>AlternatePhone</DataField>
        </Field>
        <Field Name="GenderId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>GenderId</DataField>
        </Field>
        <Field Name="Gender">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Gender</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CompanyDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:DesignerState>
          <QueryDefinition xmlns="http://schemas.microsoft.com/ReportingServices/QueryDefinition/Relational">
            <SelectedColumns>
              <ColumnExpression ColumnOwner="CompanyContacts" ColumnName="CompanyId" />
              <ColumnExpression ColumnOwner="Company" ColumnName="Name" />
            </SelectedColumns>
            <Joins>
              <Join Type="CROSS JOIN" ColumnOwner="Company" />
              <Join Type="INNER JOIN" ColumnOwner="CompanyContacts">
                <On>
                  <From ColumnOwner="Company" ColumnName="Id" />
                  <To ColumnOwner="CompanyContacts" ColumnName="CompanyId" />
                </On>
              </Join>
            </Joins>
          </QueryDefinition>
        </rd:DesignerState>
        <CommandText>SELECT DISTINCT
	CC.CompanyId AS ContactId,
	C.[Name] AS CompanyName
FROM CompanyContacts CC
LEFT JOIN Company C ON C.Id=CC.CompanyId
WHERE
	CC.Deleted!=1 AND 
	C.Deleted!=1 
ORDER BY CompanyName</CommandText>
      </Query>
      <Fields>
        <Field Name="ContactId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ContactId</DataField>
        </Field>
        <Field Name="CompanyName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CompanyName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PersonDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <CommandText>SELECT DISTINCT
	P.FirstName+' '+P.LastName AS ContactName
FROM CompanyContacts CC
LEFT JOIN Person P ON P.Id=CC.PersonId
WHERE
	CC.Deleted!=1 AND 
	P.Deleted!=1
ORDER BY ContactName</CommandText>
      </Query>
      <Fields>
        <Field Name="ContactName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ContactName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
