  <DataSets>
    <DataSet Name="ListOfCustomersDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@BusinessType">
            <Value>=Parameters!BusinessType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PrimaryPersonName">
            <Value>=Parameters!PrimaryPersonName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
	CC.Id AS CustomerId,
	C.Name AS CustomerName,
	C.Website AS Website,
	C.BusinessTypeId AS BusinessId,
	DD.DropDownValue AS BusinessType,
	ISNULL(NULLIF(C.EmailAddress,''),'NA') AS Email,
	ISNULL(NULLIF(C.AlternativeEmailAddress,''),'NA') as AlternateEmail,
	C.PhoneNumber AS Phone,
	C.AlternativePhoneNumber AS AlternatePhone,
	Ad.AddressLine1 AS Address,
	Ad.City AS City,
	SP.[Name] AS State,
	Con.[Name] AS Country,
	Ad.ZipCode AS ZipCode,
	C.EmployeeId AS PrimaryEmployeeId,
	CONCAT(P.FirstName, ' ', P.LastName) AS PrimaryPersonName,
                P.PrimaryEmailAddress AS PrimaryEmail,
                P.PrimaryPhoneNumber AS PrimaryPhone,
				pr.name as projectname,
				pr.Description
FROM CompanyCustomers CC
LEFT JOIN Company C ON C.Id=CC.CompanyId
LEFT JOIN DropDown DD ON DD.Id=C.BusinessTypeId
LEFT JOIN Address Ad ON Ad.Id=C.AddressId
LEFT JOIN StateProvince SP ON SP.Id=Ad.StateProvinceId
LEFT JOIN Country Con ON Con.Id=Ad.CountryId
LEFT JOIN Employee E ON E.Id=C.EmployeeId
LEFT JOIN Person P ON P.Id=E.PersonId
inner join projects pr on pr.customerid =cc.id
WHERE
	CC.Deleted!=1 AND
	C.Deleted!=1 AND
               ISNULL(C.BusinessTypeId,'NULL') IN (@BusinessType) AND
               ISNULL(C.EmployeeId,'NULL') IN (@PrimaryPersonName)


ORDER BY CustomerName;</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
        <Field Name="Website">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Website</DataField>
        </Field>
        <Field Name="BusinessId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>BusinessId</DataField>
        </Field>
