        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="CustomerDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <CommandText>SELECT 
	CC.Id AS CustomerId,
	C.[Name] AS CustomerName
FROM CompanyCustomers CC
LEFT JOIN Company C ON CC.CompanyId=C.Id
WHERE
	C.Deleted!=1 AND
	CC.Deleted!=1
ORDER BY CustomerName;</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="BusinessTypeDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>

SELECT DISTINCT
	ISNULL(C.BusinessTypeId,'NULL') AS BusinessTypeId,
	ISNULL(DD.DropDownValue,'NA') AS BusinessType
FROM CompanyCustomers CC
LEFT JOIN Company C ON C.Id=CC.CompanyId
LEFT JOIN DropDown DD ON DD.Id=C.BusinessTypeId</CommandText>
      </Query>
      <Fields>
        <Field Name="BusinessTypeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>BusinessTypeId</DataField>
        </Field>
        <Field Name="BusinessType">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>BusinessType</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PrimaryPersonDropDownDS">
      <Query>
        <DataSourceName>MELDEPLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT
	ISNULL(C.EmployeeId,'NULL') AS PrimaryEmployeeId,
	ISNULL((P.FirstName+' '+P.LastName),'NA') AS PrimaryEmployeeName
FROM CompanyCustomers CC
LEFT JOIN Company C ON C.Id=CC.CompanyId
LEFT JOIN Employee E ON E.Id=C.EmployeeId
LEFT JOIN Person P ON P.Id=E.PersonId
WHERE
	C.Deleted!=1 AND
	CC.Deleted!=1 
ORDER BY PrimaryEmployeeName;</CommandText>
      </Query>
      <Fields>
        <Field Name="PrimaryEmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PrimaryEmployeeId</DataField>
        </Field>
        <Field Name="PrimaryEmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PrimaryEmployeeName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
