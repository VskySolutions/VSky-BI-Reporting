        <Field Name="Country">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Country</DataField>
        </Field>
        <Field Name="ZipCode">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ZipCode</DataField>
        </Field>
        <Field Name="PrimaryEmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PrimaryEmployeeId</DataField>
        </Field>
        <Field Name="PrimaryPersonName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PrimaryPersonName</DataField>
        </Field>
        <Field Name="PrimaryEmail">
          <rd:TypeName>System.String</rd:TypeName>
