  <DataSets>
    <DataSet Name="EmployeeTimesheetData">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <rd:UserDefined>true</rd:UserDefined>
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <rd:UserDefined>true</rd:UserDefined>
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>sp_BI_Timesheet_MissedEntries</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
        <Field Name="DateValue">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>DateValue</DataField>
        </Field>
        <Field Name="MissedDays">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>MissedDays</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EmployeeDataset">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
 DISTINCT 
             CONCAT(P.FirstName, ' ', P.LastName) AS EmployeeName

FROM Employee e

LEFT OUTER JOIN EmployeeStatus es 
                     ON e.Id = es.EmployeeId

LEFT OUTER JOIN Dropdown dd 
                     ON dd.Id = es.EmployeeStatusId

LEFT OUTER JOIN Person p 
                     ON e.PersonId = p.Id

WHERE dd.DropdownValue = 'Current'
  AND e.Deleted != 1

ORDER BY EmployeeName;</CommandText>
      </Query>
      <Fields>
        <Field Name="EmployeeName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
