  <ReportParameters>
    <ReportParameter Name="FromDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd("d", -7, Today().AddDays(-1))</Value>
        </Values>
      </DefaultValue>
      <Prompt>Timesheet Start Date</Prompt>
      <cl:ComponentMetadata>
        <cl:HideUpdateNotifications>true</cl:HideUpdateNotifications>
      </cl:ComponentMetadata>
    </ReportParameter>
    <ReportParameter Name="ToDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=Today().AddDays(-1)</Value>
        </Values>
      </DefaultValue>
      <Prompt>Timesheet End Date</Prompt>
      <cl:ComponentMetadata>
        <cl:HideUpdateNotifications>true</cl:HideUpdateNotifications>
      </cl:ComponentMetadata>
    </ReportParameter>
