  <DataSets>
    <DataSet Name="LIST_OF_DOMAIN_MAIN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectName">
            <Value>=Parameters!ProjectName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@URL">
            <Value>=Parameters!URL.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DomainType">
            <Value>=Parameters!DomainType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DomainServer">
            <Value>=Parameters!DomainServer.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@HostingServer">
            <Value>=Parameters!HostingServer.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>With Server_Details AS (SELECT 
	D.Id AS ID,
    CONCAT_WS('/', DD_Domain_Provider.DropDownValue, S_Domain.CustomerId, S_Domain.ContractId) AS Domain_Server,
	CONCAT_WS('/', DD_Hosting_Provider.DropDownValue, S_Hosting.CustomerId, S_Hosting.ContractId) AS Hosting_Server
FROM Domain D
LEFT JOIN dbo.Server S_Domain ON D.DomainServerId = S_Domain.Id
LEFT JOIN dbo.Server S_Hosting ON D.HostingServerId = S_Hosting.Id
LEFT JOIN dbo.DropDown DD_Domain_Provider ON S_Domain.ProviderId = DD_Domain_Provider.Id
LEFT JOIN dbo.DropDown DD_Hosting_Provider ON S_Hosting.ProviderId = DD_Hosting_Provider.Id
)

SELECT Distinct
	P.Id,
    P.Name AS ProjectName,
	D.ID,
    D.Url,
	DD_Type.Id AS DomaintypeId,
    DD_Type.DropDownValue AS DomainType,
    COALESCE(DD_Domain_Provider.DropDownValue, 'N/A') AS DomainServer,
    COALESCE(DD_Hosting_Provider.DropDownValue, 'N/A') AS HostingServer,
	SD.Domain_Server,
	SD.Hosting_Server,
    D.ExternalMappingNote,
    D.DatabaseName,
    D.DatabaseUsername,
    D.DatabasePassword,
    D.DatabaseHostname,
    D.FtpUsername,
    D.FtpPassword,
    D.FtpPort,
    D.FtpHostname,
    D.WebsiteLoginUrl,
    D.WebsiteLoginId,
    D.WebsiteLoginPassword,
    D.Instructions,
    D.Notes AS DomainNotes,
    DD_Attribute.DropDownValue AS DomainAttributeValue,
    DA.StartDate,
    DA.EndDate,
    DA.Amount,
    DA.Duration,
    DA.Notes AS DomainAttributeNotes
FROM dbo.Domain D
JOIN dbo.Projects P ON D.ProjectId = P.Id
JOIN dbo.DropDown DD_Type ON D.DomainTypeId = DD_Type.Id
LEFT JOIN dbo.Server S_Domain ON D.DomainServerId = S_Domain.Id
LEFT JOIN dbo.Server S_Hosting ON D.HostingServerId = S_Hosting.Id
LEFT JOIN dbo.DropDown DD_Domain_Provider ON S_Domain.ProviderId = DD_Domain_Provider.Id
LEFT JOIN dbo.DropDown DD_Hosting_Provider ON S_Hosting.ProviderId = DD_Hosting_Provider.Id
LEFT JOIN dbo.DomainAttributes DA ON D.Id = DA.DomainId 
LEFT JOIN dbo.DropDown DD_Attribute ON DA.DomainAttributeId = DD_Attribute.Id
Left join Server_Details sd on sd.ID = D.Id
WHERE D.Deleted = 0 
AND P.Deleted = 0
AND (P.ID IN (@ProjectName))
AND (D.ID IN (@URL))
AND (DD_Type.Id IN (@DomainType))
AND (SD.Domain_Server IN (@DomainServer))
AND (SD.Hosting_Server IN (@HostingServer));</CommandText>
      </Query>
      <Fields>
        <Field Name="Id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Id</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
