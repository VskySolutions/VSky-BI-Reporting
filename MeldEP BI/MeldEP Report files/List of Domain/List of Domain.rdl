    <DataSet Name="PROJECT_NAME_DROPDOWN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <CommandText>SELECT DISTINCT
     Id,
     Name AS ProjectName
FROM PROJECTS
WHERE DELETED != 1
ORDER BY NAME</CommandText>
      </Query>
      <Fields>
        <Field Name="Id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Id</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="URL_DROPDOWN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <CommandText>SELECT
    Id,
    URL
FROM DOMAIN</CommandText>
      </Query>
      <Fields>
        <Field Name="Id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Id</DataField>
        </Field>
        <Field Name="URL">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>URL</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DOMAIN_TYPE_DROPDOWN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <CommandText>SELECT 
    d.Id AS DomaintypeId,
    d.DropDownValue AS DomainType
FROM dbo.DropDown d
LEFT JOIN dbo.DropDownType dt ON d.DropDownTypeId = dt.Id
WHERE dt.Type = 'Domain Type'
  AND d.Deleted = 0
  AND dt.Deleted = 0
  Order by DropDownValue ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="DomaintypeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DomaintypeId</DataField>
        </Field>
        <Field Name="DomainType">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DomainType</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DOMAIN_SERVER_DROPDOWN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <CommandText>SELECT 
    CONCAT_WS('/', D.DropDownValue, S.CustomerId, S.ContractId) AS Domain_Server
FROM Server S
JOIN DropDown D ON S.ProviderId = D.Id;</CommandText>
      </Query>
      <Fields>
        <Field Name="Domain_Server">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Domain_Server</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="HOSTING_SERVER_DROPDOWN_DS">
      <Query>
        <DataSourceName>Meldep_Live_V3_2</DataSourceName>
        <CommandText>SELECT 
    CONCAT_WS('/', D.DropDownValue, S.CustomerId, S.ContractId) AS Hosting_Server
FROM Server S
JOIN DropDown D ON S.ProviderId = D.Id;</CommandText>
      </Query>
      <Fields>
        <Field Name="Hosting_Server">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Hosting_Server</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
