  <DataSources>
    <DataSource Name="MELDEPDevV32">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=67.211.217.118;Initial Catalog=MeldEp_Live_v3-2</ConnectString>
        <Prompt>Specify a user name and password for data source MELDEPDevV32:</Prompt>
      </ConnectionProperties>
      <rd:DataSourceID>3eed33c2-5b08-46b8-aa3b-cc895d15ba97</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ListOfProjectNoRecentActivityDS">
      <Query>
        <DataSourceName>MELDEPDevV32</DataSourceName>
        <CommandText>SELECT 
	P.Id AS ProjectId,
	P.[Name] AS Project,
	DD.DropDownValue AS ProjectStatus,
	MAX(T.TimeSheetDate) LastUpdatedDate,
	ISNULL(DATEDIFF(DAY, MAX(T.TimesheetDate), GETDATE()),'0') AS InactiveDays
FROM Projects P
LEFT JOIN TimesheetLines TL ON TL.ProjectId=P.Id
LEFT JOIN Timesheet T ON T.Id=TL.TimesheetId
LEFT JOIN DropDown DD ON DD.Id=P.ProjectStatusId
WHERE P.Active=1 AND P.Deleted!=1
GROUP BY P.[Id],P.[Name],DD.DropDownValue
ORDER BY InactiveDays DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="ProjectStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatus</DataField>
        </Field>
        <Field Name="LastUpdatedDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>LastUpdatedDate</DataField>
        </Field>
        <Field Name="InactiveDays">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>InactiveDays</DataField>
        </Field>
        <Field Name="GroupRange">
          <Value>=IIF(Fields!InactiveDays.Value &gt;= 30 AND Fields!InactiveDays.Value &lt;= 60, "30-60",
	IIF(Fields!InactiveDays.Value &gt;= 61 AND Fields!InactiveDays.Value &lt;= 90, "61-90",
		IIF(Fields!InactiveDays.Value &gt;= 91 AND Fields!InactiveDays.Value &lt;= 120, "91-120",
			IIF(Fields!InactiveDays.Value &gt;= 121 AND Fields!InactiveDays.Value &lt;= 150, "121-150",
				"150+"
			)
		)
	)
)</Value>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!GroupRange.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!InactiveDaysRange.Value</FilterValue>
          </FilterValues>
        </Filter>
        <Filter>
          <FilterExpression>=Fields!InactiveDays.Value</FilterExpression>
          <Operator>GreaterThanOrEqual</Operator>
          <FilterValues>
            <FilterValue DataType="Integer">30</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
  </DataSets>
