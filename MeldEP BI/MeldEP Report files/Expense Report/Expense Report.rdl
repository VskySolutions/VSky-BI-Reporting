  <DataSets>
    <DataSet Name="CategoryDataset">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>
SELECT '' AS CategoryId, 'NA' AS CategoryName
UNION
SELECT DISTINCT 
       CAST(ddt.Id AS VARCHAR(50)) AS CategoryId, 
       ddt.DisplayName AS CategoryName
FROM DropDownType ddt
WHERE ddt.GroupName = 'expense category'
                                     --AND ddt.Deleted != 1
ORDER BY CategoryName</CommandText>
      </Query>
      <Fields>
        <Field Name="CategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryId</DataField>
        </Field>
        <Field Name="CategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SubCategoryDataset">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CategoryParam">
            <rd:UserDefined>true</rd:UserDefined>
            <Value>=Parameters!CategoryParam.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--SELECT '' AS SubCategoryId, 'NA' AS SubCategoryName
--UNION
--SELECT 
       --exp_sub.id AS SubCategoryId,
       --exp_sub.name AS SubCategoryName
--FROM Expense_Category_Subcategory exp_sub
--WHERE exp_sub.deleted != 1
  --AND exp_sub.ExpenseCategoryId IN (@CategoryParam)
--ORDER BY SubCategoryName;


--SELECT '' AS SubCategoryId, 'NA' AS SubCategoryName
--UNION
--SELECT 
      -- dd.id AS SubCategoryId,
       --dd.dropdownvalue AS SubCategoryName
--FROM dropdown as dd
--WHERE dd.deleted != 1
  --AND dd.DropDownTypeId IN (@CategoryParam)
--ORDER BY SubCategoryName;


SELECT '' AS SubCategoryId, 'NA' AS SubCategoryName
UNION
SELECT DISTINCT 
       CAST(d.Id AS VARCHAR(50)) AS SubCategoryId,
       d.DropDownValue AS SubCategoryName
FROM DropDown d
WHERE --d.Deleted != 1
       d.DropDownTypeId  IN (@CategoryParam)
ORDER BY SubCategoryName;</CommandText>
      </Query>
      <Fields>
        <Field Name="SubCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubCategoryId</DataField>
        </Field>
        <Field Name="SubCategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubCategoryName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DateDataset">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT CONVERT(VARCHAR(10), e.expensedate, 101) AS ExpenseDate
FROM Expense e
UNION
SELECT DISTINCT CONVERT(VARCHAR(10), exp_adv.RequestDate, 101)
FROM Expense_Advance_Requests exp_adv
UNION
SELECT DISTINCT CONVERT(VARCHAR(10), exp_pur.RequestDate, 101)
FROM Expense_Purchase_Requests exp_pur
ORDER BY ExpenseDate;</CommandText>
      </Query>
      <Fields>
        <Field Name="ExpenseDate">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ExpenseDate</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ExpenseDetails">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CategoryParam">
            <Value>=Parameters!CategoryParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SubCategoryParam">
            <Value>=Parameters!SubCategoryParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromDateParam">
            <Value>=Parameters!FromDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDateParam">
            <Value>=Parameters!ToDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ApprStatusParam">
            <Value>=Parameters!ApprStatusParam.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--expense cat-sub

SELECT 
    e.expensedate AS 'ExpenseDate',
    ddt.DisplayName AS CategoryName,
    d.DropDownValue AS SubCategoryName,
statusDD.DropDownValue as 'Approvement Status',
   e.memo as 'Description',
   per.FIRSTNAME+' '+per.LASTNAME AS Requester,
    SUM(el.Amount) AS TotalAmount
FROM Expense e
LEFT  JOIN Expense_Lines el 
    ON e.Id = el.ExpenseId
LEFT JOIN DropDownType ddt 
    ON el.ExpenseCategoryId = ddt.Id
LEFT  JOIN DropDown d 
    ON el.ExpenseSubCategoryId = d.Id
LEFT  JOIN DropDown statusDD 
    ON statusDD.Id = e.StatusId   -- ✅ approvement status mapping
LEFT JOIN ASPNETUSERS ASP on ASP.ID = e.createdbyid
LEFT JOIN Person per on per.id=ASP.Personid ----Requester Name Mapping
WHERE
    (ISNULL(ddt.Id,'') IN (@CategoryParam))
    AND (ISNULL(d.Id,'') IN (@SubCategoryParam))
    AND CAST(e.expensedate AS DATE) BETWEEN @FromDateParam AND @ToDateParam
    AND ddt.GroupName = 'Expense Category'
    AND e.Deleted != 1
    AND (
        ((statusDD.DropDownValue IS NULL OR LTRIM(RTRIM(statusDD.DropDownValue)) = '') 
             AND 'NA' IN (@ApprStatusParam))
        OR (LTRIM(RTRIM(statusDD.DropDownValue)) IN (@ApprStatusParam))
    )
GROUP BY 
    ddt.DisplayName, 
    d.DropDownValue, 
    e.expensedate,
    statusDD.DropDownValue,
   e.memo,
 per.FIRSTNAME+' '+per.LASTNAME
ORDER BY 
    ddt.DisplayName, 
    d.DropDownValue;</CommandText>
      </Query>
      <Fields>
        <Field Name="ExpenseDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ExpenseDate</DataField>
        </Field>
        <Field Name="CategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryName</DataField>
        </Field>
        <Field Name="SubCategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubCategoryName</DataField>
        </Field>
        <Field Name="Approvement_Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Approvement Status</DataField>
        </Field>
        <Field Name="Description">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Description</DataField>
        </Field>
        <Field Name="Requester">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Requester</DataField>
        </Field>
        <Field Name="TotalAmount">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalAmount</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ExpAdvanceDetails">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CategoryParam">
            <Value>=Parameters!CategoryParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromDateParam">
            <Value>=Parameters!FromDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SubCategoryParam">
            <Value>=Parameters!SubCategoryParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDateParam">
            <Value>=Parameters!ToDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ApprStatusParam">
            <Value>=Parameters!ApprStatusParam.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
    adv.RequestDate AS 'ExpenseDate', 
    ddt.DisplayName AS CategoryName,
    d.DropDownValue AS SubCategoryName,
    statusDD.DropDownValue as 'ApprovementStatus',
    adv.AdvanceDetails as 'Desription',
   per.FIRSTNAME+' '+per.LASTNAME AS Requester,
    SUM(adv.Amount) AS TotalAmount
FROM Expense_Advance_Requests adv
LEFT  JOIN DropDownType ddt 
    ON adv.ItemCategoryId = ddt.Id
LEFT  JOIN DropDown d 
    ON adv.ItemSubCategoryId = d.Id
LEFT  JOIN DropDown statusDD
    ON statusDD.Id = adv.StatusId   -- ✅ approvement status mapping
LEFT JOIN ASPNETUSERS ASP on ASP.ID = adv.createdbyid
LEFT JOIN Person per on per.id=ASP.Personid
WHERE 
    (ISNULL(ddt.Id,'') IN (@CategoryParam))
    AND (ISNULL(d.Id,'') IN (@SubCategoryParam))
    AND CAST(adv.RequestDate AS DATE) BETWEEN @FromDateParam AND @ToDateParam
    AND ddt.GroupName = 'Expense Category'
    AND adv.Deleted != 1
   AND (
        ((statusDD.DropDownValue IS NULL OR LTRIM(RTRIM(statusDD.DropDownValue)) = '') 
             AND 'NA' IN (@ApprStatusParam))
        OR (LTRIM(RTRIM(statusDD.DropDownValue)) IN (@ApprStatusParam))
    )
GROUP BY 
    ddt.DisplayName, 
    d.DropDownValue, 
    adv.RequestDate,
    statusDD.DropDownValue,
   adv.AdvanceDetails,
 per.FIRSTNAME+' '+per.LASTNAME
ORDER BY 
    ddt.DisplayName, 
    d.DropDownValue;</CommandText>
      </Query>
      <Fields>
        <Field Name="ExpenseDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ExpenseDate</DataField>
        </Field>
        <Field Name="CategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryName</DataField>
        </Field>
        <Field Name="SubCategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubCategoryName</DataField>
        </Field>
        <Field Name="ApprovementStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ApprovementStatus</DataField>
        </Field>
        <Field Name="Desription">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Desription</DataField>
        </Field>
        <Field Name="Requester">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Requester</DataField>
        </Field>
        <Field Name="TotalAmount">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalAmount</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ExpPurchaseDetails">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CategoryParam">
            <Value>=Parameters!CategoryParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SubCategoryParam">
            <Value>=Parameters!SubCategoryParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromDateParam">
            <Value>=Parameters!FromDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDateParam">
            <Value>=Parameters!ToDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ApprStatusParam">
            <Value>=Parameters!ApprStatusParam.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT 
    pur.RequestDate AS 'ExpenseDate',
    ddt.DisplayName AS CategoryName,
    d.DropDownValue AS SubCategoryName,
   statusDD.DropDownValue AS 'ApprovementStatus',
   pur.Description as 'Description',
   per.FIRSTNAME+' '+per.LASTNAME AS Requester,
    SUM(pur.EstimatedAmount) AS TotalAmount
FROM Expense_Purchase_Requests pur
LEFT  JOIN DropDownType ddt 
    ON pur.ItemCategoryId = ddt.Id
LEFT  JOIN DropDown d 
    ON pur.ItemSubCategoryId = d.Id
LEFT  JOIN DropDown statusDD
    ON statusDD.Id = pur.StatusId   -- ✅ approvement status mapping
LEFT JOIN ASPNETUSERS ASP on ASP.ID = pur.createdbyid
LEFT JOIN Person per on per.id=ASP.Personid
WHERE 
    (ISNULL(ddt.Id,'') IN (@CategoryParam))
    AND (ISNULL(d.Id,'') IN (@SubCategoryParam))
    AND CAST(pur.RequestDate AS DATE) BETWEEN @FromDateParam AND @ToDateParam
    AND ddt.GroupName = 'Expense Category'
    AND pur.Deleted != 1
    AND (
        ((statusDD.DropDownValue IS NULL OR LTRIM(RTRIM(statusDD.DropDownValue)) = '') 
             AND 'NA' IN (@ApprStatusParam))
        OR (LTRIM(RTRIM(statusDD.DropDownValue)) IN (@ApprStatusParam))
    )
GROUP BY 
    ddt.DisplayName, 
    d.DropDownValue, 
    pur.RequestDate,
statusDD.DropDownValue,
pur.Description,
 per.FIRSTNAME+' '+per.LASTNAME
ORDER BY 
    ddt.DisplayName, 
    d.DropDownValue;</CommandText>
      </Query>
      <Fields>
        <Field Name="ExpenseDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ExpenseDate</DataField>
        </Field>
        <Field Name="CategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CategoryName</DataField>
        </Field>
        <Field Name="SubCategoryName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubCategoryName</DataField>
        </Field>
        <Field Name="ApprovementStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ApprovementStatus</DataField>
        </Field>
        <Field Name="Description">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Description</DataField>
        </Field>
        <Field Name="Requester">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Requester</DataField>
        </Field>
        <Field Name="TotalAmount">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalAmount</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ApprovementDataset">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT ApprovementStatus
FROM (
    SELECT LTRIM(RTRIM(dd.DropDownValue)) AS ApprovementStatus
    FROM DropDown dd
    WHERE dd.Id IN (
        SELECT StatusId FROM Expense
        UNION
        SELECT StatusId FROM Expense_Advance_Requests
        UNION
        SELECT StatusId FROM Expense_Purchase_Requests
    )
    AND dd.DropDownValue NOT IN ('Cancelled','Declined')
    UNION

    SELECT 'NA' AS ApprovementStatus   
) t
ORDER BY ApprovementStatus;</CommandText>
      </Query>
      <Fields>
        <Field Name="ApprovementStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ApprovementStatus</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ReportSummary">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CategoryParam">
            <Value>=Parameters!CategoryParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SubCategoryParam">
            <Value>=Parameters!SubCategoryParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromDateParam">
            <Value>=Parameters!FromDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDateParam">
            <Value>=Parameters!ToDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ApprStatusParam">
            <Value>=Parameters!ApprStatusParam.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>-- combining all three tables

SELECT 
    'Expense Report' AS ReportName,
    CONVERT(VARCHAR(10), @FromDateParam, 103) + ' to ' + CONVERT(VARCHAR(10), @ToDateParam, 103) AS ReportDate,
    SUM(el.Amount) AS TotalAmount
FROM Expense e
LEFT  JOIN Expense_Lines el
          ON e.Id = el.ExpenseID
LEFT  JOIN DropDownType ddt
          ON ddt.Id = el.ExpenseCategoryId
LEFT  JOIN DropDown dd
          ON el.ExpenseSubCategoryId = dd.Id
LEFT  JOIN DropDown statusDD
          ON statusDD.Id = e.StatusId
WHERE 
   (ISNULL(ddt.Id,'') IN (@CategoryParam))
   AND (ISNULL(dd.Id,'') IN (@SubCategoryParam))
   AND CAST(e.ExpenseDate AS DATE) BETWEEN @FromDateParam AND @ToDateParam
   AND ddt.GroupName = 'Expense Category'
   AND (
        ((statusDD.DropDownValue IS NULL OR LTRIM(RTRIM(statusDD.DropDownValue)) = '') 
             AND 'NA' IN (@ApprStatusParam))
        OR (LTRIM(RTRIM(statusDD.DropDownValue)) IN (@ApprStatusParam))
   )

UNION ALL

SELECT 
    'Expense Advance Report' AS ReportName,
    CONVERT(VARCHAR(10), @FromDateParam, 103) + ' to ' + CONVERT(VARCHAR(10), @ToDateParam, 103) AS ReportDate,
    SUM(adv.Amount) AS TotalAmount
FROM Expense_Advance_Requests adv
LEFT  JOIN DropDownType ddt
           ON ddt.Id = adv.ItemCategoryId
LEFT  JOIN DropDown dd
           ON dd.Id = adv.ItemSubCategoryId
LEFT  JOIN DropDown statusDD
           ON statusDD.Id = adv.StatusId
WHERE 
   (ISNULL(ddt.Id,'') IN (@CategoryParam))
   AND (ISNULL(dd.Id,'') IN (@SubCategoryParam))
   AND CAST(adv.RequestDate AS DATE) BETWEEN @FromDateParam AND @ToDateParam
   AND ddt.GroupName = 'Expense Category'
   AND (
        ((statusDD.DropDownValue IS NULL OR LTRIM(RTRIM(statusDD.DropDownValue)) = '') 
             AND 'NA' IN (@ApprStatusParam))
        OR (LTRIM(RTRIM(statusDD.DropDownValue)) IN (@ApprStatusParam))
   )

UNION ALL

SELECT 
    'Expense Purchase Report' AS ReportName,
    CONVERT(VARCHAR(10), @FromDateParam, 103) + ' to ' + CONVERT(VARCHAR(10), @ToDateParam, 103) AS ReportDate,
    SUM(pur.EstimatedAmount) AS TotalAmount
FROM Expense_Purchase_Requests pur
LEFT  JOIN DropDownType ddt
           ON ddt.Id = pur.ItemCategoryId
LEFT  JOIN DropDown dd
           ON dd.Id = pur.ItemSubCategoryId
LEFT JOIN DropDown statusDD
           ON statusDD.Id = pur.StatusId
WHERE 
   (ISNULL(ddt.Id,'') IN (@CategoryParam))
   AND (ISNULL(dd.Id,'') IN (@SubCategoryParam))
   AND CAST(pur.RequestDate AS DATE) BETWEEN @FromDateParam AND @ToDateParam
   AND ddt.GroupName = 'Expense Category'
   AND (
        ((statusDD.DropDownValue IS NULL OR LTRIM(RTRIM(statusDD.DropDownValue)) = '') 
             AND 'NA' IN (@ApprStatusParam))
        OR (LTRIM(RTRIM(statusDD.DropDownValue)) IN (@ApprStatusParam))
   );</CommandText>
      </Query>
      <Fields>
        <Field Name="ReportName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ReportName</DataField>
        </Field>
        <Field Name="ReportDate">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ReportDate</DataField>
        </Field>
        <Field Name="TotalAmount">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>TotalAmount</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="All_Report_Details">
      <Query>
        <DataSourceName>MeldepLive</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDateParam">
            <Value>=Parameters!FromDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDateParam">
            <Value>=Parameters!ToDateParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ApprStatusParam">
            <Value>=Parameters!ApprStatusParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CategoryParam">
            <Value>=Parameters!CategoryParam.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SubCategoryParam">
            <Value>=Parameters!SubCategoryParam.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText> 
-- ===================== EXPENSES =====================
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SELECT   
    exp.ExpenseNumber                       AS ExpenseNumber,

    exp.ExpenseDate                         AS ExpenseDate,

    exp.Memo                                AS Memo,

    CASE 

        WHEN exp.IsReimbursement = 1 THEN 'Yes'

        WHEN exp.IsReimbursement = 0 THEN 'No'

        ELSE NULL 

    END                                     AS IsReimbursement,

    exp.RecurringStartDate                  AS RecurringStartDate,

    per.FIRSTNAME + ' ' + per.LASTNAME      AS CreatedBy,

    exp.CreatedOnUtc                        AS RequestedDate,

    p2.FIRSTNAME + ' ' + p2.LASTNAME        AS UpdatedBy,

    exp.UpdatedOnUtc                        AS UpdatedOn,

    exp.PostApproverNote                    AS ApproverNote,

    exp.PreApproverNote                     AS PreApproverNote,

    exp.PaidByNote                          AS PaidByNote,

    statusDD.DropDownValue                  AS Status,

    DD.DropDownValue                        AS Location,

    ven.VendorName                          AS VendorName,

    DDVendor.DropDownValue                  AS VendorPaymentMethod,

    el.Amount                               AS Amount,

    ddt.DisplayName                         AS CategoryName,

    d.DropDownValue                         AS SubCategoryName
 
FROM Expense exp

INNER JOIN AspNetUsers ASP   ON ASP.Id = exp.CreatedById

INNER JOIN Person per         ON per.Id = ASP.PersonId

INNER JOIN AspNetUsers asp2   ON asp2.Id = exp.UpdatedById

INNER JOIN Person p2          ON p2.Id = asp2.PersonId

INNER JOIN DropDown statusDD  ON statusDD.Id = exp.StatusId

INNER JOIN DropDown DD        ON DD.Id = exp.LocationId

INNER JOIN Expense_Vendor_BankAccounts venbnk ON venbnk.Id = exp.ExpenseVendorBankAccountId

INNER JOIN Expense_Vendors ven               ON ven.Id = venbnk.VendorId

INNER JOIN DropDown DDVendor                 ON venbnk.PaymentTypeId = DDVendor.Id

RIGHT JOIN Expense_Lines el                  ON exp.Id = el.ExpenseId

INNER JOIN DropDownType ddt                  ON el.ExpenseCategoryId = ddt.Id

INNER JOIN DropDown d                        ON el.ExpenseSubCategoryId = d.Id

WHERE exp.Deleted = 0
AND exp.CreatedOnUtc &gt;= @FromDateParam
AND exp.CreatedOnUtc &lt; DATEADD(DAY, 1, @ToDateParam)
AND statusDD.DropDownValue IN (@ApprStatusParam)
  
AND (ISNULL(ddt.Id,'') IN (@CategoryParam))
 AND (ISNULL(d.Id,'') IN (@SubCategoryParam))
 
UNION ALL
 
-- ===================== PURCHASE REQUESTS =====================

SELECT  

    pr.ReferenceId                          AS ExpenseNumber,

    pr.RequestDate                          AS ExpenseDate,

    pr.Description                          AS Memo,

    NULL                                    AS IsReimbursement,

    NULL                                    AS RecurringStartDate,

    per.FIRSTNAME + ' ' + per.LASTNAME      AS CreatedBy,

    pr.CreatedOnUtc                         AS RequestedDate,

    p2.FIRSTNAME + ' ' + p2.LASTNAME        AS UpdatedBy,

    pr.UpdatedOnUtc                         AS UpdatedOn,

    pr.PostApproverNote                     AS ApproverNote,

    pr.PreApproverNote                      AS PreApproverNote,

    pr.PaidByNote                           AS PaidByNote,

    statusDD.DropDownValue                  AS Status,

    NULL                                    AS Location,

    ven.VendorName                          AS VendorName,

    NULL                                    AS VendorPaymentMethod,

    pr.EstimatedAmount                      AS Amount,

    ddt.DisplayName                         AS CategoryName,

    d.DropDownValue                         AS SubCategoryName
 
FROM Expense_Purchase_Requests pr

INNER JOIN AspNetUsers ASP   ON ASP.Id = pr.CreatedById

INNER JOIN Person per         ON per.Id = ASP.PersonId

INNER JOIN AspNetUsers asp2   ON asp2.Id = pr.UpdatedById

INNER JOIN Person p2          ON p2.Id = asp2.PersonId

INNER JOIN DropDown statusDD  ON statusDD.Id = pr.StatusId

INNER JOIN Expense_Vendors ven   ON ven.Id = pr.VendorId

INNER JOIN DropDownType ddt      ON pr.ItemCategoryId = ddt.Id

INNER JOIN DropDown d            ON pr.ItemSubCategoryId = d.Id

WHERE pr.Deleted = 0
AND pr.CreatedOnUtc &gt;= @FromDateParam
AND pr.CreatedOnUtc &lt; DATEADD(DAY, 1, @ToDateParam)
AND statusDD.DropDownValue IN (@ApprStatusParam)
  
 AND (ISNULL(ddt.Id,'') IN (@CategoryParam))
  AND (ISNULL(d.Id,'') IN (@SubCategoryParam))
 
UNION ALL
 
-- ===================== ADVANCE REQUESTS =====================

SELECT 

    ar.ReferenceId                          AS ExpenseNumber,

    ar.RequestDate                          AS ExpenseDate,

    ar.AdvanceDetails                       AS Memo,

    NULL                                    AS IsReimbursement,

    NULL                                    AS RecurringStartDate,

    per.FIRSTNAME + ' ' + per.LASTNAME      AS CreatedBy,

    ar.CreatedOnUtc                         AS RequestedDate,

    p2.FIRSTNAME + ' ' + p2.LASTNAME        AS UpdatedBy,

    ar.UpdatedOnUtc                         AS UpdatedOn,

    ar.PostApproverNote                     AS ApproverNote,

    ar.PreApproverNote                      AS PreApproverNote,

    ar.PaidByNote                           AS PaidByNote,

    statusDD.DropDownValue                  AS Status,

    DD.DropDownValue                        AS Location,

    NULL                                    AS VendorName,

    payDD.DropDownValue                     AS VendorPaymentMethod,

    ar.Amount                               AS Amount,

    ddt.DisplayName                         AS CategoryName,

    d.DropDownValue                         AS SubCategoryName
 
FROM Expense_Advance_Requests ar

INNER JOIN AspNetUsers ASP   ON ASP.Id = ar.CreatedById

INNER JOIN Person per         ON per.Id = ASP.PersonId

INNER JOIN AspNetUsers asp2   ON asp2.Id = ar.UpdatedById

INNER JOIN Person p2          ON p2.Id = asp2.PersonId

INNER JOIN DropDown statusDD  ON statusDD.Id = ar.StatusId

INNER JOIN DropDown DD        ON DD.Id = ar.LocationId

INNER JOIN DropDown payDD     ON payDD.Id = ar.PaymentTypeId

INNER JOIN DropDownType ddt   ON ar.ItemCategoryId = ddt.Id

INNER JOIN DropDown d         ON ar.ItemSubCategoryId = d.Id

WHERE ar.Deleted = 0
AND ar.CreatedOnUtc &gt;= @FromDateParam
AND ar.CreatedOnUtc &lt; DATEADD(DAY, 1, @ToDateParam)
AND statusDD.DropDownValue IN (@ApprStatusParam)
  
AND (ISNULL(ddt.Id,'') IN (@CategoryParam))
  AND (ISNULL(d.Id,'') IN (@SubCategoryParam))</CommandText>
      </Query>
      <Fields>
        <Field Name="ExpenseNumber">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ExpenseNumber</DataField>
        </Field>
        <Field Name="ExpenseDate">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ExpenseDate</DataField>
        </Field>
        <Field Name="Memo">
          <rd:TypeName>System.String</rd:TypeName>
