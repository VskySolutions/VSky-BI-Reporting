        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
        <Field Name="Location">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Location</DataField>
        </Field>
        <Field Name="VendorName">
          <rd:TypeName>System.String</rd:TypeName>
