    <ReportParameter Name="ViewParam">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>ExpenseDetails</Value>
        </Values>
      </DefaultValue>
      <Prompt>Select Report View</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>ExpenseDetails</Value>
