  <DataSources>
    <DataSource Name="MeldEP_Live">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=67.211.217.118;Initial Catalog=Meldep_Live_v3-2</ConnectString>
        <Prompt>Specify a user name and password for data source DataSource1:</Prompt>
      </ConnectionProperties>
      <rd:DataSourceID>15844cdc-fcf3-4c2c-917e-cae6e9875b1e</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Requirement_Notes_DS">
      <Query>
        <DataSourceName>MeldEP_Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectModule">
            <Value>=Parameters!ProjectModule.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Requirement_Title">
            <Value>=Parameters!Requirement_Title.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    p.name AS Project, 
    pm.name AS ProjectModule,
    req.title,
    n.note AS Latest_Note,
    n.updatedonutc AS 'Modified date',
    dd.dropdownvalue AS Status
FROM (
    SELECT *,
        ROW_NUMBER() OVER (PARTITION BY submoduleid ORDER BY updatedonutc DESC) AS rn
    FROM notes
) n
LEFT JOIN requirement req ON req.id = n.submoduleid
LEFT JOIN Projects p ON p.id = req.projectid
LEFT JOIN projectmodules pm ON pm.id = req.projectmoduleid
LEFT JOIN dropdown dd ON req.statusid = dd.id
WHERE n.rn = 1
  AND p.id IN (@Projects)
  AND pm.id IN (@ProjectModule)
  --AND dd.dropdownvalue IN (@Status)
  AND req.id  IN (@Requirement_Title)
  
ORDER BY n.updatedonutc DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="ProjectModule">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectModule</DataField>
        </Field>
        <Field Name="title">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>title</DataField>
        </Field>
        <Field Name="Latest_Note">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Latest_Note</DataField>
        </Field>
        <Field Name="Modified_date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>Modified date</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Projects_DD">
      <Query>
        <DataSourceName>MeldEP_Live</DataSourceName>
        <CommandText>    SELECT DISTINCT
        Id AS ProjectId,
        [Name] AS Project
    
        
    FROM Projects 

    WHERE Deleted != 1
    and active=1
    and siteid='04086f10-8f09-4e0c-b5c0-c827a244addd'
ORDER BY Project</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Project_Module_DD">
      <Query>
        <DataSourceName>MeldEP_Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>    SELECT 
        Id AS Projectmoduleid,
        Name AS ProjectModule
    FROM Projectmodules 
    WHERE Deleted != 1
    and projectid in ( @Projects )

ORDER BY ProjectModule</CommandText>
      </Query>
      <Fields>
        <Field Name="Projectmoduleid">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Projectmoduleid</DataField>
        </Field>
        <Field Name="ProjectModule">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectModule</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Requirement_Title_DD">
      <Query>
        <DataSourceName>MeldEP_Live</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectModule">
            <Value>=Parameters!ProjectModule.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT req.id, req.title, dd.dropdownvalue FROM REQUIREMENT req
LEFT JOIN DROPDOWN dd on dd.id= req.statusid
WHERE req.Deleted!=1
--AND dd.dropdownvalue =@Status
AND req.PROJECTID in (@Projects)
AND req.PROJECTMODULEID in ( @ProjectModule)</CommandText>
      </Query>
      <Fields>
        <Field Name="id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>id</DataField>
        </Field>
        <Field Name="title">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>title</DataField>
        </Field>
        <Field Name="dropdownvalue">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>dropdownvalue</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
