  <DataSets>
    <DataSet Name="WeeklyProjectSummaryReportDataset">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH ConcatenatedComments AS (
    SELECT 
        tl.ProjectId AS ProjectId,
        p.[Name] AS [ProjectName],
		YEAR(T.TimesheetDate) [Year], 
  		MONTH(T.TimesheetDate) [Month],
        CONCAT(
            FORMAT(DATEADD(DAY, -7, DATEADD(DAY, 1, dd.TheLastOfWeek)), 'MM-dd-yy'), 
            ' to ', 
            FORMAT(DATEADD(DAY, 1, dd.TheLastOfWeek), 'MM-dd-yy')
        ) AS WeekInterval,
        string_Agg(tl.[Description], ' ') as PreTimesheetComments,  
        SUM(tl.[Hours]) AS ActualHrs,
        SUM(tl.BillableHours) AS BilledHrs
    FROM Timesheet t
	LEFT OUTER JOIN TimesheetLines tl ON t.Id = tl.TimesheetId
    LEFT OUTER JOIN Projects p ON p.Id= tl.ProjectId	
    LEFT OUTER JOIN DimDate dd ON dd.TheDate = t.TimesheetDate  
    WHERE t.TimesheetDate &lt;= DATEADD(DAY, 1, dd.TheLastOfWeek)
      AND t.TimesheetDate &gt; DATEADD(DAY, -7, DATEADD(DAY, 1, dd.TheLastOfWeek))
      AND t.TimesheetDate &gt;= DATEFROMPARTS(YEAR(@ToDate), 1, 1)
      AND t.TimesheetDate &lt;= @ToDate
	  AND t.Deleted != 1 and tl.Deleted != 1
    GROUP BY 
        tl.ProjectId,
        p.[Name],
	
		YEAR(T.TimesheetDate) , 
  		MONTH(T.TimesheetDate) ,
        DATEADD(DAY, -7, DATEADD(DAY, 1, dd.TheLastOfWeek)),
        DATEADD(DAY, 1, dd.TheLastOfWeek)--,
		--tl.Description
), concatination as(
	SELECT 
		ProjectId,
		ProjectName,
		[Year],
		[Month],
		WeekInterval,
		STRING_AGG(PreTimesheetComments,'') AS TimesheetComments,
		sum(ActualHrs) ActualHrs,
		sum(BilledHrs) BilledHrs
	FROM ConcatenatedComments
	GROUP BY
		ProjectId,
		ProjectName,
		[Year],
		[Month],
		WeekInterval
)
select * from 
	concatination;</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
        <Field Name="Month">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Month</DataField>
        </Field>
        <Field Name="WeekInterval">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekInterval</DataField>
        </Field>
        <Field Name="TimesheetComments">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TimesheetComments</DataField>
        </Field>
        <Field Name="ActualHrs">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ActualHrs</DataField>
        </Field>
        <Field Name="BilledHrs">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>BilledHrs</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!ProjectId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!ProjectDropDown.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="ProjectDropDownDataSet">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Customer">
            <Value>=Parameters!Customer.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH ProjectDetailsList AS(
SELECT DISTINCT
	P.Id AS ProjectId,
	P.[Name] AS Project,
P.CustomerId

FROM Projects P 
WHERE
	P.Deleted!=1 AND P.Active=1
)
SELECT
	PD.ProjectId,
	PD.Project
FROM ProjectDetailsList PD
WHERE 
          isnull(PD.CustomerId,'') IN (@Customer)
ORDER BY Project</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MonthYearDataset">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>SELECT DISTINCT
	YEAR(t.TimesheetDate) Year, 
    MONTH(t.TimesheetDate) Month,
    FORMAT(t.TimesheetDate, 'MMM yyyy') AS MonthYear
FROM Timesheet t
ORDER BY 
    YEAR(t.TimesheetDate), 
    MONTH(t.TimesheetDate);</CommandText>
      </Query>
      <Fields>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
        <Field Name="Month">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Month</DataField>
        </Field>
        <Field Name="MonthYear">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthYear</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectTimesheetDetailsDataset">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
        FORMAT(t.TimesheetDate, 'MM/dd/yyyy') AS [Date],  
        FORMAT(DATEADD(DAY, 1, dd.TheLastOfWeek), 'MM/dd/yyyy') AS WeekEnding, 
        tl.ProjectId AS ProjectId,
        p.[Name] AS Project,    
       -- dbo.RemoveHTMLTagsAndEntities(t.ActivityDetails) AS ActivityDetails,
tl.[Description] AS ActivityDetails,
        e.Id AS EmployeeId,
        Per.FirstName + ' ' + Per.LastName AS [Resource],
        tl.[Hours] AS ActualHours,
        tl.BillableHours AS BillableHours,
        tl.ProjectTaskId AS TaskId,
        pt.Name AS WorkType

    FROM Timesheet t
	LEFT JOIN TimesheetLines tl ON (t.Id = tl.TimesheetId)

    LEFT JOIN Projects p ON tl.ProjectId = p.Id
    LEFT JOIN ProjectTasks pt ON tl.ProjectTaskId = pt.Id
    LEFT JOIN [DimDate] dd ON t.TimesheetDate = dd.TheDate
    LEFT JOIN AspNetUsers anu ON tl.CreatedById = anu.Id
    --LEFT JOIN Employee e ON e.Email = anu.Email
	LEFT JOIN Person Per ON anu.PersonId = Per.Id
	LEFT JOIN Employee e ON (e.PersonId = Per.Id AND (e.deleted IS NULL OR e.Deleted = 0))

    WHERE 
        (t.TimesheetDate BETWEEN @FromDate AND @ToDate) 
        AND (t.Deleted = 0 or t.Deleted is null) and (tl.Deleted = 0 or tl.Deleted is null)

       
    ORDER BY t.TimesheetDate ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="Date">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Date</DataField>
        </Field>
        <Field Name="WeekEnding">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekEnding</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="ActivityDetails">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActivityDetails</DataField>
        </Field>
        <Field Name="EmployeeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EmployeeId</DataField>
        </Field>
        <Field Name="Resource">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Resource</DataField>
        </Field>
        <Field Name="ActualHours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ActualHours</DataField>
        </Field>
        <Field Name="BillableHours">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>BillableHours</DataField>
        </Field>
        <Field Name="TaskId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TaskId</DataField>
        </Field>
        <Field Name="WorkType">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WorkType</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!ProjectId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!ProjectDropDown.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="ActualVsBillableHrsDataset">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    tl.ProjectId,
    P.[Name] AS ProjectName,
  YEAR(T.TimesheetDate) [Year], 
  MONTH(T.TimesheetDate) [Month],
    FORMAT(T.TimesheetDate, 'MMM yyyy') AS MonthYear,
    SUM(tl.Hours) AS ActualHrs,
    SUM(tl.BillableHours) AS BillableHrs
FROM 
    Timesheet T
LEFT OUTER JOIN 
    TimesheetLines tl ON t.Id=tl.TimesheetId
LEFT OUTER JOIN 
    Projects P ON P.Id = tl.ProjectId
WHERE 
    (T.Deleted = 0 OR T.Deleted IS NULL) 
    AND P.Name IS NOT NULL
    AND T.TimesheetDate BETWEEN DATEFROMPARTS(YEAR(@ToDate), 1, 1) AND @ToDate
GROUP BY 
    tl.ProjectId, P.[Name], FORMAT(T.TimesheetDate, 'MMM yyyy'), YEAR(T.TimesheetDate), MONTH(T.TimesheetDate)
ORDER BY 
    YEAR(T.TimesheetDate), 
    MONTH(T.TimesheetDate),
  P.[Name];</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="ProjectName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectName</DataField>
        </Field>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
        <Field Name="Month">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Month</DataField>
        </Field>
        <Field Name="MonthYear">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthYear</DataField>
        </Field>
        <Field Name="ActualHrs">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ActualHrs</DataField>
        </Field>
        <Field Name="BillableHrs">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>BillableHrs</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!ProjectId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!ProjectDropDown.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="CustomerDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>WITH CustomerDetails AS (
SELECT 
	CC.Id AS CustomerId,
	C.[Name] AS CustomerName
FROM CompanyCustomers CC
LEFT  JOIN Company C ON C.Id=CC.CompanyId
LEFT JOIN Projects P ON P.CustomerId=CC.Id AND P.Deleted!=1 and P.Active=1
WHERE CC.Deleted!=1 AND C.Deleted!=1
)
SELECT 'NULL' AS CustomerId,'NA' AS CustomerName
UNION
SELECT DISTINCT
CD.CustomerId,
CD.CustomerName
FROM CustomerDetails CD
ORDER BY CustomerName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
