	dd.dropdownvalue as projecttype
from dropdown dd
left join dropdowntype ddt on ddt.id=dd.dropdowntypeid and ddt.deleted!=1
where dd.deleted!=1
and ddt.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---Vsky SiteID
