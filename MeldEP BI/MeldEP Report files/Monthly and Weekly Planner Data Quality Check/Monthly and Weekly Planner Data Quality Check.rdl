    <DataSet Name="ProjectCategoryDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT ''as projectcategoryid,
'NA' AS projectcategory
UNION 
SELECT
	ddt.id as projectcategoryid,
	ddt.Type as projectcategory
FROM DropDownType ddt 
Where ddt.Groupname='ProjectCategory'
and ddt.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---Vsky SiteID
and ddt.deleted!=1</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectcategoryid</DataField>
        </Field>
        <Field Name="projectcategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectSubCategoryDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectCategory">
            <Value>=Parameters!ProjectCategory.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--select ''as projectsubcategoryid,
--'NA' AS projectsubcategory
--UNION
--select 
--	dd.id as projectsubcategoryid,
--	dd.dropdownvalue as projectsubcategory
--from dropdown dd
--left join dropdowntype ddt on ddt.id=dd.dropdowntypeid and ddt.deleted!=1
--where dd.deleted!=1
--and ddt.type='Project Subcategory'
--order by projectsubcategory


select ''as SubCategoryId,
           'NA' AS Subcategory 
UNION 
SELECT DISTINCT 
       CAST(dd.Id AS VARCHAR(50)) AS SubCategoryId, 
     dd.DropDownValue as Subcategory
FROM DropDownType ddt LEFT JOIN DropDown dd
           ON ddt.Id = dd.DropDownTypeId 
WHERE ddt.GroupName = 'ProjectCategory' 
            --AND ddt.Deleted != 1 
           AND ddt.Id IN (@ProjectCategory) 
ORDER BY Subcategory</CommandText>
      </Query>
      <Fields>
        <Field Name="SubCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubCategoryId</DataField>
        </Field>
        <Field Name="Subcategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Subcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
