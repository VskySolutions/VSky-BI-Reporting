    <DataSet Name="YearDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>SELECT DISTINCT 
    YEAR(PWPD.WeekDate) AS Year
FROM Project_WeeklyPlan_Dates PWPD
ORDER BY Year DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="Year">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Year</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MonthDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>SELECT 
    DISTINCT MONTH(pwd.WeekDate) AS MonthNumber,
    DATENAME(MONTH, DATEFROMPARTS(2000, MONTH(pwd.WeekDate), 1)) AS MonthName
FROM Project_WeeklyPlan_Dates pwd
ORDER BY Monthnumber</CommandText>
      </Query>
      <Fields>
        <Field Name="MonthNumber">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>MonthNumber</DataField>
        </Field>
        <Field Name="MonthName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="WeekEndDateDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Month">
            <Value>=Parameters!Month.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH Tally AS (
    SELECT TOP (31) ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) - 1 AS n
    FROM sys.all_objects
)
SELECT 
    CAST(DATEADD(DAY, n, DATEFROMPARTS(@Year, @Month, 1)) AS DATE) AS WeekEndDateValue,
    FORMAT(DATEADD(DAY, n, DATEFROMPARTS(@Year, @Month, 1)), 'MM-dd-yyyy') AS WeekEndDateLabel
FROM Tally
WHERE 
    DATENAME(WEEKDAY, DATEADD(DAY, n, DATEFROMPARTS(@Year, @Month, 1))) = 'Sunday'
    AND MONTH(DATEADD(DAY, n, DATEFROMPARTS(@Year, @Month, 1))) = @Month</CommandText>
      </Query>
      <Fields>
        <Field Name="WeekEndDateValue">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>WeekEndDateValue</DataField>
        </Field>
        <Field Name="WeekEndDateLabel">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekEndDateLabel</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectActiveStatusDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>SELECT DISTINCT
                CASE 
		WHEN P.Active=1 THEN 1
		WHEN P.Active=0 THEN 0
	END AS StatusId,
	CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status
FROM Projects P
WHERE
	P.Deleted!=1 
and p.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---Vsky SiteID
ORDER BY Status</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CustomerDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectActiveStatus">
            <Value>=Parameters!ProjectActiveStatus.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH ProjectDetailsList AS (
    SELECT DISTINCT
        CASE 
            WHEN P.Active = 1 THEN 1
            ELSE 0
        END AS StatusId,
        CASE 
            WHEN P.Active = 1 THEN 'Active'
            ELSE 'Inactive'
        END AS Status,
        CPL.CustomerId,
		C.CustomerName
    FROM Projects P
JOIN ProjectActivities pa on pa.projectid=p.id and pa.deleted!=1
    JOIN VW_CustomerProjectList CPL ON P.Id = CPL.Id
	JOIN  VW_CustomerList C ON C.Id=CPL.CustomerId
    WHERE P.Deleted != 1
)
SELECT PD.CustomerId, PD.CustomerName
FROM ProjectDetailsList PD
WHERE PD.StatusId IN (@ProjectActiveStatus)
ORDER BY CustomerName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectActiveStatus">
            <Value>=Parameters!ProjectActiveStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CustomerName">
            <Value>=Parameters!CustomerName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH ProjectDetailsList AS (
    SELECT DISTINCT
        P.Id AS ProjectId,
        P.[Name] AS Project,
        CASE 
            WHEN P.Active = 1 THEN 1
            ELSE 0
        END AS StatusId,
        CASE 
            WHEN P.Active = 1 THEN 'Active'
            ELSE 'Inactive'
        END AS Status,
        CPL.CustomerId
    FROM Projects P
    JOIN VW_CustomerProjectList CPL ON P.Id = CPL.Id
    WHERE P.Deleted != 1
and p.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---Vsky SiteID
)
SELECT PD.ProjectId, PD.Project
FROM ProjectDetailsList PD
WHERE PD.StatusId IN (@ProjectActiveStatus) and PD.CustomerId IN (@CustomerName)
ORDER BY Project</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectStatusDropDownDS">
      <Query>
        <DataSourceName>MeldepLiveV32</DataSourceName>
        <CommandText>select 
	dd.id as projectstatusid,
	dd.dropdownvalue as projectstatus
from dropdown dd
left join dropdowntype ddt on ddt.id=dd.dropdowntypeid and ddt.deleted!=1
where dd.deleted!=1
and ddt.siteid='04086f10-8f09-4e0c-b5c0-c827a244addd' ---Vsky SiteID
and ddt.type='Project Status'
order by projectstatus</CommandText>
      </Query>
      <Fields>
        <Field Name="projectstatusid">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectstatusid</DataField>
        </Field>
        <Field Name="projectstatus">
