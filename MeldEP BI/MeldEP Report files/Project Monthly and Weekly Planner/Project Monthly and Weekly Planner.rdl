                <TablixColumnHierarchy>
                  <TablixMembers>
                    <TablixMember>
                      <Group Name="Date">
                        <GroupExpressions>
                          <GroupExpression>=Fields!Date.Value</GroupExpression>
                        </GroupExpressions>
                      </Group>
