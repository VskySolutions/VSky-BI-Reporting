  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="ProjectWeeklyPlanner">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=67.211.217.118;Initial Catalog=Meldep_Live_v3-2</ConnectString>
        <Prompt>Specify a user name and password for data source ProjectWeeklyPlanner:</Prompt>
      </ConnectionProperties>
      <rd:DataSourceID>b1be40b5-7730-4003-b466-2226eddd33c6</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProjectMonthlyPlanDescription">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <rd:UserDefined>true</rd:UserDefined>
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <rd:UserDefined>true</rd:UserDefined>
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CustomerName">
            <Value>=Parameters!CustomerName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectType">
            <Value>=Parameters!ProjectType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectPriority">
            <Value>=Parameters!ProjectPriority.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectCategory">
            <Value>=Parameters!ProjectCategory.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectSubcategory">
            <Value>=Parameters!ProjectSubcategory.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
-- 1. Generate all months in the range
;WITH MonthsCTE AS (
    SELECT DATEADD(MONTH, DATEDIFF(MONTH, 0, @FromDate), 0) AS MonthStart
    UNION ALL
    SELECT DATEADD(MONTH, 1, MonthStart)
    FROM MonthsCTE
    WHERE MonthStart &lt; DATEADD(MONTH, DATEDIFF(MONTH, 0, @ToDate), 0)
),

-- 2. Aggregate Actual Data
ActualData AS (
    SELECT 
        DATEADD(MONTH, DATEDIFF(MONTH, 0, PWPD.WeekDate), 0) AS MonthStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,
       COALESCE(STRING_AGG(PWPDL.ActualDescription, CHAR(13) + CHAR(10)), '') AS ActualDescription
    FROM Projects P
INNER JOIN VW_CustomerProjectList CPL ON CPL.Id = P.Id
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId
LEFT JOIN DropDown SDD ON SDD.Id = P.ProjectStatusId
LEFT JOIN DropDown PT ON PT.Id = P.ProjectTypeId
LEFT JOIN DropDown PP ON PP.Id = P.ProjectPriorityId
LEFT JOIN DropDownType DDT ON DDT.Id = P.ProjectCategoryId
LEFT JOIN DropDown PSC ON PSC.Id = P.ProjectSubcategoryId

    WHERE 
        P.Deleted != 1
       AND PWPDL.Deleted != 1
        AND PWPDL.ActualDescription IS NOT NULL
       AND LTRIM(RTRIM(PWPDL.ActualDescription)) &lt;&gt; ''
        AND D.Id = 'A2F7DA83-A804-4ACE-914D-F0B6E9F63A39'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
AND CPL.CustomerId IN (@CustomerName)
AND CPL.Id IN  (@Projects)
AND P.ProjectStatusId IN (@ProjectStatus)
AND P.ProjectTypeId IN (@ProjectType)
AND P.ProjectPriorityId IN (@ProjectPriority)

AND (ISNULL(P.ProjectCategoryId, '') IN (@ProjectCategory))
AND (ISNULL(P.ProjectSubcategoryId, '') IN (@ProjectSubcategory))



    GROUP BY 
        DATEADD(MONTH, DATEDIFF(MONTH, 0, PWPD.WeekDate), 0),
        P.Id,
        P.Name,
        P.Active
),

-- 3. Aggregate Expected Data
ExpectedData AS (
    SELECT
        DATEADD(MONTH, DATEDIFF(MONTH, 0, PWPD.WeekDate), 0) AS MonthStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,
       COALESCE(STRING_AGG(PWPDL.ExpectedDescription, CHAR(13) + CHAR(10)), '') AS ExpectedDescription
    FROM Projects P
INNER JOIN VW_CustomerProjectList CPL ON CPL.Id = P.Id
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId
LEFT JOIN DropDown SDD ON SDD.Id = P.ProjectStatusId
LEFT JOIN DropDown DPT ON DPT.Id = P.ProjectTypeId
LEFT JOIN DropDown DPP ON DPP.Id = P.ProjectPriorityId
LEFT JOIN DropDownType DDT ON DDT.Id = P.ProjectCategoryId
LEFT JOIN DropDown PSC ON PSC.Id = P.ProjectSubcategoryId
    WHERE 
        P.Deleted != 1
         AND PWPDL.Deleted != 1
        AND PWPDL.ExpectedDescription IS NOT NULL
       AND LTRIM(RTRIM(PWPDL.ExpectedDescription)) &lt;&gt; ''
        AND D.Id = 'A2F7DA83-A804-4ACE-914D-F0B6E9F63A39'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
AND CPL.CustomerId IN (@CustomerName)
AND CPL.Id IN  (@Projects)
AND P.ProjectStatusId IN (@ProjectStatus)
AND P.ProjectTypeId IN (@ProjectType)
AND P.ProjectPriorityId IN (@ProjectPriority)
AND (ISNULL(P.ProjectCategoryId, '') IN (@ProjectCategory))
AND (ISNULL(P.ProjectSubcategoryId, '') IN (@ProjectSubcategory))


    GROUP BY 
        DATEADD(MONTH, DATEDIFF(MONTH, 0, PWPD.WeekDate), 0),
        P.Id,
        P.Name,
        P.Active
),

-- 4. Get all distinct Projects appearing in Actual or Expected data for the range
AllProjects AS (
    SELECT DISTINCT ProjectId, Project, StatusId, Status
    FROM (
        SELECT ProjectId, Project, StatusId, Status FROM ActualData
        UNION
        SELECT ProjectId, Project, StatusId, Status FROM ExpectedData
    ) p
)

-- 5. Final join: all months × all projects LEFT JOIN data
SELECT
    COALESCE(A.MonthStart, E.MonthStart, M.MonthStart) AS Date,  -- raw date for grouping
    FORMAT(COALESCE(A.MonthStart, E.MonthStart, M.MonthStart), 'MMMM yyyy') AS MonthName,
    P.ProjectId,
    P.Project,
    P.StatusId,
    P.Status,
    CASE 
      WHEN A.ActualDescription IS NULL OR LTRIM(RTRIM(A.ActualDescription)) = '' THEN ' ' 
      ELSE A.ActualDescription 
    END AS ActualDescription,
    CASE 
      WHEN E.ExpectedDescription IS NULL OR LTRIM(RTRIM(E.ExpectedDescription)) = '' THEN ' ' 
      ELSE E.ExpectedDescription 
    END AS ExpectedDescription
FROM MonthsCTE M
CROSS JOIN AllProjects P
LEFT JOIN ActualData A 
    ON A.MonthStart = M.MonthStart AND A.ProjectId = P.ProjectId
LEFT JOIN ExpectedData E
    ON E.MonthStart = M.MonthStart AND E.ProjectId = P.ProjectId
ORDER BY M.MonthStart, P.ProjectId
OPTION (MAXRECURSION 0);</CommandText>
      </Query>
      <Fields>
        <Field Name="Date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>Date</DataField>
        </Field>
        <Field Name="MonthName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthName</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
        <Field Name="ActualDescription">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActualDescription</DataField>
        </Field>
        <Field Name="ExpectedDescription">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ExpectedDescription</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!ProjectId.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!Projects.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="ProjectDS">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CustomerName">
            <Value>=Parameters!CustomerName.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH ProjectDetailsList AS (
    SELECT DISTINCT
        P.Id AS ProjectId,
        P.[Name] AS Project,
        CASE 
            WHEN P.Active = 1 THEN 1
            ELSE 0
        END AS StatusId,
        CASE 
            WHEN P.Active = 1 THEN 'Active'
            ELSE 'Inactive'
        END AS Status,
        CPL.CustomerId
    FROM Projects P
    JOIN VW_CustomerProjectList CPL ON P.Id = CPL.Id
    WHERE P.Deleted != 1
)
SELECT PD.ProjectId, PD.Project
FROM ProjectDetailsList PD
WHERE PD.StatusId IN (@Status) 
  AND PD.CustomerId IN (@CustomerName)
ORDER BY Project</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="StatusDS">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT
                CASE 
		WHEN P.Active=1 THEN 1
		WHEN P.Active=0 THEN 0
	END AS StatusId,
	CASE 
		WHEN P.Active=1 THEN 'Active'
		WHEN P.Active=0 THEN 'Inactive'
	END AS Status
FROM Projects P
WHERE
	P.Deleted!=1 
ORDER BY Status</CommandText>
      </Query>
      <Fields>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ClientNameList">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>WITH ProjectDetailsList AS (
    SELECT DISTINCT
        CASE 
            WHEN P.Active = 1 THEN 1
            ELSE 0
        END AS StatusId,
        CASE 
            WHEN P.Active = 1 THEN 'Active'
            ELSE 'Inactive'
        END AS Status,
        CPL.CustomerId,
		C.CustomerName
    FROM Projects P
    JOIN VW_CustomerProjectList CPL ON P.Id = CPL.Id
	JOIN  VW_CustomerList C ON C.Id=CPL.CustomerId
    WHERE P.Deleted != 1
)
SELECT PD.CustomerId, PD.CustomerName
FROM ProjectDetailsList PD
WHERE PD.StatusId IN (@Status)
ORDER BY CustomerName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerID">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CustomerName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectMOduleDropDown">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT '' AS ProjectId,'NA' AS Project,
'' AS ModuleId,
'NA' AS ModuleName UNION
SELECT DISTINCT
P.Id AS ProjectId,
P.Name AS Project,
ISNULL(PM.Id,'NULL') AS ModuleId,
ISNULL(PM.Name,'NA') AS ModuleName
FROM Projects P
LEFT JOIN ProjectModules PM ON PM.ProjectId=P.Id AND PM.Deleted!=1
WHERE P.Deleted!=1
AND ISNULL(P.Id,'NULL') IN (@Projects)
ORDER BY ModuleName</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="ModuleId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ModuleId</DataField>
        </Field>
        <Field Name="ModuleName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ModuleName</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectStatus">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT
	DD.Id AS ProjectStatusId,
	DD.DropDownValue AS ProjectStatus
FROM projects p
LEFT JOIN DropDown DD
ON p.ProjectStatusId = dd.id
LEFT JOIN DropDownType DDT
ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Status'
AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectStatusId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatusId</DataField>
        </Field>
        <Field Name="ProjectStatus">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectStatus</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjetTypeDS">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT DISTINCT
	DD.Id AS ProjectTypeId,
	DD.DropDownValue AS ProjectType
FROM projects P
LEFT JOIN DropDown DD 
ON P.projecttypeid = dd.id
LEFT JOIN DropDownType DDT 
ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Type'
AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectTypeId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectTypeId</DataField>
        </Field>
        <Field Name="ProjectType">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectType</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectPriorityDS">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--SELECT 
--	DD.Id AS ProjectPriorityId,
--	DD.DropDownValue AS ProjectPriority
--FROM DropDown DD
--LEFT JOIN DropDownType DDT ON DD.DropDownTypeId=DDT.Id
--WHERE DDT.Type='Project Priorities'
--AND DDT.Deleted!=1
--ORDER BY DD.DropDownValue

SELECT DISTINCT
	DD.Id AS ProjectPriorityId,
	DD.DropDownValue AS ProjectPriority
FROM Projects P
LEFT JOIN DropDown DD
        ON P.ProjectPriorityId = DD.Id
LEFT JOIN DropDownType DDT 
       ON DD.DropDownTypeId=DDT.Id
WHERE DDT.Type='Project Priorities'
             AND DDT.Deleted!=1
ORDER BY DD.DropDownValue</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectPriorityId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectPriorityId</DataField>
        </Field>
        <Field Name="ProjectPriority">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectPriority</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectCategoryDS">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT ''as projectcategoryid,
'NA' AS projectcategory
UNION 
SELECT
	ddt.id as projectcategoryid,
	ddt.Type as projectcategory
FROM DropDownType ddt 
Where ddt.Groupname='ProjectCategory'
and ddt.deleted!=1</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectcategoryid</DataField>
        </Field>
        <Field Name="ProjectCategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>projectcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectSubCategoryDS">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectCategory">
            <Value>=Parameters!ProjectCategory.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>

select ''as SubCategoryId,
           'NA' AS Subcategory 
UNION 
SELECT DISTINCT 
       CAST(dd.Id AS VARCHAR(50)) AS SubCategoryId, 
     dd.DropDownValue as Subcategory
FROM DropDownType ddt LEFT JOIN DropDown dd
           ON ddt.Id = dd.DropDownTypeId 
WHERE ddt.GroupName = 'ProjectCategory' 
           AND ddt.Id IN (@ProjectCategory) 
ORDER BY Subcategory</CommandText>
      </Query>
      <Fields>
        <Field Name="SubCategoryId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SubCategoryId</DataField>
        </Field>
        <Field Name="Subcategory">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Subcategory</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectWeeklyPlanDescription">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CustomerName">
            <Value>=Parameters!CustomerName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectType">
            <Value>=Parameters!ProjectType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectPriority">
            <Value>=Parameters!ProjectPriority.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectCategory">
            <Value>=Parameters!ProjectCategory.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectSubcategory">
            <Value>=Parameters!ProjectSubcategory.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SET DATEFIRST 1;  -- Week starts on Monday

-- 1. Generate Week Range
;WITH WeekRange AS (
    SELECT DISTINCT
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, TheDate), TheDate) AS WeekStart,
        DATEADD(DAY, 7 - DATEPART(WEEKDAY, TheDate), TheDate) AS WeekEnd
    FROM DimDate
    WHERE TheDate BETWEEN @FromDate AND @ToDate
),

-- 2. Actual Data
ActualData AS (
    SELECT
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, PWPD.WeekDate), CAST(PWPD.WeekDate AS DATE)) AS WeekStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,
        STRING_AGG(PWPDL.ActualDescription, CHAR(13) + CHAR(10)) AS ActualDescription
    FROM Projects P
    INNER JOIN VW_CustomerProjectList CPL ON CPL.Id = P.Id
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId
    WHERE
        P.Deleted &lt;&gt; 1
        AND PWPDL.Deleted &lt;&gt; 1
        AND PWPDL.ActualDescription IS NOT NULL
        AND LTRIM(RTRIM(PWPDL.ActualDescription)) &lt;&gt; ''
        AND D.Id = '1CFDEC9F-9C68-4E75-BC4E-E408C5918B1A'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
        AND CPL.CustomerId IN (@CustomerName)
        AND CPL.Id IN (@Projects)
        AND P.ProjectStatusId IN (@ProjectStatus)
        AND P.ProjectTypeId IN (@ProjectType)
        AND P.ProjectPriorityId IN (@ProjectPriority)
        AND ISNULL(P.ProjectCategoryId,'') IN (@ProjectCategory)
        AND ISNULL(P.ProjectSubcategoryId,'') IN (@ProjectSubcategory)
    GROUP BY
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, PWPD.WeekDate), CAST(PWPD.WeekDate AS DATE)),
        P.Id, P.Name, P.Active
),

-- 3. Expected Data
ExpectedData AS (
    SELECT
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, PWPD.WeekDate), CAST(PWPD.WeekDate AS DATE)) AS WeekStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,
        STRING_AGG(PWPDL.ExpectedDescription, CHAR(13) + CHAR(10)) AS ExpectedDescription
    FROM Projects P
    INNER JOIN VW_CustomerProjectList CPL ON CPL.Id = P.Id
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId
    WHERE
        P.Deleted &lt;&gt; 1
        AND PWPDL.Deleted &lt;&gt; 1
        AND PWPDL.ExpectedDescription IS NOT NULL
        AND LTRIM(RTRIM(PWPDL.ExpectedDescription)) &lt;&gt; ''
        AND D.Id = '1CFDEC9F-9C68-4E75-BC4E-E408C5918B1A'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
        AND CPL.CustomerId IN (@CustomerName)
        AND CPL.Id IN (@Projects)
        AND P.ProjectStatusId IN (@ProjectStatus)
        AND P.ProjectTypeId IN (@ProjectType)
        AND P.ProjectPriorityId IN (@ProjectPriority)
        AND ISNULL(P.ProjectCategoryId,'') IN (@ProjectCategory)
        AND ISNULL(P.ProjectSubcategoryId,'') IN (@ProjectSubcategory)
    GROUP BY
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, PWPD.WeekDate), CAST(PWPD.WeekDate AS DATE)),
        P.Id, P.Name, P.Active
),

-- 4. Project List
AllProjects AS (
    SELECT DISTINCT ProjectId, Project, StatusId, Status
    FROM (
        SELECT ProjectId, Project, StatusId, Status FROM ActualData
        UNION
        SELECT ProjectId, Project, StatusId, Status FROM ExpectedData
    ) P
)

-- 5. Final Output
SELECT
    W.WeekStart AS [Date],
    FORMAT(W.WeekStart, 'dd MMM yyyy') + ' - ' +
    FORMAT(W.WeekEnd, 'dd MMM yyyy') AS WeekRange,
    P.ProjectId,
    P.Project,
    P.StatusId,
    P.Status,
    ISNULL(E.ExpectedDescription, '') AS ExpectedDescription,
    ISNULL(A.ActualDescription, '') AS ActualDescription
FROM WeekRange W
CROSS JOIN AllProjects P
LEFT JOIN ActualData A 
    ON A.WeekStart = W.WeekStart 
    AND A.ProjectId = P.ProjectId
LEFT JOIN ExpectedData E 
    ON E.WeekStart = W.WeekStart 
    AND E.ProjectId = P.ProjectId
ORDER BY W.WeekStart, P.ProjectId;</CommandText>
      </Query>
      <Fields>
        <Field Name="Date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>Date</DataField>
        </Field>
        <Field Name="WeekRange">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekRange</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
        <Field Name="ActualDescription">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ActualDescription</DataField>
        </Field>
        <Field Name="ExpectedDescription">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ExpectedDescription</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="WeeksDataset">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SET DATEFIRST 1; -- Monday

DECLARE @FromDate DATE = CAST(GETDATE() AS DATE);   -- you can later replace with parameter if needed
DECLARE @WeekStart DATE =
    DATEADD(DAY, 1 - DATEPART(WEEKDAY, @FromDate), @FromDate);

;WITH WeekCTE AS (
    -- current week
    SELECT @WeekStart AS WeekStart
    UNION ALL
    -- previous weeks (optional, change 4 to number you want)
    SELECT DATEADD(WEEK, -1, WeekStart)
    FROM WeekCTE
    WHERE DATEADD(WEEK, -1, WeekStart) &gt;= DATEADD(MONTH, -1, @FromDate)
)
SELECT
    WeekStart,
    DATEADD(DAY, 6, WeekStart) AS WeekEnd,
    FORMAT(WeekStart, 'dd MMM yyyy') + ' - ' +
    FORMAT(DATEADD(DAY, 6, WeekStart), 'dd MMM yyyy') AS WeekLabel
FROM WeekCTE
ORDER BY WeekStart DESC
OPTION (MAXRECURSION 10);</CommandText>
      </Query>
      <Fields>
        <Field Name="WeekStart">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>WeekStart</DataField>
        </Field>
        <Field Name="WeekEnd">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>WeekEnd</DataField>
        </Field>
        <Field Name="WeekLabel">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekLabel</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectMonthlySummarydataset">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CustomerName">
            <Value>=Parameters!CustomerName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectType">
            <Value>=Parameters!ProjectType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectPriority">
            <Value>=Parameters!ProjectPriority.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectCategory">
            <Value>=Parameters!ProjectCategory.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectSubcategory">
            <Value>=Parameters!ProjectSubcategory.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
-- 1. Generate all months in the range
;WITH MonthsCTE AS (
    SELECT DATEADD(MONTH, DATEDIFF(MONTH, 0, @FromDate), 0) AS MonthStart
    UNION ALL
    SELECT DATEADD(MONTH, 1, MonthStart)
    FROM MonthsCTE
    WHERE MonthStart &lt; DATEADD(MONTH, DATEDIFF(MONTH, 0, @ToDate), 0)
),

-- 2. Aggregate Actual Data (WORD COUNT)
ActualData AS (
    SELECT 
        DATEADD(MONTH, DATEDIFF(MONTH, 0, PWPD.WeekDate), 0) AS MonthStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,

        -- ✅ Word Count
        SUM(
            LEN(PWPDL.ActualDescription)
            - LEN(REPLACE(PWPDL.ActualDescription, ' ', '')) + 1
        ) AS ActualWordCount

    FROM Projects P
    INNER JOIN VW_CustomerProjectList CPL ON CPL.Id = P.Id
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId

    WHERE 
        P.Deleted &lt;&gt; 1
        AND PWPDL.Deleted &lt;&gt; 1
        AND PWPDL.ActualDescription IS NOT NULL
        AND LTRIM(RTRIM(PWPDL.ActualDescription)) &lt;&gt; ''
        AND D.Id = 'A2F7DA83-A804-4ACE-914D-F0B6E9F63A39'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
        AND CPL.CustomerId IN (@CustomerName)
        AND CPL.Id IN (@Projects)
        AND P.ProjectStatusId IN (@ProjectStatus)
        AND P.ProjectTypeId IN (@ProjectType)
        AND P.ProjectPriorityId IN (@ProjectPriority)
        AND ISNULL(P.ProjectCategoryId,'') IN (@ProjectCategory)
        AND ISNULL(P.ProjectSubcategoryId,'') IN (@ProjectSubcategory)

    GROUP BY 
        DATEADD(MONTH, DATEDIFF(MONTH, 0, PWPD.WeekDate), 0),
        P.Id, P.Name, P.Active
),

-- 3. Aggregate Expected Data (WORD COUNT)
ExpectedData AS (
    SELECT 
        DATEADD(MONTH, DATEDIFF(MONTH, 0, PWPD.WeekDate), 0) AS MonthStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,

        -- ✅ Word Count
        SUM(
            LEN(PWPDL.ExpectedDescription)
            - LEN(REPLACE(PWPDL.ExpectedDescription, ' ', '')) + 1
        ) AS ExpectedWordCount

    FROM Projects P
    INNER JOIN VW_CustomerProjectList CPL ON CPL.Id = P.Id
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId

    WHERE 
        P.Deleted &lt;&gt; 1
        AND PWPDL.Deleted &lt;&gt; 1
        AND PWPDL.ExpectedDescription IS NOT NULL
        AND LTRIM(RTRIM(PWPDL.ExpectedDescription)) &lt;&gt; ''
        AND D.Id = 'A2F7DA83-A804-4ACE-914D-F0B6E9F63A39'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
        AND CPL.CustomerId IN (@CustomerName)
        AND CPL.Id IN (@Projects)
        AND P.ProjectStatusId IN (@ProjectStatus)
        AND P.ProjectTypeId IN (@ProjectType)
        AND P.ProjectPriorityId IN (@ProjectPriority)
        AND ISNULL(P.ProjectCategoryId,'') IN (@ProjectCategory)
        AND ISNULL(P.ProjectSubcategoryId,'') IN (@ProjectSubcategory)

    GROUP BY 
        DATEADD(MONTH, DATEDIFF(MONTH, 0, PWPD.WeekDate), 0),
        P.Id, P.Name, P.Active
),

-- 4. All Projects
AllProjects AS (
    SELECT DISTINCT ProjectId, Project, StatusId, Status
    FROM (
        SELECT ProjectId, Project, StatusId, Status FROM ActualData
        UNION
        SELECT ProjectId, Project, StatusId, Status FROM ExpectedData
    ) p
)

-- 5. Final Output (FOR SSRS)
SELECT
    M.MonthStart AS [Date],   -- for column grouping
    FORMAT(M.MonthStart, 'MMMM yyyy') AS MonthName,
    P.ProjectId,
    P.Project,
    P.StatusId,
    P.Status,
    ISNULL(E.ExpectedWordCount, 0) AS PlannedTarget,
    ISNULL(A.ActualWordCount, 0) AS TargetAchieved
FROM MonthsCTE M
CROSS JOIN AllProjects P
LEFT JOIN ActualData A 
    ON A.MonthStart = M.MonthStart AND A.ProjectId = P.ProjectId
LEFT JOIN ExpectedData E
    ON E.MonthStart = M.MonthStart AND E.ProjectId = P.ProjectId
ORDER BY M.MonthStart, P.ProjectId
OPTION (MAXRECURSION 0);</CommandText>
      </Query>
      <Fields>
        <Field Name="Date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>Date</DataField>
        </Field>
        <Field Name="MonthName">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MonthName</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
        <Field Name="PlannedTarget">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>PlannedTarget</DataField>
        </Field>
        <Field Name="TargetAchieved">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>TargetAchieved</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Weekly_Summary_Count">
      <Query>
        <DataSourceName>ProjectWeeklyPlanner</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CustomerName">
            <Value>=Parameters!CustomerName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Projects">
            <Value>=Parameters!Projects.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectStatus">
            <Value>=Parameters!ProjectStatus.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectType">
            <Value>=Parameters!ProjectType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectPriority">
            <Value>=Parameters!ProjectPriority.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectCategory">
            <Value>=Parameters!ProjectCategory.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectSubcategory">
            <Value>=Parameters!ProjectSubcategory.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SET DATEFIRST 1;  -- Week starts Monday

;WITH WeekRange AS (
    SELECT DISTINCT
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, TheDate), TheDate) AS WeekStart,
        DATEADD(DAY, 7 - DATEPART(WEEKDAY, TheDate), TheDate) AS WeekEnd
    FROM DimDate
    WHERE TheDate BETWEEN @FromDate AND @ToDate
),

/* =========================
   ACTUAL WORD COUNT
   ========================= */
ActualData AS (
    SELECT
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, PWPD.WeekDate), CAST(PWPD.WeekDate AS DATE)) AS WeekStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,

        SUM(
            CASE 
                WHEN LTRIM(RTRIM(PWPDL.ActualDescription)) = '' THEN 0
                ELSE LEN(LTRIM(RTRIM(PWPDL.ActualDescription)))
                     - LEN(REPLACE(LTRIM(RTRIM(PWPDL.ActualDescription)), ' ', '')) + 1
            END
        ) AS ActualWordCount

    FROM Projects P
    INNER JOIN VW_CustomerProjectList CPL ON CPL.Id = P.Id
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId

    WHERE
        P.Deleted &lt;&gt; 1
        AND PWPDL.Deleted &lt;&gt; 1
        AND PWPDL.ActualDescription IS NOT NULL
        AND LTRIM(RTRIM(PWPDL.ActualDescription)) &lt;&gt; ''
        AND D.Id = '1CFDEC9F-9C68-4E75-BC4E-E408C5918B1A'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
        AND CPL.CustomerId IN (@CustomerName)
        AND CPL.Id IN (@Projects)
        AND P.ProjectStatusId IN (@ProjectStatus)
        AND P.ProjectTypeId IN (@ProjectType)
        AND P.ProjectPriorityId IN (@ProjectPriority)
        AND ISNULL(P.ProjectCategoryId,'') IN (@ProjectCategory)
        AND ISNULL(P.ProjectSubcategoryId,'') IN (@ProjectSubcategory)

    GROUP BY
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, PWPD.WeekDate), CAST(PWPD.WeekDate AS DATE)),
        P.Id, P.Name, P.Active
),

/* =========================
   EXPECTED WORD COUNT
   ========================= */
ExpectedData AS (
    SELECT
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, PWPD.WeekDate), CAST(PWPD.WeekDate AS DATE)) AS WeekStart,
        P.Id AS ProjectId,
        P.Name AS Project,
        CASE WHEN P.Active = 1 THEN 1 ELSE 0 END AS StatusId,
        CASE WHEN P.Active = 1 THEN 'Active' ELSE 'Inactive' END AS Status,

        SUM(
            CASE 
                WHEN LTRIM(RTRIM(PWPDL.ExpectedDescription)) = '' THEN 0
                ELSE LEN(LTRIM(RTRIM(PWPDL.ExpectedDescription)))
                     - LEN(REPLACE(LTRIM(RTRIM(PWPDL.ExpectedDescription)), ' ', '')) + 1
            END
        ) AS ExpectedWordCount

    FROM Projects P
    INNER JOIN VW_CustomerProjectList CPL ON CPL.Id = P.Id
    INNER JOIN Project_WeeklyPlan PW ON PW.ProjectId = P.Id
    INNER JOIN Project_WeeklyPlan_Dates PWPD ON PWPD.ProjectWeeklyPlanId = PW.Id
    INNER JOIN Project_WeeklyPlan_Dates_Lines PWPDL ON PWPDL.ProjectWeeklyPlanDatesId = PWPD.Id
    LEFT JOIN DropDown D ON D.Id = PWPD.PlanTypeId

    WHERE
        P.Deleted &lt;&gt; 1
        AND PWPDL.Deleted &lt;&gt; 1
        AND PWPDL.ExpectedDescription IS NOT NULL
        AND LTRIM(RTRIM(PWPDL.ExpectedDescription)) &lt;&gt; ''
        AND D.Id = '1CFDEC9F-9C68-4E75-BC4E-E408C5918B1A'
        AND PWPD.WeekDate BETWEEN @FromDate AND @ToDate
        AND CPL.CustomerId IN (@CustomerName)
        AND CPL.Id IN (@Projects)
        AND P.ProjectStatusId IN (@ProjectStatus)
        AND P.ProjectTypeId IN (@ProjectType)
        AND P.ProjectPriorityId IN (@ProjectPriority)
        AND ISNULL(P.ProjectCategoryId,'') IN (@ProjectCategory)
        AND ISNULL(P.ProjectSubcategoryId,'') IN (@ProjectSubcategory)

    GROUP BY
        DATEADD(DAY, 1 - DATEPART(WEEKDAY, PWPD.WeekDate), CAST(PWPD.WeekDate AS DATE)),
        P.Id, P.Name, P.Active
),

/* =========================
   PROJECT LIST
   ========================= */
AllProjects AS (
    SELECT DISTINCT ProjectId, Project, StatusId, Status
    FROM (
        SELECT ProjectId, Project, StatusId, Status FROM ActualData
        UNION
        SELECT ProjectId, Project, StatusId, Status FROM ExpectedData
    ) P
)

/* =========================
   FINAL OUTPUT
   ========================= */
SELECT
    W.WeekStart AS [Date],
    FORMAT(W.WeekStart, 'dd MMM yyyy') + ' - ' +
    FORMAT(W.WeekEnd, 'dd MMM yyyy') AS WeekRange,
    P.ProjectId,
    P.Project,
    P.StatusId,
    P.Status,
    ISNULL(E.ExpectedWordCount, 0) AS ExpectedWordCount,
    ISNULL(A.ActualWordCount, 0) AS ActualWordCount

FROM WeekRange W
CROSS JOIN AllProjects P
LEFT JOIN ActualData A 
    ON A.WeekStart = W.WeekStart 
    AND A.ProjectId = P.ProjectId
LEFT JOIN ExpectedData E 
    ON E.WeekStart = W.WeekStart 
    AND E.ProjectId = P.ProjectId

ORDER BY W.WeekStart, P.ProjectId;</CommandText>
      </Query>
      <Fields>
        <Field Name="Date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>Date</DataField>
        </Field>
        <Field Name="WeekRange">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WeekRange</DataField>
        </Field>
        <Field Name="ProjectId">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ProjectId</DataField>
        </Field>
        <Field Name="Project">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Project</DataField>
        </Field>
        <Field Name="StatusId">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>StatusId</DataField>
        </Field>
        <Field Name="Status">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Status</DataField>
        </Field>
        <Field Name="ExpectedWordCount">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>ExpectedWordCount</DataField>
        </Field>
        <Field Name="ActualWordCount">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>ActualWordCount</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
